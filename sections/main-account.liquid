{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account section-{{ section.id }}-padding">
  <div>
    <div class="block__customer-account-page-main flex items-start">
      <div class="block__customer-account-titles-wrapper w-full">
        {% render 'account-menu' %}
      </div>
      <div class="block__customer-account-overview">
        <h4 class="customer-account-detail-title font-weight-600">{{ 'customer.account.title' | t }}</h4>
        <hr>
        <div id="account-details" class="block__customer-account-details">
          <div class="block__account-title flex items-center justify-between">
            <h4 class="primary_h4">{{ 'customer.account.detail_title' | t }}</h4>
            {% comment %} <p class="">Member of the Bedgear Family since <span id="customer_created_at">{{ customer.created_at }}</span> </p> {% endcomment %}
          </div>
          <div class="block__customer-account-profile-wrapper flex items-start gap-20">
            <h3 class="block__customer-account-avatar flex items-center justify-center">
              {{ customer.first_name | split: ' ' | first | slice: 0, 1 -}}
              {{- customer.last_name | split: ' ' | last | slice: 0, 1 }}
            </h3>
            <div class="flex justify-between items-center w-full">
              <div class="block__customer-account-details-inner w-full">
                <h4 class="primary_h4">
                
                {%- if customer.orders.size <= 0 -%}
                  Welcome, {{ customer.name }}!
                  {%- else -%}
                  Welcome back, {{ customer.name }}!    
                {%- endif -%}  
                 </h4>
                <p class="block__customer-account-fullname flex items-center gap-10">
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 18 18"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M3 16.75C3 13.4363 5.68629 10.75 9 10.75C12.3137 10.75 15 13.4363 15 16.75H13.5C13.5 14.2647 11.4853 12.25 9 12.25C6.51472 12.25 4.5 14.2647 4.5 16.75H3ZM9 10C6.51375 10 4.5 7.98625 4.5 5.5C4.5 3.01375 6.51375 1 9 1C11.4862 1 13.5 3.01375 13.5 5.5C13.5 7.98625 11.4862 10 9 10ZM9 8.5C10.6575 8.5 12 7.1575 12 5.5C12 3.8425 10.6575 2.5 9 2.5C7.3425 2.5 6 3.8425 6 5.5C6 7.1575 7.3425 8.5 9 8.5Z" fill="var(--primary-color)" />
                  </svg>
                  {{ customer.name }}
                </p>
                <p class="block__customer-account-email flex items-center gap-10">
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 22 22"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M3.07922 3.84961H18.9192C19.4052 3.84961 19.7992 4.21442 19.7992 4.66442V17.7015C19.7992 18.1515 19.4052 18.5163 18.9192 18.5163H3.07922C2.59321 18.5163 2.19922 18.1515 2.19922 17.7015V4.66442C2.19922 4.21442 2.59321 3.84961 3.07922 3.84961ZM18.0392 7.30273L11.0624 13.088L3.95922 7.28482V16.8866H18.0392V7.30273ZM4.4093 5.47924L11.0537 10.9075L17.6001 5.47924H4.4093Z" fill="var(--primary-color)" />
                  </svg>
                  <span>{{ customer.email }}</span>
                </p>
              </div>
              <div class="block__customer-account-edit-profile">
                <a href="{{ routes.account_addresses_url }}" class="small_body items-center gap-10">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M11.3322 5.92689L10.0731 4.66775L1.78069 12.9602V14.2193H3.03982L11.3322 5.92689ZM12.5913 4.66775L13.8505 3.40862L12.5913 2.14948L11.3322 3.40862L12.5913 4.66775ZM3.77741 16H0V12.2225L11.9618 0.260773C12.3095 -0.0869243 12.8732 -0.0869243 13.2209 0.260773L15.7392 2.77905C16.0869 3.12675 16.0869 3.69049 15.7392 4.03818L3.77741 16Z" fill="white" />
                  </svg>
                  {{ 'customer.account.edit_profile' | t -}}
                </a>
              </div>
            </div>
          </div>
        </div>

        <div id="address-list" class="block_address-list-main">
          <h4 class="block__account-title primary_h4">{{ 'customer.account.address_title' | t }}</h4>
          {%- for address in customer.addresses limit: 1 -%}
            <div class="block__customer-default-address-inner">
              {% comment %} {{ customer.default_address | format_address }} {% endcomment %}
              <div class="block_address_box">
                <p class="block__account-tabs-address-person-name medium_body font-weight-600">
                  {{ address.first_name }}
                  {{ address.last_name }}!
                </p>
                <div class="block__account-tabs-address">
                  {% if address.address1 != blank %}
                    {{ address.address1 }},
                  {% endif %}
                  {% if address.address2 != blank %}
                    {{ address.address2 }}
                    <br>
                  {% endif %}
                  {% if address.city != blank %}
                    {{ address.city }}
                    {% if address.zip != blank %}- {{ address.zip }}{% endif %},
                  {% endif %}
                  {{ address.country }}
                </div>
                <div class="block__address-buttons">
                  <div class="w-full flex items-center gap-20" data-address>
                    <a
                      href="{{ routes.account_addresses_url }}"
                      class="block__edit-address-button senary-border-radius font-weight-600"
                    >
                      {{- 'customer.addresses.edit_address' | t -}}
                    </a>
                    <button
                      type="button"
                      aria-controls="AddAddress"
                      class="block__add-address-button font-weight-600"
                    >
                      {{- 'customer.addresses.add' | t -}}
                    </button>
                  </div>
                  <div id="AddAddress" class="w-full block__address-tab">
                    <h3 id="AddressNewHeading">{{ 'customer.addresses.add_new' | t }}</h3>
                    {%- form 'customer_address', customer.new_address, aria-labelledBy: 'AddressNewHeading' -%}
                      <div class="field">
                        <input
                          type="text"
                          id="AddressFirstNameNew"
                          name="address[first_name]"
                          value="{{ form.first_name }}"
                          autocomplete="given-name"
                          placeholder="{{ 'customer.addresses.first_name' | t }}"
                          class="AddressName"
                          required
                        >
                        <label for="AddressFirstNameNew">{{ 'customer.addresses.first_name' | t }}</label>
                      </div>
                      <div class="field">
                        <input
                          type="text"
                          id="AddressLastNameNew"
                          name="address[last_name]"
                          value="{{ form.last_name }}"
                          autocomplete="family-name"
                          placeholder="{{ 'customer.addresses.last_name' | t }}"
                          class="AddressName"
                          required
                        >
                        <label for="AddressLastNameNew">{{ 'customer.addresses.last_name' | t }}</label>
                      </div>
                      <div class="field">
                        <input
                          type="text"
                          id="AddressCompanyNew"
                          name="address[company]"
                          value="{{ form.company }}"
                          autocomplete="organization"
                          placeholder="{{ 'customer.addresses.company' | t }}"
                          required
                        >
                        <label for="AddressCompanyNew">{{ 'customer.addresses.company' | t }}</label>
                      </div>
                      <div class="field">
                        <input
                          type="text"
                          id="AddressAddress1New"
                          name="address[address1]"
                          value="{{ form.address1 }}"
                          autocomplete="address-line1"
                          placeholder="{{ 'customer.addresses.address1' | t }}"
                          required
                        >
                        <label for="AddressAddress1New">{{ 'customer.addresses.address1' | t }}</label>
                      </div>
                      <div class="field">
                        <input
                          type="text"
                          id="AddressAddress2New"
                          name="address[address2]"
                          value="{{ form.address2 }}"
                          autocomplete="address-line2"
                          placeholder="{{ 'customer.addresses.address2' | t }}"
                          required
                        >
                        <label for="AddressAddress2New">{{ 'customer.addresses.address2' | t }}</label>
                      </div>
                      <div class="field">
                        <input
                          type="text"
                          id="AddressCityNew"
                          name="address[city]"
                          value="{{ form.city }}"
                          autocomplete="address-level2"
                          placeholder="{{ 'customer.addresses.city' | t }}"
                          class="AddressName"
                          required
                        >
                        <label for="AddressCityNew">{{ 'customer.addresses.city' | t }}</label>
                      </div>
                      <div class="select-field">
                        <label for="AddressCountryNew">{{ 'customer.addresses.country' | t }}</label>
                        <div class="select">
                          <select
                            id="AddressCountryNew"
                            name="address[country]"
                            data-default="{{ form.country }}"
                            autocomplete="country"
                          >
                            {{ all_country_option_tags }}
                          </select>
                          <span class="svg-wrapper">
                            {{- 'icon-caret.svg' | inline_asset_content -}}
                          </span>
                        </div>
                      </div>
                      <div id="AddressProvinceContainerNew" style="display: none">
                        <label for="AddressProvinceNew">{{ 'customer.addresses.province' | t }}</label>
                        <div class="select">
                          <select
                            id="AddressProvinceNew"
                            name="address[province]"
                            data-default="{{ form.province }}"
                            autocomplete="address-level1"
                          ></select>
                          <span class="svg-wrapper">
                            {{- 'icon-caret.svg' | inline_asset_content -}}
                          </span>
                        </div>
                      </div>
                      <div class="field">
                        <input
                          type="text"
                          id="AddressZipNew"
                          name="address[zip]"
                          value="{{ form.zip }}"
                          autocapitalize="characters"
                          autocomplete="postal-code"
                          placeholder="{{ 'customer.addresses.zip' | t }}"
                          class="AddressNumber"
                          required
                        >
                        <label for="AddressZipNew">{{ 'customer.addresses.zip' | t }}</label>
                      </div>
                      <div class="field">
                        <input
                          type="tel"
                          id="AddressPhoneNew"
                          name="address[phone]"
                          value="{{ form.phone }}"
                          autocomplete="tel"
                          placeholder="{{ 'customer.addresses.phone' | t }}"
                          class="AddressNumber"
                          required
                        >
                        <label for="AddressPhoneNew">{{ 'customer.addresses.phone' | t }}</label>
                      </div>
                      <div class="block__set-as-default-button">
                        {{ form.set_as_default_checkbox }}
                        <label for="address_default_address_new">{{ 'customer.addresses.set_default' | t }}</label>
                      </div>
                      <div class="block__add-address-button-inner">
                        <button class="add-address-button">{{ 'customer.addresses.add' | t }}</button>
                        <button type="reset" class="reset-address-button">{{ 'customer.addresses.cancel' | t }}</button>
                      </div>
                    {%- endform -%}
                  </div>
                  {% comment %}
                    <a
                    href="{{ routes.account_addresses_url }}"
                    class="block__add-address-button senary-border-radius font-weight-600"
                    >
                    {{- 'customer.addresses.add' | t -}}
                    </a>
                  {% endcomment %}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div id="order-history" class="block_custmers-order">
          {% render 'customers-order' %}
        </div>
        {% comment %}
          <h3>{{ 'customer.orders.title' | t }}</h3>

          {% paginate customer.orders by 20 %}
          {%- if customer.orders.size > 0 -%}
          <table role="table" class="order-history">
          <caption class="visually-hidden">
          {{ 'customer.orders.title' | t }}
          </caption>
          <thead role="rowgroup">
          <tr role="row">
          <th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
          <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
          <th id="ColumnPayment" scope="col" role="columnheader">
          {{ 'customer.orders.payment_status' | t }}
          </th>
          <th id="ColumnFulfillment" scope="col" role="columnheader">
          {{ 'customer.orders.fulfillment_status' | t }}
          </th>
          <th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th>
          </tr>
          </thead>
          <tbody role="rowgroup">
          {%- for order in customer.orders -%}
          <tr role="row">
          <td
          id="RowOrder"
          role="cell"
          headers="ColumnOrder"
          data-label="{{ 'customer.orders.order_number' | t }}"
          >
          <a
          href="{{ order.customer_url }}"
          aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
          >
          {{ order.name }}
          </a>
          </td>
          <td headers="RowOrder ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t }}">
          {{ order.created_at | time_tag: format: 'date' }}
          </td>
          <td
          headers="RowOrder ColumnPayment"
          role="cell"
          data-label="{{ 'customer.orders.payment_status' | t }}"
          >
          {{ order.financial_status_label }}
          </td>
          <td
          headers="RowOrder ColumnFulfillment"
          role="cell"
          data-label="{{ 'customer.orders.fulfillment_status' | t }}"
          >
          {{ order.fulfillment_status_label }}
          </td>
          <td headers="RowOrder ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t }}">
          {{ order.total_net_amount | money_with_currency }}
          </td>
          </tr>
          {%- endfor -%}
          </tbody>
          </table>
          {%- else -%}
          <p>{{ 'customer.orders.none' | t }}</p>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
          {%- if paginate.parts.size > 0 -%}
          <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
          <ul role="list">
          {%- if paginate.previous -%}
          <li>
          <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
          <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
          </span>
          </a>
          </li>
          {%- endif -%}

          {%- for part in paginate.parts -%}
          <li>
          {%- if part.is_link -%}
          <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
          {{- part.title -}}
          </a>
          {%- else -%}
          {%- if part.title == paginate.current_page -%}
          <span
          aria-current="page"
          aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
          >
          {{- part.title -}}
          </span>
          {%- else -%}
          <span>{{ part.title }}</span>
          {%- endif -%}
          {%- endif -%}
          </li>
          {%- endfor -%}

          {%- if paginate.next -%}
          <li>
          <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
          <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
          </span>
          </a>
          </li>
          {%- endif -%}
          </ul>
          </nav>
          {%- endif -%}
          {%- endif -%}
          {% endpaginate %}
        {% endcomment %}
      </div>
    </div>
  </div>
</div>

<script>
  window.addEventListener('load', () => {
    typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
  });
</script>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "name": "Account Pages Link",
      "type": "Link",
      "settings": [
        {
          "type": "image_picker",
          "id": "menu_logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "menu_text",
          "label": "Menu Label"
        },
        {
          "type": "url",
          "id": "menu_url",
          "label": "Menu Url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-account.name",
      "blocks": [
        {
          "type": "Link"
        }
      ]
    }
  ]
}
{% endschema %}
