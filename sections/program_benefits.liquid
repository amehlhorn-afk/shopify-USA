{% comment %}
  Loyalty Program Benefits Section
  Block-based comparison table for program tiers
{% endcomment %}

<style>
  .loyalty-benefits {
    font-family: 'Roboto', sans-serif;
    background: #ffffff;
    width: 100%;
  }

  .loyalty-benefits__container {
    max-width: 1600px;
    margin: 0 auto;
    padding-left: 50px;
    padding-right: 50px;
  }

  .loyalty-benefits__header {
    text-align: center;
    margin-bottom: 60px;
  }

  .loyalty-benefits__title {
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1.3;
    margin: 0 0 24px 0;
  }

  .loyalty-benefits__intro {
    font-family: 'Roboto', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 28px;
    color: #666;
    margin: 0;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Table Wrapper */
  .loyalty-benefits__table-wrapper {
    background: #f5f5f5;
    max-width: 1021px;
    margin: 0 auto;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
  }

  /* Table */
  .loyalty-benefits__table {
    width: 100%;
    border-collapse: collapse;
    background: #f5f5f5;
    min-width: 600px;
  }

  .loyalty-benefits__table thead {
    background: #000000;
  }

  .loyalty-benefits__table th {
    font-family: 'DIN', 'Roboto', sans-serif;
    font-weight: 700;
    font-size: 19.544px;
    line-height: 30.399px;
    letter-spacing: 3.5179px;
    text-transform: uppercase;
    padding: 24px 16px;
    text-align: center;
    color: #ffffff;
    background: #000000;
  }

  .loyalty-benefits__table th:first-child {
    text-align: left;
    padding-left: 37px;
  }

  .loyalty-benefits__table tbody tr {
    border-bottom: 1px solid #dddddd;
  }

  .loyalty-benefits__table tbody tr:last-child {
    border-bottom: none;
  }

  .loyalty-benefits__table td {
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    font-size: 17px;
    line-height: 1.5;
    letter-spacing: 0.34px;
    padding: 20px 16px;
    text-align: center;
    vertical-align: middle;
    background: #f5f5f5;
  }

  .loyalty-benefits__table td:first-child {
    text-align: left;
    padding-left: 37px;
  }

  .loyalty-benefits__table td:nth-child(2) {
    background: #ffffff;
  }

  .loyalty-benefits__table td:nth-child(3) {
    background: #f5f5f5;
  }

  .loyalty-benefits__checkmark {
    font-family: 'Roboto', 'Noto Sans', sans-serif;
    font-size: 22.152px;
    line-height: 22px;
    letter-spacing: 0.2215px;
  }

  .loyalty-benefits__asterisk {
    font-family: 'Roboto', sans-serif;
    font-size: 18.152px;
    vertical-align: super;
    margin-left: 2px;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .loyalty-benefits__container {
      padding-left: 20px;
      padding-right: 20px;
    }

    .loyalty-benefits__header {
      margin-bottom: 40px;
    }

    .loyalty-benefits__title {
      font-size: 32px;
      margin-bottom: 16px;
    }

    .loyalty-benefits__intro {
      font-size: 16px;
      line-height: 24px;
    }

    .loyalty-benefits__table th {
      font-size: 14px;
      padding: 16px 8px;
      letter-spacing: 2px;
    }

    .loyalty-benefits__table th:first-child {
      padding-left: 12px;
    }

    .loyalty-benefits__table td {
      font-size: 14px;
      line-height: 1.6;
      padding: 16px 8px;
    }

    .loyalty-benefits__table td:first-child {
      padding-left: 12px;
      font-size: 13px;
    }

    .loyalty-benefits__checkmark {
      font-size: 18px;
    }
  }

  @media (max-width: 480px) {
    .loyalty-benefits__title {
      font-size: 28px;
    }

    .loyalty-benefits__intro {
      font-size: 14px;
      line-height: 22px;
    }

    .loyalty-benefits__table {
      min-width: 500px;
    }

    .loyalty-benefits__table th {
      font-size: 12px;
      padding: 14px 6px;
    }

    .loyalty-benefits__table th:first-child {
      padding-left: 10px;
    }

    .loyalty-benefits__table td {
      font-size: 12px;
      line-height: 1.5;
      padding: 14px 6px;
    }

    .loyalty-benefits__table td:first-child {
      font-size: 11px;
      padding-left: 10px;
    }
  }
</style>

<section class="loyalty-benefits" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
