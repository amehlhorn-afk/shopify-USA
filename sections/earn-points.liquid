{% comment %}
  Loyalty Ways to Earn Section
  Block-based section with icon cards and CTAs
{% endcomment %}

<style>
  .loyalty-earn {
    font-family: 'Roboto', sans-serif;
    width: 100%;
    padding-left: 40px;
    padding-right: 40px;
  }

  .loyalty-earn__wrapper {
    position: relative;
    max-width: 1520px;
    margin: 0 auto;
    border-radius: 32px;
    overflow: hidden;
  }

  .loyalty-earn__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .loyalty-earn__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .loyalty-earn__bg-image--mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .loyalty-earn__bg-image--desktop {
      display: none;
    }

    .loyalty-earn__bg-image--mobile {
      display: block;
    }
  }

  .loyalty-earn__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 15, 43, 0.46);
    z-index: 2;
  }

  .loyalty-earn__container {
    position: relative;
    z-index: 3;
    max-width: 1116px;
    margin: 0 auto;
    padding: 60px 40px;
    text-align: center;
  }

  .loyalty-earn__header {
    margin-bottom: 39px;
  }

  .loyalty-earn__title {
    font-family: 'DIN', 'Roboto', sans-serif;
    font-weight: 700;
    font-size: 33.152px;
    line-height: 36.17px;
    letter-spacing: 1.6576px;
    text-transform: uppercase;
    margin: 0 0 23px 0;
    color: inherit;
  }

  .loyalty-earn__subtitle {
    font-family: 'DIN', 'Roboto', sans-serif;
    font-style: italic;
    font-size: 21.938px;
    line-height: 26.117px;
    margin: 0;
    max-width: 700px;
    margin: 0 auto;
    color: inherit;
  }

  .loyalty-earn__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 19px;
    margin-bottom: 39px;
  }

  .loyalty-earn__card {
    border: 2px solid currentColor;
    border-radius: 22px;
    padding: 27px 16px 20px;
    min-height: 142px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }

  .loyalty-earn__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .loyalty-earn__card-icon img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .loyalty-earn__card-text {
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 20.506px;
    text-align: center;
    margin: 0;
    color: inherit;
  }

  .loyalty-earn__buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .loyalty-earn__button {
    font-family: 'DIN', 'Roboto', sans-serif;
    font-weight: 700;
    font-size: 17px;
    line-height: 19.171px;
    letter-spacing: 0.85px;
    text-transform: uppercase;
    padding: 13.42px 38.341px;
    border-radius: 69.015px;
    border: 0;
    background: #000000;
    color: #ffffff;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    white-space: nowrap;
  }

  .loyalty-earn__button:hover {
    background: #ffffff;
    color: #000000;
    transform: translateY(-2px);
  }

  /* Mobile Responsive */
  @media (max-width: 1200px) {
    .loyalty-earn__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .loyalty-earn {
      padding-left: 0;
      padding-right: 0;
    }

    .loyalty-earn__wrapper {
      border-radius: 0;
    }

    .loyalty-earn__container {
      padding: 50px 20px;
    }

    .loyalty-earn__title {
      font-size: 28px;
      line-height: 32px;
      margin-bottom: 16px;
    }

    .loyalty-earn__subtitle {
      font-size: 18px;
      line-height: 24px;
    }

    .loyalty-earn__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-bottom: 30px;
    }

    .loyalty-earn__card {
      min-height: 130px;
      padding: 20px 12px 16px;
    }

    .loyalty-earn__card-icon {
      width: 40px;
      height: 40px;
    }

    .loyalty-earn__card-text {
      font-size: 14px;
      line-height: 18px;
    }

    .loyalty-earn__buttons {
      flex-direction: column;
      width: 100%;
    }

    .loyalty-earn__button {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .loyalty-earn__wrapper {
      border-radius: 0;
    }

    .loyalty-earn__container {
      padding: 40px 20px;
    }

    .loyalty-earn__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .loyalty-earn__title {
      font-size: 24px;
      line-height: 28px;
    }

    .loyalty-earn__subtitle {
      font-size: 16px;
      line-height: 22px;
    }

    .loyalty-earn__card {
      min-height: 120px;
    }

    .loyalty-earn__card-text {
      font-size: 13px;
    }
  }
</style>

<section class="loyalty-earn" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; {% if section.settings.text_color %}color: {{ section.settings.text_color }};{% endif %}">
  <div class="loyalty-earn__wrapper">
    
    {% if section.settings.background_image %}
      <div class="loyalty-earn__bg">
      <img 
        class="loyalty-earn__bg-image loyalty-earn__bg-image--desktop"
        src="{{ section.settings.background_image | img_url: '1920x' }}"
        srcset="{{ section.settings.background_image | img_url: '800x' }} 800w,
                {{ section.settings.background_image | img_url: '1200x' }} 1200w,
                {{ section.settings.background_image | img_url: '1920x' }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.title }}"
        loading="lazy"
      >
      {% if section.settings.background_image_mobile %}
        <img 
          class="loyalty-earn__bg-image loyalty-earn__bg-image--mobile"
          src="{{ section.settings.background_image_mobile | img_url: '800x' }}"
          srcset="{{ section.settings.background_image_mobile | img_url: '400x' }} 400w,
                  {{ section.settings.background_image_mobile | img_url: '800x' }} 800w"
          sizes="100vw"
          alt="{{ section.settings.title }}"
          loading="lazy"
        >
      {% else %}
        <img 
          class="loyalty-earn__bg-image loyalty-earn__bg-image--mobile"
          src="{{ section.settings.background_image | img_url: '800x' }}"
          srcset="{{ section.settings.background_image | img_url: '400x' }} 400w,
                  {{ section.settings.background_image | img_url: '800x' }} 800w"
          sizes="100vw"
          alt="{{ section.settings.title }}"
          loading="lazy"
        >
      {% endif %}
      <div class="loyalty-earn__overlay"></div>
    </div>
  {% endif %}

  <div class="loyalty-earn__container">
    
    {% for block in section.blocks %}
      {% case block.type %}
        
        {% when 'header' %}
          <div class="loyalty-earn__header">
            {% if block.settings.title != blank %}
              <h2 class="loyalty-earn__title">{{ block.settings.title }}</h2>
            {% endif %}
            {% if block.settings.subtitle != blank %}
              <p class="loyalty-earn__subtitle">{{ block.settings.subtitle }}</p>
            {% endif %}
          </div>

        {% when 'card_grid' %}
          <div class="loyalty-earn__grid">
            
            {% if block.settings.card_1_text != blank %}
              {% if block.settings.card_1_link != blank %}
                <a href="{{ block.settings.card_1_link }}" class="loyalty-earn__card">
              {% else %}
                <div class="loyalty-earn__card">
              {% endif %}
                <div class="loyalty-earn__card-icon">
                  {% if block.settings.card_1_icon %}
                    <img src="{{ block.settings.card_1_icon | img_url: '100x' }}" alt="{{ block.settings.card_1_text }}">
                  {% endif %}
                </div>
                <p class="loyalty-earn__card-text">{{ block.settings.card_1_text }}</p>
              {% if block.settings.card_1_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}

            {% if block.settings.card_2_text != blank %}
              {% if block.settings.card_2_link != blank %}
                <a href="{{ block.settings.card_2_link }}" class="loyalty-earn__card">
              {% else %}
                <div class="loyalty-earn__card">
              {% endif %}
                <div class="loyalty-earn__card-icon">
                  {% if block.settings.card_2_icon %}
                    <img src="{{ block.settings.card_2_icon | img_url: '100x' }}" alt="{{ block.settings.card_2_text }}">
                  {% endif %}
                </div>
                <p class="loyalty-earn__card-text">{{ block.settings.card_2_text }}</p>
              {% if block.settings.card_2_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}

            {% if block.settings.card_3_text != blank %}
              {% if block.settings.card_3_link != blank %}
                <a href="{{ block.settings.card_3_link }}" class="loyalty-earn__card">
              {% else %}
                <div class="loyalty-earn__card">
              {% endif %}
                <div class="loyalty-earn__card-icon">
                  {% if block.settings.card_3_icon %}
                    <img src="{{ block.settings.card_3_icon | img_url: '100x' }}" alt="{{ block.settings.card_3_text }}">
                  {% endif %}
                </div>
                <p class="loyalty-earn__card-text">{{ block.settings.card_3_text }}</p>
              {% if block.settings.card_3_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}

            {% if block.settings.card_4_text != blank %}
              {% if block.settings.card_4_link != blank %}
                <a href="{{ block.settings.card_4_link }}" class="loyalty-earn__card">
              {% else %}
                <div class="loyalty-earn__card">
              {% endif %}
                <div class="loyalty-earn__card-icon">
                  {% if block.settings.card_4_icon %}
                    <img src="{{ block.settings.card_4_icon | img_url: '100x' }}" alt="{{ block.settings.card_4_text }}">
                  {% endif %}
                </div>
                <p class="loyalty-earn__card-text">{{ block.settings.card_4_text }}</p>
              {% if block.settings.card_4_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}

            {% if block.settings.card_5_text != blank %}
              {% if block.settings.card_5_link != blank %}
                <a href="{{ block.settings.card_5_link }}" class="loyalty-earn__card">
              {% else %}
                <div class="loyalty-earn__card">
              {% endif %}
                <div class="loyalty-earn__card-icon">
                  {% if block.settings.card_5_icon %}
                    <img src="{{ block.settings.card_5_icon | img_url: '100x' }}" alt="{{ block.settings.card_5_text }}">
                  {% endif %}
                </div>
                <p class="loyalty-earn__card-text">{{ block.settings.card_5_text }}</p>
              {% if block.settings.card_5_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}

            {% if block.settings.card_6_text != blank %}
              {% if block.settings.card_6_link != blank %}
                <a href="{{ block.settings.card_6_link }}" class="loyalty-earn__card">
              {% else %}
                <div class="loyalty-earn__card">
              {% endif %}
                <div class="loyalty-earn__card-icon">
                  {% if block.settings.card_6_icon %}
                    <img src="{{ block.settings.card_6_icon | img_url: '100x' }}" alt="{{ block.settings.card_6_text }}">
                  {% endif %}
                </div>
                <p class="loyalty-earn__card-text">{{ block.settings.card_6_text }}</p>
              {% if block.settings.card_6_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}

          </div>

        {% when 'buttons' %}
          <div class="loyalty-earn__buttons">
            {% if block.settings.button_1_text != blank %}
              <a href="{{ block.settings.button_1_link }}" class="loyalty-earn__button">
                {{ block.settings.button_1_text }}
              </a>
            {% endif %}

            {% if block.settings.button_2_text != blank %}
              <a href="{{ block.settings.button_2_link }}" class="loyalty-earn__button">
                {{ block.settings.button_2_text }}
              </a>
            {% endif %}
          </div>

      {% endcase %}
    {% endfor %}

  </div>
  </div>
</section>

{% schema %}
{
  "name": "Ways to Earn",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Desktop Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop Background Image",
      "info": "Recommended: 1920x600px or larger"
    },
    {
      "type": "header",
      "content": "Mobile Background"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile Background Image (Optional)",
      "info": "If not set, desktop image will be used. Recommended: 800x800px or larger"
    },
    {
      "type": "header",
      "content": "Text Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Border Color",
      "default": "#ffffff",
      "info": "Applies to all text, card borders, and icons"
    }
  ],
  "blocks": [
    {
      "type": "header",
      "name": "Section Header",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "WAYS TO EARN POINTS"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "people should be able to immediately take action on these items if they are logged in. We should include an instruction blurb if necessary"
        }
      ]
    },
    {
      "type": "card_grid",
      "name": "Earn Cards",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Upload icons and set text/links for each card. Leave text blank to hide a card."
        },
        {
          "type": "header",
          "content": "Card 1"
        },
        {
          "type": "image_picker",
          "id": "card_1_icon",
          "label": "Icon",
          "info": "Default: Star icon"
        },
        {
          "type": "text",
          "id": "card_1_text",
          "label": "Text",
          "default": "Sign up:<br>1000 pts"
        },
        {
          "type": "url",
          "id": "card_1_link",
          "label": "Link (optional)"
        },
        {
          "type": "header",
          "content": "Card 2"
        },
        {
          "type": "image_picker",
          "id": "card_2_icon",
          "label": "Icon",
          "info": "Default: Shopping bag icon"
        },
        {
          "type": "text",
          "id": "card_2_text",
          "label": "Text",
          "default": "Points for purchases"
        },
        {
          "type": "url",
          "id": "card_2_link",
          "label": "Link (optional)"
        },
        {
          "type": "header",
          "content": "Card 3"
        },
        {
          "type": "image_picker",
          "id": "card_3_icon",
          "label": "Icon",
          "info": "Default: People icon"
        },
        {
          "type": "text",
          "id": "card_3_text",
          "label": "Text",
          "default": "Refer a Friend<br>$50"
        },
        {
          "type": "url",
          "id": "card_3_link",
          "label": "Link (optional)"
        },
        {
          "type": "header",
          "content": "Card 4"
        },
        {
          "type": "image_picker",
          "id": "card_4_icon",
          "label": "Icon",
          "info": "Default: Instagram icon"
        },
        {
          "type": "text",
          "id": "card_4_text",
          "label": "Text",
          "default": "Follow Us:<br>500pts"
        },
        {
          "type": "url",
          "id": "card_4_link",
          "label": "Link (optional)"
        },
        {
          "type": "header",
          "content": "Card 5"
        },
        {
          "type": "image_picker",
          "id": "card_5_icon",
          "label": "Icon",
          "info": "Default: Review icon"
        },
        {
          "type": "text",
          "id": "card_5_text",
          "label": "Text",
          "default": "Leave a Review<br>1000 points"
        },
        {
          "type": "url",
          "id": "card_5_link",
          "label": "Link (optional)"
        },
        {
          "type": "header",
          "content": "Card 6"
        },
        {
          "type": "image_picker",
          "id": "card_6_icon",
          "label": "Icon",
          "info": "Default: Gift icon"
        },
        {
          "type": "text",
          "id": "card_6_text",
          "label": "Text",
          "default": "Birthday Gift"
        },
        {
          "type": "url",
          "id": "card_6_link",
          "label": "Link (optional)"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "CTA Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_1_text",
          "label": "Button 1 Text",
          "default": "JOIN FREE REWARDS"
        },
        {
          "type": "url",
          "id": "button_1_link",
          "label": "Button 1 Link"
        },
        {
          "type": "text",
          "id": "button_2_text",
          "label": "Button 2 Text",
          "default": "LOGIN"
        },
        {
          "type": "url",
          "id": "button_2_link",
          "label": "Button 2 Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ways to Earn",
      "blocks": [
        {
          "type": "header"
        },
        {
          "type": "card_grid"
        },
        {
          "type": "buttons"
        }
      ]
    }
  ]
}
{% endschema %}
