{%- comment -%}
  Metafield: custom.take_inside_content [metaobject_reference]
  Metaobject fields (flat numbered pattern):
    - inside_image                    [file_reference]      main product cross-section image
    - pdp_section_heading             [single_line_text_field]
    - content_heading_1..4            [single_line_text_field]
    - content_description_1..4        [multi_line_text_field]
    - content_icon_1..4               [file_reference]      (optional icon per layer)
    - content_position_top_side_1..4  [number]              ignored — was used for overlay positioning
    - content_position_left_side_1..4 [number]              ignored — was used for overlay positioning
{%- endcomment -%}

{%- liquid
  assign wi = product.metafields.custom.take_inside_content.value
  assign show = false
  if wi != blank and wi.inside_image != blank
    assign show = true
  endif
-%}

{%- if show -%}
  <div class="product-whats-inside">
    <div class="page-width">

      <p class="product-whats-inside__eyebrow">What's Inside</p>

      <div class="product-whats-inside__grid">

        {%- comment -%} Left: product image {%- endcomment -%}
        <div class="product-whats-inside__media">
          {{-
            wi.inside_image
            | image_url: width: 700
            | image_tag:
              loading: 'lazy',
              widths: '375, 550, 700',
              sizes: '(min-width: 990px) 50vw, 100vw',
              class: 'product-whats-inside__image'
          -}}
        </div>

        {%- comment -%} Right: heading + numbered layer list {%- endcomment -%}
        <div class="product-whats-inside__content">

          {%- if wi.pdp_section_heading != blank -%}
            <h2 class="product-whats-inside__heading">{{ wi.pdp_section_heading }}</h2>
          {%- endif -%}

          <ul class="product-whats-inside__layers" role="list">
            {%- for i in (1..4) -%}
              {%- liquid
                assign heading_key = 'content_heading_'     | append: i
                assign desc_key    = 'content_description_' | append: i
                assign icon_key    = 'content_icon_'        | append: i
                assign layer_heading = wi[heading_key]
                assign layer_desc    = wi[desc_key]
                assign layer_icon    = wi[icon_key]
              -%}
              {%- if layer_heading != blank or layer_desc != blank -%}
                <li class="product-whats-inside__layer">
                  {%- if layer_icon != blank -%}
                    <span class="product-whats-inside__layer-icon" aria-hidden="true">
                      {{- layer_icon | image_url: width: 40 | image_tag: loading: 'lazy', alt: '' -}}
                    </span>
                  {%- else -%}
                    <span class="product-whats-inside__layer-num" aria-hidden="true">{{ i }}</span>
                  {%- endif -%}
                  <div class="product-whats-inside__layer-text">
                    {%- if layer_heading != blank -%}
                      <strong>{{ layer_heading }}</strong>
                    {%- endif -%}
                    {%- if layer_desc != blank -%}
                      <span>{{ layer_desc }}</span>
                    {%- endif -%}
                  </div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>

        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% style %}
  .product-whats-inside {
    background: var(--brand-gray-50);
    padding: 72px 0;
  }

  .product-whats-inside__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--brand-cyan);
    margin-bottom: 14px;
  }

  .product-whats-inside__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .product-whats-inside__image {
    width: 100%;
    border-radius: var(--brand-radius-lg);
    display: block;
  }

  .product-whats-inside__heading {
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: var(--brand-gray-900);
    margin-bottom: 24px;
  }

  .product-whats-inside__layers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-whats-inside__layer {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    font-size: 14px;
    color: var(--brand-gray-600);
    line-height: 1.55;
  }

  .product-whats-inside__layer-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: var(--brand-navy);
    color: var(--brand-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    margin-top: 1px;
  }

  .product-whats-inside__layer-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-whats-inside__layer-icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .product-whats-inside__layer-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .product-whats-inside__layer-text strong {
    display: block;
    font-weight: 700;
    color: var(--brand-gray-900);
    margin-bottom: 2px;
  }

  @media screen and (max-width: 749px) {
    .product-whats-inside { padding: 48px 0; }
    .product-whats-inside__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "What's Inside",
  "settings": [],
  "presets": [{ "name": "What's Inside" }]
}
{% endschema %}
