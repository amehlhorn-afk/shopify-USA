{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'yotpo-loyaly-rewards.css' |  asset_url |  stylesheet_tag }}
{%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
    }
  
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}
{% if page.title contains 'Loyalty Program' %}
  <h1 style="display:none">{{ page.title }}</h1>
{% endif %}
<div class="section-{{ section.id }}-padding color-{{ section.settings.section_color_scheme }}">
    <div class="page-width">
        <div class="block__customer-account-page-main flex items-start">
            <div class="block__customer-account-titles-wrapper w-full">
              {% render 'account-menu' %}
            </div>
            <div class="block__customer-account-overview {% unless customer %}block__no-customer-account{% endunless %}">
                <h4 class="customer-account-detail-title font-weight-600">{{ page.title }}</h4>
                <hr>
                {% for block  in section.blocks %}
                    {%if block.type == 'html' %}
                        {{ block.settings.html_content }}
                 {% endif %}
               {% endfor %}
               {%- if customer -%}
                <div class="yotpo-widget-instance" data-yotpo-instance-id="1008744"></div>
                {%- else -%}
                <div class="yotpo-no-cstomer-widget">
                  <div class="yotpo-no-customer-widget-content">
                    <h4>Earn $10 for Signing Up</h4>
                    <p>Earn points and activate rewards every time you shop with us! It's so simple:</p>
                    <a href="{{ routes.account_register_url }}" class="btn btn--secondary">
                      Earn $10 Now
                    </a>
                  </div>
                  <div class="yotpo-widget-instance" data-yotpo-instance-id="1008744"></div>
                </div>
               {%- endif -%}
                <div class="yotpo-widget-instance" data-yotpo-instance-id="1008743"></div>
                <div class="yotpo-widget-instance" data-yotpo-instance-id="1008742"></div>
                <div class="yotpo-widget-instance" data-yotpo-instance-id="1008740"></div>
            </div>
        </div>
    </div>
</div>
{% schema %}
  {
    "name": "Account Loyalty Rewards",
    "tag": "section",
    "class": "section",
    "settings": [
        {
        "type": "color_scheme",
        "id": "section_color_scheme",
        "label": "Color scheme",
        "default": "scheme-1"
        },
        {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
        },
        {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
        },
        {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
        }
    ],
    "blocks": [
    {
      "name": "Account Pages Link",
      "type": "Link",
      "settings": [
        {
          "type": "image_picker",
          "id": "menu_logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "menu_text",
          "label": "Menu Label"
        },
        {
          "type": "url",
          "id": "menu_url",
          "label": "Menu Url"
        }
      ]
    },
    {
        "type": "html",
        "name":"HTML",
        "settings": [
          {
            "type": "html",
            "id": "html_content",
            "label": "HTML Content"
          }
        ]
    }
  ],
    "presets": [
      {
        "name": "Account Loyalty Rewards"
      }
    ]
  }
{% endschema %}