{{ 'section-bundle-multicolumn.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-bundle-multicolumn">
  <div class="page-width">
    {% if section.settings.title != blank or section.settings.caption != blank %}
      <div class="block__bundle-multicolumn-header">
        {% if section.settings.title != blank %}
          <h2 class="block__bundle-multicolumn-title primary_h2 text-center">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body text-center">{{ section.settings.caption }}</p>
        {% endif %}
      </div>
    {% endif %}
    <div class="block__bundle-multicolumn-row">
      {% for block in section.blocks %}
        <div class="block__bundle-multicolumn-wrapper block__bundle-multicolumn-img-{{ block.settings.img_position }}">
          <div class="block__bundle-multicolumn-img">
            {% if block.settings.video != blank %}
              {{ block.settings.video.src }}
              {% if block.settings.image != blank %}
                {% assign poster = block.settings.image %}
              {% else %}
                {% assign poster = block.settings.video %}
              {% endif %}
              {{
                block.settings.video
                | video_tag:
                  loop: true,
                  autoplay: true,
                  muted: true,
                  playsinline: true,
                  controls: false,
                  width: '100%',
                  height: '100%',
                  poster: poster
              }}
            {% elsif block.settings.image != blank %}
              {%
                render 'custom-image', image: block.settings.image, class: 'img-fluid
                {% elsif block.settings.image != blank
              %}
              {% render 'custom-image', image: block.settings.image, class: 'img-fluid object-cover' %}
            {% endif %}
          </div>
          <div class="block__bundle-multicolumn-info">
            {% if block.settings.subhead != blank %}
              <h6 class="extra_body">{{ block.settings.subhead }}</h6>
            {% endif %}
            {% if block.settings.title != blank %}
              <h4>{{ block.settings.title }}</h4>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="body">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
<div data-revy-bundle-id="a8dc9efe-7e93-4942-a4be-04d2ceb8dae7"></div>
<div data-revy-bundle-id="b15cbf53-95dc-4660-a8ef-5f5397364e07"></div>

{% schema %}
{
  "name": "Bundle Multicolumn",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Select Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "bundle_detail_block",
      "name": "Detail Block",
      "settings": [
        {
          "type": "select",
          "id": "img_position",
          "label": "Media Position",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subhead",
          "label": "Subhead"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Multicolumn"
    }
  ]
}
{% endschema %}
