{{ 'benefits-image-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  @media (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.desktop_padding_top }}px;
      padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    }
  }
  @media (max-width: 989px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
{% endstyle %}

<div class="block__benefits-image-banner color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding {{ section.id }}">
  <div class="page-width">
    <div class="block__benefits-image-banner-wrapper relative">
      {% if section.settings.banner_image %}
        <div class="block__benefits-image-banner-inner relative">
          {% if section.settings.overlay != blank%}
            <span class="w-full h-full block absolute block__overlay_opacity inset-0 quaternary-border-radius"
                  style="background-color: {{ section.settings.color }}; opacity:{{ section.settings.overlay_opacity }}%;">
            </span>
          {% endif %}
          {% render 'custom-image',
            image: section.settings.banner_image,
            class: 'w-full img-fluid block object-cover quaternary-border-radius'
          {% render 'custom-image',
            image: section.settings.banner_image,
            class: 'w-full img-fluid block object-cover quaternary-border-radius'
          %}
        </div>
      {% endif %}
      <div class="block__benefits-image-banner-content absolute">
        <div class="block__benefits-image-banner-heading w-full">
          {% if section.settings.main_heading != blank %}
            <h2 class="primary_h2">{{ section.settings.main_heading }}</h2>
          {% endif %}
          {% if section.settings.main_subheading != blank %}
            <p>{{ section.settings.main_subheading }}</p>
          {% endif %}
        </div>
      </div>
      {% for block in section.blocks %}
        <div class="block__image-banner-content-inner block-{{ block.id }} absolute {% if forloop.index0 == 0 %} block__first-content {% endif %}">
          <div class="block__image-banner-content">
            {% if block.settings.heading != blank %}
              <h4 class="primary_h4">{{ block.settings.heading }}</h4>
            {% endif %}
            {% if block.settings.description != blank %}
              <p>{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% style %}
  
  {% for block in section.blocks %}
     @media (min-width: 1200px) {
      .block__benefits-image-banner-wrapper .block__image-banner-content-inner.block-{{ block.id }} {
        top: {{ block.settings.desktop_vertical_position }}%;
        left: {{ block.settings.desktop_horizontal_position }}%;
        width: auto;
        position: absolute;
      }
      .block__image-banner-content-inner.block-{{ block.id }} .block__image-banner-content{max-width: {{ block.settings.desktop_width }}px;}
      {% if block.settings.show_arrow %}
        .block__benefits-image-banner-wrapper .block__image-banner-content-inner.block-{{ block.id }}::before {
          position: absolute;
          content: '';
          background-image: url("{{ block.settings.arrow_image | img_url: 'master' }}");
          background-repeat: no-repeat;
          background-size: contain;
          width: 100%;
          height: 100%;
          max-width: {{ block.settings.arrow_image_Width | default: '50' }}px;
          left: {{ block.settings.arrow_horizontal_positions }}px;
          top: {{ block.settings.arrow_vertical_positions }}px;
        }
      {% endif %}

      .block__benefits-image-banner-wrapper .block__image-banner-content-inner.block-{{ block.id }}::after {
        left: {{ block.settings.dot_horizontal_positions }}px;
        top: {{ block.settings.dot_vertical_positions }}px;
      }
    }
    .block__benefits-image-banner-wrapper .block__image-banner-content-inner.block-{{ block.id }}::after {
      position: absolute;
      content: '';
      background-image: url("{{ block.settings.dot_image | img_url: 'master' }}");
      background-repeat: no-repeat;
      background-size: contain;
      width: 100%;
      max-width: {{ block.settings.dot_image_Width | default: '30' }}px;
      height: {{ block.settings.dot_image_height | default: '30' }}px;
    }
    @media (max-width:1199px){
      
      .block__benefits-image-banner-wrapper .block__image-banner-content-inner.block-{{ block.id }}::after{
          left: -12px;
          top: 25px;
      }
      
      .block__benefits-image-banner-wrapper .block__image-banner-content-inner.block-{{ block.id }}:not(:last-child)::before{
        background-image: none;
        left: 7px;
        top: 38px;
        border-left: 1px solid var(--border_color);
        width: auto;
        position: absolute;
        content: "";
        height: 100%;
      }
    }
    
  {% endfor %}
  
{% endstyle %}

{% schema %}
{
  "name": "Benefits image banner",
  "tag": "section",
  "class": "shopify",
  "settings": [
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Overlay Background Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "unit": "%",
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "main_subheading",
      "label": "Subheading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "Text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "checkbox",
          "id": "show_arrow",
          "label": "Show Arrow",
          "default": true
        },
        {
          "type": "header",
          "content": "Desktop Positioning Content"
        },
        {
          "type": "range",
          "id": "desktop_horizontal_position",
          "label": "Horizontal position",
          "min": 5,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 5
        },
        {
          "type": "range",
          "id": "desktop_vertical_position",
          "label": "Vertical position",
          "min": 5,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 5
        },
        {
          "type": "range",
          "id": "desktop_width",
          "label": "Max Width For Content",
          "min": 0,
          "max": 500,
          "step": 5,
          "unit": "px",
          "default": 375
        },
        {
          "type": "header",
          "content": "Positioning Arrow" 
        },
        {
          "type": "image_picker",
          "id": "arrow_image",
          "label": "Arrow Image"
        },
        {
          "type": "text",
          "id": "arrow_image_Width",
          "label": "Arrow image width (px)"
        },
        {
          "type": "range",
          "id": "arrow_horizontal_position",
          "label": "Horizontal position",
          "min": 5,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 5
        },
        {
          "type": "range",
          "id": "arrow_vertical_position",
          "label": "Vertical position (PX)",
          "min": 5,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 5
        },
        {
          "type": "text",
          "id": "arrow_horizontal_positions",
          "label": "Horizontal position"
        },
        {
          "type": "text",
          "id": "arrow_vertical_positions",
          "label": "Vertical position (PX)"
        },
        {
          "type": "header",
          "content": "Positioning Dot"
        },
        {
          "type": "image_picker",
          "id": "dot_image",
          "label": "Dot Image"
        },
        {
          "type": "text",
          "id": "dot_image_Width",
          "label": "Dot image width (PX)"
        },
        {
          "type": "text",
          "id": "dot_image_height",
          "label": "Dot image Height (PX)"
        },
        {
          "type": "text",
          "id": "dot_horizontal_positions",
          "label": "Horizontal Position (PX)"
        },
        {
          "type": "text",
          "id": "dot_vertical_positions",
          "label": "Vertical Position (PX)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits image banner",
      "settings": {}
    }
  ]
}
{% endschema %}
