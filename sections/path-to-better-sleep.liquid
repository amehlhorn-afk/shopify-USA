{% comment %}
  Section: Path to Better Sleep Certifications
  Description: Displays certification cards with taglines, icons, titles and descriptions
{% endcomment %}

<section class="path-to-better-sleep" data-section-id="{{ section.id }}">
  <div class="certifications-wrapper">
    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    
    {%- if section.blocks.size > 0 -%}
      <div class="certifications-rows certifications-desktop-only">
        {%- assign cards_per_row = 3 -%}
        {%- assign row_count = section.blocks.size | divided_by: cards_per_row | plus: 1 -%}
        
        {%- for i in (0..row_count) -%}
          {%- assign start_index = i | times: cards_per_row -%}
          {%- assign end_index = start_index | plus: cards_per_row | minus: 1 -%}
          {%- assign row_blocks = section.blocks | slice: start_index, cards_per_row -%}
          
          {%- if row_blocks.size > 0 -%}
            <div class="certifications-row">
              {%- for block in row_blocks -%}
                <div class="certification-card" {{ block.shopify_attributes }}>
                  <div class="card-background"></div>
                  
                  {%- if block.settings.tagline != blank -%}
                    <div class="card-tagline" style="background-color: {{ block.settings.tagline_bg_color }};">
                      <p>{{ block.settings.tagline }}</p>
                    </div>
                  {%- endif -%}
                  
                  <div class="card-content">
                    {%- if block.settings.icon != blank -%}
                      <div class="card-icon">
                        <img 
                          src="{{ block.settings.icon | image_url: width: 240 }}" 
                          alt="{{ block.settings.title }}"
                          width="120"
                          height="120"
                          loading="lazy"
                        >
                      </div>
                    {%- endif -%}
                    
                    <div class="card-text">
                      {%- if block.settings.title != blank -%}
                        <h3 class="card-title">{{ block.settings.title }}</h3>
                      {%- endif -%}
                      
                      {%- if block.settings.description != blank -%}
                        <p class="card-description">{{ block.settings.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="certifications-mobile certifications-mobile-only">
        {%- for block in section.blocks -%}
          <div class="certification-card" {{ block.shopify_attributes }}>
            <div class="card-background"></div>
            
            {%- if block.settings.tagline != blank -%}
              <div class="card-tagline" style="background-color: {{ block.settings.tagline_bg_color }};">
                <p>{{ block.settings.tagline }}</p>
              </div>
            {%- endif -%}
            
            <div class="card-content">
              {%- if block.settings.icon != blank -%}
                <div class="card-icon">
                  <img 
                    src="{{ block.settings.icon | image_url: width: 240 }}" 
                    alt="{{ block.settings.title }}"
                    width="120"
                    height="120"
                    loading="lazy"
                  >
                </div>
              {%- endif -%}
              
              <div class="card-text">
                {%- if block.settings.title != blank -%}
                  <h3 class="card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                
                {%- if block.settings.description != blank -%}
                  <p class="card-description">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.path-to-better-sleep {
  width: 100%;
  background: #ffffff;
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
  position: relative;
  z-index: 0;
  isolation: isolate;
}

.path-to-better-sleep .certifications-wrapper {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 100px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 50px;
  position: relative;
}

.path-to-better-sleep .section-header {
  width: 100%;
  max-width: 722px;
  text-align: center;
}

.path-to-better-sleep .section-title {
  font-family: 'Roboto', sans-serif;
  font-weight: 500;
  font-size: 40px;
  line-height: 1;
  color: #000000;
  margin: 0;
}

.path-to-better-sleep .certifications-mobile-only {
  display: none;
}

.path-to-better-sleep .certifications-desktop-only {
  display: flex;
}

.path-to-better-sleep .certifications-rows {
  width: 100%;
  flex-direction: column;
  gap: 50px;
}

.path-to-better-sleep .certifications-row {
  display: flex;
  gap: 27px;
  justify-content: center;
  align-items: flex-start;
}

.path-to-better-sleep .certification-card {
  position: relative;
  width: 396px;
  height: 540px;
  overflow: hidden;
  background: #ffffff;
  border: 1px solid #dddedf;
  border-radius: 20px;
}

.path-to-better-sleep .card-background {
  display: none;
}

.path-to-better-sleep .card-tagline {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  padding: 23px 37px;
  border-radius: 20px 20px 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.path-to-better-sleep .card-tagline p {
  font-family: 'Roboto', sans-serif;
  font-weight: 600;
  font-size: 16px;
  line-height: 1;
  color: #000000;
  text-align: center;
  text-transform: capitalize;
  margin: 0;
}

.path-to-better-sleep .card-content {
  position: absolute;
  top: 101px;
  left: 27px;
  right: 27px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 27px;
  z-index: 1;
}

.path-to-better-sleep .card-icon {
  width: 120px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.path-to-better-sleep .card-icon img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.path-to-better-sleep .card-text {
  display: flex;
  flex-direction: column;
  gap: 20px;
  width: 100%;
}

.path-to-better-sleep .card-title {
  font-family: 'Roboto', sans-serif;
  font-weight: 500;
  font-size: 28px;
  line-height: 1.2;
  color: #000000;
  text-align: center;
  letter-spacing: 0.28px;
  margin: 0;
}

.path-to-better-sleep .card-description {
  font-family: 'Roboto', sans-serif;
  font-weight: 400;
  font-size: 16px;
  line-height: 26px;
  color: rgba(0, 0, 0, 0.6);
  text-align: left;
  margin: 0;
}

/* Tablet */
@media screen and (max-width: 990px) {
  .path-to-better-sleep {
    padding: {{ section.settings.padding_top | times: 0.75 }}px 0 {{ section.settings.padding_bottom | times: 0.75 }}px 0;
  }
  
  .path-to-better-sleep .certifications-wrapper {
    padding: 0 50px;
    gap: 40px;
  }
  
  .path-to-better-sleep .certifications-rows {
    gap: 40px;
  }
  
  .path-to-better-sleep .certifications-row {
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .path-to-better-sleep .certification-card {
    width: calc(50% - 10px);
    min-width: 320px;
  }
}

/* Mobile */
@media screen and (max-width: 749px) {
  .path-to-better-sleep {
    padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px 0;
  }
  
  .path-to-better-sleep .certifications-wrapper {
    padding: 0 0;
    gap: 32px;
  }

  .path-to-better-sleep .certifications-desktop-only {
    display: none;
  }

  .path-to-better-sleep .certifications-mobile-only {
    display: flex;
  }
  
  .path-to-better-sleep .section-header {
    padding: 0 20px;
  }
  
  .path-to-better-sleep .section-title {
    font-size: 28px;
  }
  
  .path-to-better-sleep .certifications-mobile {
    width: 100%;
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 20px;
    padding: 0 calc(50% - 140px) 20px calc(50% - 140px);
    justify-content: flex-start;
  }
  
  .path-to-better-sleep .certifications-mobile::-webkit-scrollbar {
    display: none;
  }
  
  .path-to-better-sleep .certification-card {
    flex: 0 0 280px;
    width: 280px;
    max-width: 280px;
    min-width: 280px;
    scroll-snap-align: center;
  }
  
  .path-to-better-sleep .card-tagline {
    padding: 18px 20px;
  }
  
  .path-to-better-sleep .card-tagline p {
    font-size: 14px;
  }
  
  .path-to-better-sleep .card-content {
    top: 90px;
    left: 20px;
    right: 20px;
    gap: 20px;
  }
  
  .path-to-better-sleep .card-icon {
    width: 100px;
    height: 100px;
  }
  
  .path-to-better-sleep .card-title {
    font-size: 24px;
  }
  
  .path-to-better-sleep .card-description {
    font-size: 14px;
    line-height: 22px;
  }
}
</style>

{% schema %}
{
  "name": "Path to Better Sleep",
  "tag": "section",
  "class": "section-path-to-better-sleep",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Path to Better Sleep"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "certification",
      "name": "Certification Card",
      "settings": [
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Breath easy, night after night"
        },
        {
          "type": "color",
          "id": "tagline_bg_color",
          "label": "Tagline Background Color",
          "default": "rgba(143, 212, 0, 0.2)"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Certification Icon"
        },
        {
          "type": "html",
          "id": "title",
          "label": "Title",
          "default": "GREENGUARD<br>Gold Certified"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our product is GREENGUARD Gold Certified, which means it helps ensure the air you and your family breathe is cleaner and healthier."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Path to Better Sleep",
      "blocks": [
        {
          "type": "certification",
          "settings": {
            "tagline": "Breath easy, night after night",
