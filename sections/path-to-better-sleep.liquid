            "description": "Our product is GREENGUARD Gold Certified, which means it helps ensure the air you and your family breathe is cleaner and healthier."
          }
        },
        {
          "type": "certification",
          "settings": {
            "tagline": "Gentle on skin. Tough on toxins",
            "tagline_bg_color": "rgba(1, 165, 138, 0.2)",
