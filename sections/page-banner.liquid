{{ 'section-page-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
      .section-{{ section.id }} .block__page-banner-info {
      background-color: {{ section.settings.color }};
      }
  }
  {% if section.settings.text_color != blank %}
    .section-{{ section.id }} .block__page-banner-info h2,
    .section-{{ section.id }} .block__page-banner-info p{color:{{ section.settings.text_color }};}
  {% endif %}
  .section-{{ section.id }} .block__page-banner-info {
    max-width: {{ section.settings.content_max_width }}px;
  }
  .section-{{ section.id }} .block__page-banner-info h1,
  .section-{{ section.id }} .block__page-banner-info h2 {
    font-size: {{ section.settings.title_font_size }}px;
  }
  .section-{{ section.id }} .block__page-banner-info p {
    font-size: {{ section.settings.text_font_size }}px;
  }
  .section-{{ section.id }} .block__page-banner-info a.button-primary {
    margin-top: {{ section.settings.button_spacing }}px !important;
  }
  @media (max-width: 749px) {
    .section-{{ section.id }} .block__page-banner-info {
      max-width: {{ section.settings.content_max_width_mobile }}px;
    }
    .section-{{ section.id }} .block__page-banner-info h1,
    .section-{{ section.id }} .block__page-banner-info h2 {
      font-size: {{ section.settings.title_font_size_mobile }}px;
    }
    .section-{{ section.id }} .block__page-banner-info p {
      font-size: {{ section.settings.text_font_size_mobile }}px;
    }
    .section-{{ section.id }} .block__page-banner-info a.button-primary {
      margin-top: {{ section.settings.button_spacing_m }}px !important;
    }
  }
{% endstyle %}

<div class="section-{{ section.id }} page-banner">
  <div class="page-width">
    <div class="block__page-banner block__page-banner-{{ section.settings.text_position }}">
      <div class="block__page-banner-img">
        {% if section.settings.overlay != blank%}
          <span class="w-full h-full block absolute block__overlay_opacity inset-0 quaternary-border-radius"
                style="background-color: {{ section.settings.overly_color }}; opacity:{{ section.settings.overlay_opacity }}%;">
          </span>
        {% endif %}
        {% assign desktop_img = section.settings.img %}
        {% assign mobile_img = section.settings.img_mobile %}
        {% unless mobile_img != blank %}
          {% assign mobile_img = section.settings.img %}
        {% endunless %}
        {% if desktop_img != blank %}
          <img
            src="{{ desktop_img | image_url: width:desktop_img.width }}"
            alt="{{ desktop_img.alt | default: shop.name }}"
            width=""
            height=""
            class="page-banner-desktop"
            loading="eager"
          >
          <img
            src="{{ mobile_img | image_url: width:mobile_img.width }}"
            alt="{{ mobile_img.alt | default: shop.name }}"
            width=""
            height=""
            class="page-banner-mobile"
            loading="eager"
          >
        {% endif %} 
      </div>
      <div class="block__page-banner-info text-{{ section.settings.text_align }}">
        {% if section.settings.title != blank %}
          <h1 class="h2">{{ section.settings.title }}</h1>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="body">{{ section.settings.text }}</p>
        {% endif %}
        {% if section.settings.btn != blank %}
          <a href="{{ section.settings.url }}" target="_blank" class="block__scroll_sleep-study button-primary senary-border-radius h6">{{ section.settings.btn }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page Banner",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay"
    },
    {
      "type": "color",
      "id": "overly_color",
      "label": "Overlay Background Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "unit": "%",
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Background Image(Desktop)"
    },
    {
      "type": "image_picker",
      "id": "img_mobile",
      "label": "Select Background Image(Mobile)"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 300,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "label": "Content Max Width",
      "default": 800
    },
    {
      "type": "range",
      "id": "content_max_width_mobile",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Content Max Width (Mobile)",
      "default": 400
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Text Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Font Size (Mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_spacing",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Button Top Spacing",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_spacing_m",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Button Top Spacing (Mobile)",
      "default": 20
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text Position on mobile",
      "options": [
        {
          "value": "top",
          "label": "Above Image"
        },
        {
          "value": "bottom",
          "label": "Below Image"
        }
      ],
      "default": "bottom" 
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Page Banner"
    }
  ]
}
{% endschema %}