{{ 'blog-split-content.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="block__blog-split-content-wrapper page-width section-{{ section.id }}-padding">
  {% assign selected_blog = blogs[section.settings.blog] %}
  {% if section.settings.article_handle != blank %}
    {% assign article = selected_blog.articles[section.settings.article_handle] %}
  {% endif %}
  {% if article == blank %}
    {% assign article = selected_blog.articles.first %}
  {% endif %}

  {% if article != blank %}
    <div class="block__blog-split-content-block items-stretch flex justify-between {% if section.settings.split_continer %} block__blog-split-content-rev {% endif %} {% if section.settings.mob_split_continer %} block__blog-split-mob-content-rev {% endif %}" style="background-color: {{ section.settings.color | default: '#ffffff' }};">
      <div class="block__blog-split-image-wrap">
        <a class="block__blog-split-image">
          {%- render 'custom-image', image: article.image, alt: article.title -%}
        </a>
      </div>

      <div
        class="block__blog-split-content"
        style="background-color: {{ section.settings.container_color | default: '#ffffff' }};"
      >
        <div class="block__blog-split-content-wrap flex flex-direction-column h-full text-center items-center justify-center">

          <p class="block__blog-split-blog-title h5 font-weight-600">
            {{ blog.title }}
          </p>

          <div class="block__blog-split-tit-des-wrap">
            <h2 class="block__blog-split-title primary_h2">
              <a class="block__blog-split-title-link">
                {{ article.title }}
              </a>
            </h2>
          </div>

          <h6 class="block__blog-split-article-publi flex items-center">
            {{- 'calendar-icon.svg' | inline_asset_content -}} {{ article.published_at | date: '%B %d, %Y' }}
          </h6>

        </div>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Blog Split",
  "tag": "section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "text",
      "id": "article_handle",
      "label": "Article Handle",
      "info": "Enter the article URL handle to pin a specific article (e.g. 'my-article-title'). Find it after /articles/ in the article URL. Leave blank to show the most recently published article."
    },
    {
      "type": "checkbox",
      "id": "split_continer",
      "default": false,
      "label": "Continer Split"
    },
    {
      "type": "checkbox",
      "id": "mob_split_continer",
      "default": false,
      "label": "Mobile Screen Continer Split"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Select Background Color"
    },
    {
      "type": "color",
      "id": "container_color",
      "label": "Select Container Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Blog Split"
    }
  ]
}
{% endschema %}
