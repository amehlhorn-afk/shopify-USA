{% comment %}
  BEDGEAR – Beauty: Icons + Copy flanking a centered image/video, CTA below
  Updates in this version (2025-11-06):
  • Use {{ video_tag }} for Shopify-hosted videos (better compatibility & multiple sources)
  • Reliable autoplay on iOS/Safari (muted + playsinline + JS play attempt)
  • Pause video when scrolled off-screen; resume when visible (if autoplay enabled)
  • Optional custom poster image applied via JS if set in settings
  • Retains mobile single-row scroller (.bi-features--all)
  • NEW: Configurable center media width via --bi-media-max (Theme setting: media_max_width)
{% endcomment %}

<section id="beauty-icons-{{ section.id }}" class="beauty-icons-section color-{{ section.settings.color_scheme }}">
  <div
    class="beauty-icons-wrapper page-width"
    style="
      --bi-max: {{ section.settings.max_width }}px;
      --bi-gap: {{ section.settings.column_gap }}px;
      --bi-vgap: {{ section.settings.row_gap }}px;
      --bi-pad-y: {{ section.settings.padding_y }}px;
      --bi-card-w: {{ section.settings.card_width | default: 1500 }}px;
      --bi-card-h: {{ section.settings.card_height | default: 630 }}px;
      --bi-card-radius: {{ section.settings.card_radius | default: 20 }}px;
      --bi-cta-pad-bottom: {{ section.settings.cta_pad_bottom | default: 75 }}px;
      /* NEW: icon sizing vars */
      --bi-icon-d: {{ section.settings.icon_size_desktop | default: 48 }}px;
      --bi-icon-m: {{ section.settings.icon_size_mobile | default: 36 }}px;
      --bi-bedgear-blue: #00B5E3;
      /* NEW: center media max width */
      --bi-media-max: {{ section.settings.media_max_width | default: 840 }}px;
    ">
    <div class="bi-card">
      {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank %}
        <div class="bi-header">
          {% if section.settings.eyebrow != blank %}
            <p class="bi-eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}
          {% if section.settings.heading != blank %}
            <h2 class="bi-heading">{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="bi-subheading">{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
      {% endif %}

      <div class="bi-grid">
        {%- comment -%} LEFT FEATURES (text left, icon right) — desktop only {%- endcomment -%}
        <div class="bi-features bi-features--left">
          {%- assign left_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' and block.settings.side == 'left' -%}
              {%- assign left_count = left_count | plus: 1 -%}
              <div class="bi-feature" {{ block.shopify_attributes }}>
                <div class="bi-copy">
                  {% if block.settings.title != blank %}<h3>{{ block.settings.title }}</h3>{% endif %}
                  {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
                </div>
                <div class="bi-icon" aria-hidden="true">
                  {% if block.settings.icon != blank %}
                    <img
                      src="{{ block.settings.icon | image_url: width: 256 }}"
                      alt=""
                      loading="lazy"
                      width="{{ block.settings.icon.width }}"
                      height="{{ block.settings.icon.height }}"
                    >
                  {% else %}
                    <svg width="22" height="22" viewBox="0 0 24 24" role="img" aria-label="" focusable="false"><path d="M7 12h10M12 7v10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% endif %}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} CENTER MEDIA {%- endcomment -%}
        <div class="bi-center">
          <div class="bi-image-card{% if section.settings.image_frame %} bi-image-card--framed{% endif %}">
            {% if section.settings.center_media == 'video' and section.settings.center_video != blank %}
              {%- comment -%}
                Use Shopify's video_tag to output proper <source> elements & CDN URLs.
                We pass attributes directly; 'playsinline' and 'preload' improve iOS behavior.
              {%- endcomment -%}
              {{ section.settings.center_video | video_tag:
                  image_size: '1600x',
                  class: 'bi-video',
                  autoplay: section.settings.video_autoplay,
                  loop: section.settings.video_loop,
                  muted: section.settings.video_muted,
                  controls: section.settings.video_controls,
                  playsinline: true,
                  preload: 'metadata'
              }}
            {% else %}
              {% if section.settings.image != blank or section.settings.image_mobile != blank %}
                <picture>
                  {% if section.settings.image_mobile != blank %}
                    <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 900 }}">
                  {% endif %}
                  {% if section.settings.image != blank %}
                    <img
                      src="{{ section.settings.image | image_url: width: 1600 }}
"
                      alt="{{ section.settings.image_alt | escape }}"
                      loading="lazy"
                      width="{{ section.settings.image.width }}"
                      height="{{ section.settings.image.height }}"
                    >
                  {% else %}
                    <img
                      src="{{ section.settings.image_mobile | image_url: width: 1200 }}"
                      alt="{{ section.settings.image_alt | escape }}"
                      loading="lazy"
                      width="{{ section.settings.image_mobile.width }}"
                      height="{{ section.settings.image_mobile.height }}"
                    >
                  {% endif %}
                </picture>
              {% else %}
                <div class="bi-image-placeholder"></div>
              {% endif %}
            {% endif %}
          </div>
        </div>

        {%- comment -%} RIGHT FEATURES (icon left, text right) — desktop only {%- endcomment -%}
        <div class="bi-features bi-features--right">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' and block.settings.side == 'right' -%}
              <div class="bi-feature" {{ block.shopify_attributes }}>
                <div class="bi-icon" aria-hidden="true">
                  {% if block.settings.icon != blank %}
                    <img
                      src="{{ block.settings.icon | image_url: width: 256 }}"
                      alt=""
                      loading="lazy"
                      width="{{ block.settings.icon.width }}"
                      height="{{ block.settings.icon.height }}"
                    >
                  {% else %}
                    <svg width="22" height="22" viewBox="0 0 24 24" role="img" aria-label="" focusable="false"><path d="M7 12h10M12 7v10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% endif %}
                </div>
                <div class="bi-copy">
                  {% if block.settings.title != blank %}<h3>{{ block.settings.title }}</h3>{% endif %}
                  {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} MOBILE-ONLY: Single-row scroller containing all features (6 tiles) {%- endcomment -%}
        <div class="bi-features bi-features--all">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="bi-feature" {{ block.shopify_attributes }}>
                <div class="bi-icon" aria-hidden="true">
                  {% if block.settings.icon != blank %}
                    <img
                      src="{{ block.settings.icon | image_url: width: 256 }}"
                      alt=""
                      loading="lazy"
                      width="{{ block.settings.icon.width }}"
                      height="{{ block.settings.icon.height }}"
                    >
                  {% else %}
                    <svg width="22" height="22" viewBox="0 0 24 24" role="img" aria-label="" focusable="false"><path d="M7 12h10M12 7v10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% endif %}
                </div>
                <div class="bi-copy">
                  {% if block.settings.title != blank %}<h3>{{ block.settings.title }}</h3>{% endif %}
                  {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <div class="bi-cta">
          <a class="button button--primary bi-cta-btn" href="{{ section.settings.cta_link }}" {% if section.settings.cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ section.settings.cta_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>

 <style>
  #beauty-icons-{{ section.id }} {
    background: transparent;
    padding-top: var(--bi-pad-y);
    padding-bottom: var(--bi-pad-y);
  }
  #beauty-icons-{{ section.id }} .beauty-icons-wrapper {
    max-width: var(--bi-max);
    margin: 0 auto;
  }

  /* Rounded card container */
  #beauty-icons-{{ section.id }} .bi-card {
    background: {{ section.settings.bg | default: '#F6F8FA' }};
    max-width: var(--bi-card-w);
    min-height: var(--bi-card-h);
    border-radius: var(--bi-card-radius);
    margin: 0 auto;
    padding: 24px 24px var(--bi-cta-pad-bottom);
    box-sizing: border-box;
  }

  #beauty-icons-{{ section.id }} .bi-header {
    text-align: center;
    margin-bottom: 28px;
  }
  #beauty-icons-{{ section.id }} .bi-eyebrow {
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: 12px;
    margin: 0 0 6px;
    opacity: .8;
  }
  #beauty-icons-{{ section.id }} .bi-heading {
    margin: 0 0 8px;
    font-size: clamp(24px, 2.6vw, 36px);
    line-height: 1.15;
    font-weight: 700;
  }
  #beauty-icons-{{ section.id }} .bi-subheading {
    margin: 0 auto;
    max-width: 800px;
    opacity: .85;
  }

  /* GRID */
  #beauty-icons-{{ section.id }} .bi-grid {
    display: grid;
    grid-template-columns: 1fr minmax(320px, var(--bi-media-max)) 1fr; /* increased center column */
    gap: var(--bi-vgap) var(--bi-gap);
    align-items: center;
  }

  /* Center image/video */
  #beauty-icons-{{ section.id }} .bi-image-card { border-radius: 20px; padding: 0; }
  #beauty-icons-{{ section.id }} .bi-image-card--framed {
    background: rgba(0,0,0,.03);
    padding: 16px;
    box-shadow: 0 1px 0 rgba(0,0,0,.05) inset;
  }
  #beauty-icons-{{ section.id }} .bi-center picture,
  #beauty-icons-{{ section.id }} .bi-center img,
  #beauty-icons-{{ section.id }} .bi-center video { display: block; width: 100%; height: auto; }
  #beauty-icons-{{ section.id }} .bi-image-placeholder {
    aspect-ratio: 16/9;
    background: linear-gradient(180deg, rgba(0,0,0,.06), rgba(0,0,0,.03));
    border-radius: 16px;
  }

  /* ===== FEATURE ROWS (FLEX) ===== */
  #beauty-icons-{{ section.id }} .bi-features { display: grid; gap: 20px; }
  #beauty-icons-{{ section.id }} .bi-feature {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 12px;
  }
  /* Desktop-left column: copy | icon, with right-aligned text (set in desktop media query) */

  /* ICON */
  #beauty-icons-{{ section.id }} .bi-icon {
    width: var(--bi-icon-d); height: var(--bi-icon-d); flex: 0 0 var(--bi-icon-d);
    display: flex; align-items: center; justify-content: center;
  }
  #beauty-icons-{{ section.id }} .bi-icon img,
  #beauty-icons-{{ section.id }} .bi-icon svg {
    max-width: 100%; max-height: 100%; width: 100%; height: 100%; display: block; object-fit: contain;
  }

  #beauty-icons-{{ section.id }} .bi-copy { flex: 1 1 auto; }
  #beauty-icons-{{ section.id }} .bi-copy h3 { font-size: 16px; line-height: 1.25; margin: 0 0 6px; font-weight: 700; }
  #beauty-icons-{{ section.id }} .bi-copy p { margin: 0; font-size: 12px; line-height: 1.5; opacity: .7; }

  /* CTA */
  #beauty-icons-{{ section.id }} .bi-cta { display: grid; place-items: center; margin-top: 28px; }
  #beauty-icons-{{ section.id }} .bi-cta-btn {
    border-radius: 999px; padding: 14px 28px; font-weight: 700;
    background: #00B5E3; border: 1px solid #00B5E3; color: #fff; transition: all .2s ease;
  }
  #beauty-icons-{{ section.id }} .bi-cta-btn:hover { filter: brightness(0.95); }

  /* ===== DESKTOP (≥1200px): Original two-column features + center ===== */
  @media (min-width: 1200px) {
    /* Make sure the mobile-all row is hidden on desktop */
    #beauty-icons-{{ section.id }} .bi-features--all { display: none !important; }

    /* Standard features layout */
    #beauty-icons-{{ section.id }} .bi-features {
      display: grid;
      gap: 20px;
      overflow: visible;
      scroll-snap-type: none;
      padding: 0;
    }
    #beauty-icons-{{ section.id }} .bi-feature {
      flex: 0 1 auto;
      min-width: auto;
      background: transparent;
      padding: 0;
      scroll-snap-align: unset;
      scroll-snap-stop: normal;
    }
    /* Left column: copy | icon and right-aligned text */
    #beauty-icons-{{ section.id }} .bi-features--left .bi-feature { flex-direction: row; }
    #beauty-icons-{{ section.id }} .bi-features--left .bi-copy { text-align: right; }

    /* Right column: icon | copy */
    #beauty-icons-{{ section.id }} .bi-features--right .bi-feature { flex-direction: row; }

    /* Desktop icon size */
    #beauty-icons-{{ section.id }} .bi-icon {
      width: var(--bi-icon-d);
      height: var(--bi-icon-d);
      flex: 0 0 var(--bi-icon-d);
    }
  }

  /* ===== MOBILE (≤1200px): Single-row, 6-tile scroller ===== */
  @media (max-width: 1200px) {
    #beauty-icons-{{ section.id }} .bi-card {
      border-radius: var(--bi-card-radius);
      padding: 16px 16px var(--bi-cta-pad-bottom);
      min-height: auto;
    }
    #beauty-icons-{{ section.id }} .bi-grid {
      grid-template-columns: 1fr;
      gap: 18px;
      align-items: start;
    }
    #beauty-icons-{{ section.id }} .bi-center { order: 0; }

    /* Hide desktop columns on mobile; show merged row */
    #beauty-icons-{{ section.id }} .bi-features--left,
    #beauty-icons-{{ section.id }} .bi-features--right { display: none !important; }

    #beauty-icons-{{ section.id }} .bi-features--all {
      order: 1;
      display: flex;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      gap: 12px;
      padding: 0 12px 6px; /* gutters */
    }
    /* Hide scrollbars */
    #beauty-icons-{{ section.id }} .bi-features--all::-webkit-scrollbar { display: none; }
    #beauty-icons-{{ section.id }} .bi-features--all { scrollbar-width: none; }

    /* One full-width card per slide */
    #beauty-icons-{{ section.id }} .bi-features--all .bi-feature {
      flex: 0 0 calc(100% - 24px);   /* viewport width minus gutters */
      max-width: calc(100% - 24px);
      scroll-snap-align: start;
      scroll-snap-stop: always;
      border-radius: 12px;
      background: rgba(0,0,0,.03);
      padding: 14px;
      display: flex;
      flex-direction: row;           /* icon | copy */
      align-items: flex-start;
      gap: 12px;
      overflow: hidden;
      white-space: normal;
      word-break: normal;
    }

    /* Mobile icon size */
    #beauty-icons-{{ section.id }} .bi-features--all .bi-icon {
      width: var(--bi-icon-m);
      height: var(--bi-icon-m);
      flex: 0 0 var(--bi-icon-m);
    }
    #beauty-icons-{{ section.id }} .bi-features--all .bi-copy { flex: 1 1 auto; }
    #beauty-icons-{{ section.id }} .bi-features--all .bi-copy h3 { font-size: 15px; line-height: 1.25; margin: 0 0 6px; font-weight: 700; }
    #beauty-icons-{{ section.id }} .bi-features--all .bi-copy p { font-size: 12px; line-height: 1.5; margin: 0; opacity: .75; }
  }

  /* ===== Responsive, centered middle media ===== */
  #beauty-icons-{{ section.id }} .bi-center {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  #beauty-icons-{{ section.id }} .bi-center img,
  #beauty-icons-{{ section.id }} .bi-center video {
    width: 100%;
    height: auto;
    max-width: var(--bi-media-max);
    transition: all 0.3s ease;
  }
  @media (max-width: 1200px) {
    #beauty-icons-{{ section.id }} .bi-center img,
    #beauty-icons-{{ section.id }} .bi-center video {
      max-width: min(var(--bi-media-max), 90vw);
    }
  }

  /* Optional: ensure framed video corners are rounded */
  #beauty-icons-{{ section.id }} .bi-video { display:block; width:100%; height:auto; }
  #beauty-icons-{{ section.id }} .bi-image-card--framed .bi-video { border-radius: 12px; }
 </style>

</section>

{% schema %}
{
  "name": "Icons + Center Image",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (optional)" },
    { "type": "text", "id": "heading", "label": "Heading (optional)" },
    { "type": "textarea", "id": "subheading", "label": "Subheading (optional)" },

    { "type": "select", "id": "center_media", "label": "Center media type", "default": "image", "options": [
      { "value": "image", "label": "Image" },
      { "value": "video", "label": "Video (Shopify-hosted)" }
    ]},

    { "type": "image_picker", "id": "image", "label": "Center image (desktop)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Center image (mobile)" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "checkbox", "id": "image_frame", "label": "Add soft frame behind image", "default": true },

    { "type": "video", "id": "center_video", "label": "Center video (Shopify hosted)" },
    { "type": "image_picker", "id": "video_poster", "label": "Video poster (optional)" },
    { "type": "checkbox", "id": "video_autoplay", "label": "Autoplay video", "default": true },
    { "type": "checkbox", "id": "video_muted", "label": "Mute video", "default": true },
    { "type": "checkbox", "id": "video_loop", "label": "Loop video", "default": true },
    { "type": "checkbox", "id": "video_controls", "label": "Show controls", "default": false },

    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop The Beauty Pillow" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "checkbox", "id": "cta_new_tab", "label": "Open CTA in new tab", "default": false },

    { "type": "range", "id": "max_width", "label": "Max page width (outer)", "min": 900, "max": 1800, "step": 10, "unit": "px", "default": 1800 },
    { "type": "range", "id": "column_gap", "label": "Column gap (desktop)", "min": 16, "max": 80, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "row_gap", "label": "Row gap", "min": 8, "max": 48, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_y", "label": "Section top/bottom padding (outside card)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },

    { "type": "color", "id": "bg", "label": "Card background color", "default": "#F6F8FA" },

    { "type": "range", "id": "card_width", "label": "Card max width", "min": 1000, "max": 1600, "step": 10, "unit": "px", "default": 1500 },
    { "type": "range", "id": "card_height", "label": "Card min height", "min": 400, "max": 900, "step": 10, "unit": "px", "default": 630 },
    { "type": "range", "id": "card_radius", "label": "Card border radius", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "cta_pad_bottom", "label": "Padding below CTA (inside card)", "min": 0, "max": 120, "step": 5, "unit": "px", "default": 75 },

    { "type": "range", "id": "icon_size_desktop", "label": "Icon size (desktop)", "min": 16, "max": 128, "step": 2, "unit": "px", "default": 48 },
    { "type": "range", "id": "icon_size_mobile", "label": "Icon size (mobile)", "min": 12, "max": 96, "step": 2, "unit": "px", "default": 36 },

    { "type": "range", "id": "media_max_width", "label": "Center media max width", "min": 480, "max": 1200, "step": 10, "unit": "px", "default": 840 },

    { "type": "select", "id": "color_scheme", "label": "Theme color scheme (for text/buttons)", "default": "default", "options": [
      { "value": "default", "label": "Default" },
      { "value": "inverse", "label": "Inverse" }
    ]}
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        { "type": "select", "id": "side", "label": "Desktop side", "default": "left", "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ]},
        { "type": "image_picker", "id": "icon", "label": "Icon image" },
        { "type": "text", "id": "title", "label": "Headline", "default": "Supports Healthy Skin & Hair" },
        { "type": "textarea", "id": "text", "label": "Body copy", "default": "Short supporting copy about this benefit goes here." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty • Icons + Center Image",
      "blocks": [
        { "type": "feature", "settings": { "side": "left", "title": "Supports Healthy, Radiant Skin" } },
        { "type": "feature", "settings": { "side": "left", "title": "Smooths & Protects Hair" } },
        { "type": "feature", "settings": { "side": "left", "title": "Protects Lashes & Extensions" } },
        { "type": "feature", "settings": { "side": "right", "title": "Enhanced Airflow Design" } },
        { "type": "feature", "settings": { "side": "right", "title": "Balanced Comfort & Support" } },
        { "type": "feature", "settings": { "side": "right", "title": "Removable, Washable Cover" } }
      ],
      "settings": {
        "cta_label": "Shop The Beauty Pillow"
      }
    }
  ]
}
{% endschema %}

{% javascript %}
(function() {
  var root = document.getElementById('beauty-icons-{{ section.id }}');
  if (!root) return;
  var vid = root.querySelector('.bi-video');
  if (!vid) return;

  // If a custom poster is set in settings, apply it here (safer than string-replacing video_tag output)
  {% if section.settings.video_poster != blank %}
    try { vid.setAttribute('poster', '{{ section.settings.video_poster | image_url: width: 1600 }}'); } catch(e) {}
  {% endif %}

  // Ensure muted is set before attempting autoplay (iOS/Safari requirement)
  {% if section.settings.video_autoplay %}
    {% if section.settings.video_muted %} vid.muted = true; {% endif %}
    var tryPlay = function(){ if (vid.paused) { vid.play().catch(function(){ /* ignore */ }); } };
    if (vid.readyState >= 1) tryPlay(); else vid.addEventListener('loadedmetadata', tryPlay, { once: true });
  {% endif %}

  // Pause when scrolled out of view; resume when back in view (if autoplay enabled)
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        {% if section.settings.video_autoplay %}
          {% if section.settings.video_muted %} vid.muted = true; {% endif %}
          vid.play().catch(function(){});
        {% endif %}
      } else {
        vid.pause();
      }
    });
  }, { threshold: 0.25 });
  io.observe(vid);
})();
{% endjavascript %}
