{{ 'section-eco-drive-widget.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="eco-drive-widget section-{{ section.id }}">
    <div class="page-width">
        <div class="block__eco-drive-widget">
            {{ section.settings.html }}
        </div>
    </div>
</div>

{% schema %}
    {
      "name": "Eco-Drive Widget",
      "settings": [
        {
          "type": "html",
          "id": "html",
          "label": "Widget Html"
        },
        {
          "type": "header",
          "content": "Section Style"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 150,
          "step": 2,
          "unit": "px",
          "label": "Top padding",
          "default": 36
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 150,
          "step": 2,
          "unit": "px",
          "label": "Bottom padding",
          "default": 36
        },
        {
          "type": "range",
          "id": "padding_top_m",
          "min": 0,
          "max": 150,
          "step": 2,
          "unit": "px",
          "label": "Top padding(Mobile)",
          "default": 36
        },
        {
          "type": "range",
          "id": "padding_bottom_m",
          "min": 0,
          "max": 150,
          "step": 2,
          "unit": "px",
          "label": "Bottom padding(Mobile)",
          "default": 36
        }
      ],
      "presets": [
        {
          "name": "Eco-Drive Widget"
        }
      ]
    }
    {% endschema %}
    