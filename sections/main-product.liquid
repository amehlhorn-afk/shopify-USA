<script>
  document.addEventListener('DOMContentLoaded', function() {
    function updateVariantSelection(variantInput, productContainer) {
      const { variantId, variantPrice } = variantInput?.dataset || {};
      if (!variantId || !variantPrice) return;
      // 1. Update all variant ID inputs
      document.querySelectorAll("product-form form input[name='id']").forEach(input => {
        input.value = variantId;
        input.dispatchEvent(new Event("change", { bubbles: true }));
      });

      // 2. Update Add to Cart button prices
      setTimeout(() => {
        document.querySelectorAll(".product-form__submit .add-to-cart-price")
          .forEach(btn => btn.textContent = `Add To Cart - ${variantPrice}`);
      }, 1000);

      // 3. Update all price displays
      document.querySelectorAll(".price-item").forEach(el => el.textContent = variantPrice);

      // 4. Update Firmness span in main PDP
      const fieldset = variantInput.closest('fieldset.block__form-firmness');
      const span = fieldset.querySelector('[data-selected-value]');
      if (span) span.textContent = variantInput.value;

      // 5. Update sticky bar Firmness span if exists
      const stickybar = document.querySelector('sticky-bar');
      if (stickybar) {
        stickybar.querySelectorAll('fieldset.block__form-firmness').forEach(el => {
          if (el.dataset.optionname === fieldset.dataset.optionname) {
            const stickySpan = el.querySelector('[data-selected-value]');
            if (stickySpan) stickySpan.textContent = variantInput.value;
          }
        });
      }
    }

    function autoSelectFirmness(productContainer) {
      const firstAvailable = productContainer.querySelector(".block__form-firmness input[type='radio']:not(.disabled)");
      if (firstAvailable) {
        firstAvailable.checked = true;
        updateVariantSelection(firstAvailable, productContainer);
      }
    }

    function isTwinSelected(productContainer) {
      const selectedRadio = productContainer.querySelector(".product-form__input input[type='radio']:checked");
      const selectedDropdown = productContainer.querySelector(".product-form__input select");
      return selectedRadio?.value === "Twin" || selectedDropdown?.value === "Twin";
    }

    // --- Handle option change ---
    document.addEventListener("change", e => {
      const productContainer = e.target.closest(".product");
      if (!productContainer) return;
      if (e.target.matches(".block__form-firmness input[type='radio']")) {
        updateVariantSelection(e.target, productContainer);
      } else if (e.target.matches("select, input[type='radio']") && e.target.value === "Twin") {
        setTimeout(() => autoSelectFirmness(productContainer), 1300);
      }
    });

    // --- Page load check ---
    window.addEventListener("load", () => {
      document.querySelectorAll(".product").forEach(pc => {
        console.log('Checking product on load', pc);
        if (isTwinSelected(pc)) autoSelectFirmness(pc);
      });
    });

    // --- Fix for Dawn's variant change ---
    document.addEventListener("variant:change", e => {
      const productContainer = e.target.closest(".product");
      console.log('Variant changed', productContainer);
      if (!productContainer || !isTwinSelected(productContainer)) return;
      
      const checkedFirmness = productContainer.querySelector(".block__form-firmness input[type='radio']:checked");
      checkedFirmness
        ? updateVariantSelection(checkedFirmness, productContainer)
        : autoSelectFirmness(productContainer);
    });
  });
</script>
