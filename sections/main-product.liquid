<script>
  document.addEventListener('DOMContentLoaded', function() {
    function updateBackInStockMessage(variantId) {
      const variantData = {{ product.variants | json }};
      const metafields = {{ product.variants | map: 'metafields' | json }};

      const index = variantData.findIndex(v => v.id === variantId);
      if (index === -1) return;

      const variant = variantData[index];
      const backInStockDate = metafields[index]?.custom?.product_date_back_in_stock;

      const banner = document.getElementById('back-in-stock-message');
      const text = banner?.querySelector('.back-in-stock-text');
      if(banner || text ){
        if (!variant.available && backInStockDate) {
          const date = new Date(backInStockDate);
          const today = new Date();

          date.setHours(0, 0, 0, 0);
          today.setHours(0, 0, 0, 0);

          if (date >= today) {
            const options = { year: 'numeric', month: 'long', day: 'numeric' };
            const formatted = date.toLocaleDateString(undefined, options);
            text.textContent = `Back in stock on ${formatted}`;
            banner.style.display = 'block';
          } else {
            banner.style.display = 'none';
          }
        } else {
          banner.style.display = 'none';
        }
      }
    }
    const currentVariantId = {{ product.selected_or_first_available_variant.id }};
    updateBackInStockMessage(currentVariantId);
    document.addEventListener('variant:change', function(event) {
      updateBackInStockMessage(event.detail.variant.id);
    });
    

    const featureSlides = document.querySelectorAll('.block__list_content .block__slide');
    const popups = document.querySelectorAll('.block__feature-popup');
    const body = document.body;

    // Slide click opens popup
    featureSlides.forEach(slide => {
      slide.addEventListener('click', () => {
        // Get feature text from label
        const featureLabel = slide.querySelector('label');
        if (!featureLabel) return;

        const dataFeatureGet = featureLabel.textContent.trim().toLowerCase().replace(/\s+/g, '-');
        
        // Hide all popups
        popups.forEach(popup => popup.classList.remove('active'));

        // Show matching popup
        const matchedPopup = document.querySelector(`.block__feature-popup[data_feature="${dataFeatureGet}"]`);
        if (matchedPopup) {
          matchedPopup.classList.add('active');
          body.classList.add('overflow-hidden');
        }
      });
    });

    // Close button logic
    document.querySelectorAll('.block__feature-popup-close').forEach(closeBtn => {
      closeBtn.addEventListener('click', function (e) {
        const popup = this.closest('.block__feature-popup');
        popup.classList.remove('active');
        body.classList.remove('overflow-hidden');
      });
    });

    // Outside click to close
    popups.forEach(popup => {
      popup.addEventListener('click', function (e) {
        const wrapper = popup.querySelector('.block__feature-inner-wrapper');
        if (!wrapper.contains(e.target)) {
          popup.classList.remove('active');
          body.classList.remove('overflow-hidden');
        }
      });
    });
  });
  
</script>

