{{ 'join-our-affiliate.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} block__join-our-affiliate">
  <div class="page-width">
    <div class="block__join-our-affiliate-inner">
      <div class="block__join-our-affiliate-heading text-center">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="block__join-our-affiliate-caption body">{{ section.settings.caption }}</p>
        {% endif %}
      </div>
      <div class="block__join-our-affiliate-process">
        <div class="block__join-our-affiliate-process-step-wrapper flex justify-between">
          {% for block in section.blocks %}
            <div class="block__join-our-process-step">
              {{ block.settings.step_number }}
            </div>
          {% endfor %}
        </div>
        <div class="block__join-process-step-inner flex items-center">
          {% for block in section.blocks %}
            <div class="block__join-our-process-wrapper">
              <div class="block__join-our-process-step-number">
                <div class="block__join-our-process-step">
                  {{ block.settings.step_number }}
                </div>
              </div>
              <div class="block__join-our-process-cotent-wrapper">
                <div class="block__join-process-content">
                  <span>{{ block.settings.heading }}</span>
                  <p>{{ block.settings.text }}</p>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Join Our Affiliate",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "join_process",
      "name": "Join Process",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Join Our Affiliate"
    }
  ]
}
{% endschema %}
