{{ 'pdp-review-sec.css' | asset_url | stylesheet_tag }}
<div class="block__pdp-review-secion">
    <div class="page-width">
        {% if section.settings.title != blank%}
        <div class="block__heading center">
            <h2 class="primary_h2">{{- section.settings.title -}}</h2>
        </div>
        {% endif %}
        <div class="block__review-wrapp">
          
            <script src="https://ui.powerreviews.com/stable/4.1/ui.js" async></script>
            <div id="pr-write"></div>
            <div id="pr-reviewdisplay" style=""></div>
    

            <script defer="defer">
           window.pwr = window.pwr || function() {
              (pwr.q = pwr.q || []).push(arguments);
            }
            pwr("render", {
                api_key: "47fff520-f385-4739-afdf-0e90788492b6",
                locale: "en_US",
                merchant_group_id: "2014345704",
                merchant_id: "1806575603",
                page_id: "{{ product.id }}",
                review_wrapper_url: "https://3dc651-2c.myshopify.com/pages/write-a-review/?pr_page_id={{ product.id }}",
                product: {
                    name: "{{ product.title | replace: "+", " " }}",
                    url: "{{ product.url }}",
                    image_url: "{{ product.featured_image | img_url: 'master' }}",
                    description: "{{ product.description | strip_html | strip_newlines | replace: "%0A", "%20" | replace: '"', '%27' | escape }}",
                    category_name: {% if product.type != '' %}"{{ product.type }}"{% else %} "Default" {% endif %},
                    upc: "{{ product.barcode }}",
                    brand_name: "{{ product.vendor }}",
                    price: "{{ product.price | money_without_currency }}",
                    in_stock: "{{ product.available }}",
                    variants: [ {% for variant in product.variants %}
                        {% assign product_name = product.title %}
                        {% if product.variants.size > 1 %}{% assign product_name = variant.title %}{% endif %}
                    {
                    name: "{{ product_name | replace: "+", " " }}",
                    description: "{{ product_name | escape }}",
                    page_id_variant: "{{variant.id}}",
                    upc: "{{ variant.barcode }}"
                    }{% if forloop.last == false %}, {% endif %} {% endfor %}
                ]},
                components: {
                            ReviewDisplay: "pr-reviewdisplay",
                            ReviewSnippet: "pr-reviewsnippet"
                            
                        }
                });
            </script> 
        </div> 
    </div>
</div>
{% style %}  
    @media (min-width:990px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.desktop_padding_top }}px;
            padding-bottom:{{ section.settings.desktop_padding_bottom }}px;
        }
    }
    @media (max-width:989px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.mobile_padding_top }}px;
            padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
        }
    }
{% endstyle %}
{% schema %}
{
    "name": "PDP Review Section",
    "settings": [
        {
            "type": "color",
            "id": "bg_color",
            "label": "Background Color"
        },
        {
            "type": "inline_richtext",
            "id": "title",
            "label": "Title"
        },
        {
            "type": "header",
            "content": "Desktop Space"
        },
        {
            "type": "range",
            "id": "desktop_padding_top",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Desktop Padding Top",
            "default": 16
        },
        {
            "type": "range",
            "id": "desktop_padding_bottom",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Desktop Padding Bottom",
            "default": 16
        },
        {
            "type": "header",
            "content": "Mobile Space"
        },
        {
            "type": "range",
            "id": "mobile_padding_top",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Mobile Padding Top",
            "default": 16
        },
        {
            "type": "range",
            "id": "mobile_padding_bottom",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Mobile Padding Bottom",
            "default": 16
        }
    ],
    "presets": [
        {
            "name": "PDP Review Section"
        }
    ]
}
{% endschema %}

