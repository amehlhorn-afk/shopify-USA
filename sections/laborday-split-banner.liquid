{%- comment -%}
  File: sections/laborday-banner.liquid
{%- endcomment -%}
{{ 'hero-banner.css' | asset_url | stylesheet_tag }}

{% style %}
/* ===== SHARED / DESKTOP ===== */
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.desktop_padding_top }}px;
  padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
}

.promo-bg--pagewidth { padding-left: 1.5rem; padding-right: 1.5rem; }

.promo-bg__frame {
  position: relative;
  overflow: hidden;
  border-radius: 20px;
  min-height: 520px;
  display: flex;
  align-items: center; /* vertical centering */
  justify-content: center; /* horizontal centering */
}

.promo-bg__media { position: absolute; inset: 0; z-index: 1; }
.promo-bg__media video,
.promo-bg__media img { width: 100%; height: 100%; object-fit: cover; }
.promo-bg__media--mobile { display: none; }

.promo-bg__overlay {
  position: absolute; inset: 0; z-index: 0;
  background: {{ section.settings.overlay_color }};
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  pointer-events: none;
  display: {% if section.settings.enable_overlay %}block{% else %}none{% endif %};
}

.promo-bg__content {
  position: relative; /* anchor for sale-image */
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center; /* vertical centering */
  align-items: center;     /* horizontal centering */
  width: 50%;
  margin-right: auto;
  padding: 58px 40px;
  text-align: center;
}

/* Shared typography */
.promo-bg__content * {
  font-family: 'Roboto', sans-serif;
}

/* Explicit colors instead of universal override */
.promo-heading,
.promo-subhead,
.promo-tier-right {
  color: {{ section.settings.text_color }};
}

.promo-tagline {
  margin: -10 0 45px;
  font-size: 22.5px;
  color: #DAF262;
}

.promo-tier-left {
  font-weight: 800;
  font-size: 42px;
  line-height: 1;
  color: #DAF262;
}

.sale-image {
  max-width: 160px;
  height: auto;
  margin-bottom: 24px;
}

.promo-eyebrow {  /* hidden by default */
  display: none !important;
  background: {{ section.settings.eyebrow_bg }};
  color: {{ section.settings.eyebrow_color }};
  font-weight: 700;
  font-size: 18px;
  line-height: 1.3;
  padding: .25rem .75rem;
  border-radius: 6px;
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: .02em;
}

.promo-heading { font-weight: 800; font-size: 48px; line-height: 1.05; text-transform: uppercase; }
.promo-heading--line { display: block; }

.promo-subhead { margin: 0 0 12px; font-size: 36px; font-weight: 400; }

.promo-tiers { display: inline-block; text-align: center; }
.promo-tier { display: flex; align-items: baseline; justify-content: center; gap: 16px; margin: 10px 0; }

.promo-cta {
  display: block;
  width: 217px;
  margin: 24px auto 0;
  padding: 1.5rem 1.8rem;
  border-radius: 999px;
  background: {{ section.settings.cta_bg }};
  color: {{ section.settings.cta_text }};
  font-weight: 800;
  font-size: 16px;
  text-decoration: none;
  border: none;
  box-shadow: none;
  transition: all 0.25s ease;
}

.promo-cta:hover {
  background: #ffffff;
  color: #00B5E3;
  box-shadow: 0 6px 12px rgba(0,0,0,0.15);
}

.promo-sticker {
  position: absolute;
  top: {{ section.settings.sticker_top }}px;
  right: {{ section.settings.sticker_right }}px;
  width: {{ section.settings.sticker_width }}px;
  height: auto;
  object-fit: contain;
  pointer-events: none;
  z-index: 1;
}

/* ===== MOBILE ===== */
@media (max-width: 989px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  .promo-bg--pagewidth { padding-left: 0; padding-right: 0; }
  .promo-bg__frame { border-radius: 0; min-height: 560px; }

  .promo-bg__content {
    width: 100%;
    padding: 32px 20px 120px;
    align-items: flex-start;
    justify-content: center;
    text-align: center;
  }

  .promo-bg__inner {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding-bottom: 100px;
  }

  .sale-image {
    position: static;
    transform: none;
    margin: 0 auto 16px;
    max-width: {{ section.settings.sticker_width_mobile }}px;
  }

  .promo-heading { font-size: 42px; line-height: 1.07; }
  .promo-subhead { font-size: 21px; }
  .promo-tagline { font-size: 16px; }
  .promo-tier-left { font-size: 30px; }
  .promo-tier-right { font-size: 22px; }

  .promo-sticker { display: none !important; }

  .promo-cta {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    margin: 0;
    z-index: 5;
  }

  .promo-bg__media--desktop { display: none; }
  .promo-bg__media--mobile { display: block; }
}
{% endstyle %}

<div id="Banner-{{ section.id }}" class="section-{{ section.id }}-padding">
  <div class="promo-bg--pagewidth">
    <div class="promo-bg__frame">

      <!-- Desktop Background -->
      <div class="promo-bg__media promo-bg__media--desktop">
        {% if section.settings.bg_video_url != blank %}
          <video autoplay loop muted playsinline {% if section.settings.bg_poster != blank %}poster="{{ section.settings.bg_poster | image_url }}"{% endif %}>
            <source src="{{ section.settings.bg_video_url }}" type="video/mp4">
          </video>
        {% elsif section.settings.bg_image != blank %}
          <img src="{{ section.settings.bg_image | image_url: width: 1920 }}" alt="{{ section.settings.bg_image.alt | default: section.settings.bg_image_alt | escape }}">
        {% endif %}
      </div>

      <!-- Mobile Background -->
      <div class="promo-bg__media promo-bg__media--mobile">
        {% if section.settings.bg_video_url_mobile != blank %}
          <video autoplay loop muted playsinline {% if section.settings.bg_poster != blank %}poster="{{ section.settings.bg_poster | image_url }}"{% endif %}>
            <source src="{{ section.settings.bg_video_url_mobile }}" type="video/mp4">
          </video>
        {% elsif section.settings.bg_image_mobile != blank %}
          <img src="{{ section.settings.bg_image_mobile | image_url: width: 1080 }}" alt="{{ section.settings.bg_image_mobile.alt | default: section.settings.bg_image_alt_mobile | escape }}">
        {% endif %}
      </div>

      <!-- Overlay -->
      <span class="promo-bg__overlay" aria-hidden="true"></span>

      <!-- Sticker -->
      {% if section.settings.sticker_image != blank %}
        <img class="promo-sticker" src="{{ section.settings.sticker_image | image_url }}" alt="{{ section.settings.sticker_alt | escape }}">
      {% endif %}

      <!-- Content -->
      <div class="promo-bg__content">
        <div class="promo-bg__inner">

          {% if section.settings.sale_image != blank %}
            <img class="sale-image" src="{{ section.settings.sale_image | image_url }}" alt="Promo Tag">
          {% endif %}

          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'eyebrow' %}
                {% if block.settings.text != blank %}
                  <span class="promo-eyebrow">{{ block.settings.text }}</span>
                {% endif %}
              {% when 'heading' %}
                {% if block.settings.line1 != blank or block.settings.line2 != blank %}
                  <h2 class="promo-heading">
                    {% if block.settings.line1 != blank %}<span class="promo-heading--line">{{ block.settings.line1 }}</span>{% endif %}
                    {% if block.settings.line2 != blank %}<span class="promo-heading--line" style="color:#DAF262;">{{ block.settings.line2 }}</span>{% endif %}
                  </h2>
                {% endif %}
              {% when 'subhead' %}
                {% if block.settings.text != blank %}
                  <h3 class="promo-subhead">{{ block.settings.text }}</h3>
                {% endif %}
              {% when 'tagline' %}
                {% if block.settings.text != blank %}
                  <p class="promo-tagline">{{ block.settings.text }}</p>
                {% endif %}
              {% when 'tier' %}
                {% if block.settings.tiers != blank %}
                  <div class="promo-tiers">
                    {% assign lines = block.settings.tiers | newline_to_br | split: '<br />' %}
                    {% for line in lines %}
                      {% assign parts = line | split: '|' %}
                      <div class="promo-tier">
                        <div class="promo-tier-left">{{ parts[0] }}</div>
                        <div class="promo-tier-right">{{ parts[1] }}</div>
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}
              {% when 'cta' %}
                {% if block.settings.text != blank and block.settings.link != blank %}
                  <a class="promo-cta" href="{{ block.settings.link }}">{{ block.settings.text }}</a>
                {% endif %}
            {% endcase %}
          {% endfor %}

        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Labor Day Banner",
  "settings": [
    { "type": "url", "id": "bg_video_url", "label": "Background Video URL (.mp4 or .webm)" },
    { "type": "image_picker", "id": "bg_poster", "label": "Poster (shown while video loads)" },
    { "type": "image_picker", "id": "bg_image", "label": "Fallback Image (if no video)" },
    { "type": "text", "id": "bg_image_alt", "label": "Fallback Image Alt" },
    { "type": "url", "id": "bg_video_url_mobile", "label": "Mobile Background Video URL (.mp4 or .webm)" },
    { "type": "image_picker", "id": "bg_image_mobile", "label": "Mobile Background Image" },
    { "type": "text", "id": "bg_image_alt_mobile", "label": "Mobile Image Alt" },
    { "type": "checkbox", "id": "enable_overlay", "label": "Enable Color Overlay", "default": false },
    { "type": "color", "id": "overlay_color", "label": "Overlay Color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Overlay Opacity", "default": 30 },
    { "type": "color", "id": "text_color", "label": "Primary Text Color", "default": "#FFFFFF" },
    { "type": "color", "id": "eyebrow_bg", "label": "Eyebrow Background", "default": "#073F6C" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow Text", "default": "#FFFFFF" },
    { "type": "image_picker", "id": "sticker_image", "label": "Optional Sticker Image" },
    { "type": "text", "id": "sticker_alt", "label": "Sticker Alt Text", "default": "Sale sticker" },
    { "type": "range", "id": "sticker_width", "min": 60, "max": 240, "step": 2, "unit": "px", "label": "Sticker Width (Desktop)", "default": 140 },
    { "type": "range", "id": "sticker_width_mobile", "min": 50, "max": 180, "step": 2, "unit": "px", "label": "Sticker Width (Mobile)", "default": 100 },
    { "type": "range", "id": "sticker_top", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Sticker Top Offset", "default": 24 },
    { "type": "range", "id": "sticker_right", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Sticker Right Offset (Desktop)", "default": 24 },
    { "type": "color", "id": "cta_bg", "label": "CTA Background", "default": "#00B5E3" },
    { "type": "color", "id": "cta_text", "label": "CTA Text", "default": "#FFFFFF" },
    { "type": "range", "id": "content_max_width", "min": 300, "max": 700, "step": 10, "unit": "px", "label": "Content Max Width", "default": 600 },
    { "type": "range", "id": "desktop_padding_top", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Desktop Padding Top", "default": 16 },
    { "type": "range", "id": "desktop_padding_bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Desktop Padding Bottom", "default": 16 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Mobile Padding Top", "default": 16 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Mobile Padding Bottom", "default": 16 },
    { "type": "image_picker", "id": "sale_image", "label": "Optional Sale Image" },
    { "type": "text", "id": "desktop_content_position", "label": "Desktop Content Position", "default": "top-left" },
    { "type": "text", "id": "mobile_content_position", "label": "Mobile Content Position", "default": "center" }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow/Badge",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Eyebrow Text", "default": "Labor Day Sale" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading (2 lines)",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "line1", "label": "Heading Line 1", "default": "Buy More," },
        { "type": "text", "id": "line2", "label": "Heading Line 2", "default": "Save More." }
      ]
    },
    {
      "type": "subhead",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Subheading Text", "default": "Performance® Bedding" }
      ]
    },
    {
      "type": "tagline",
      "name": "Tagline",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Tagline Text", "default": "Personalize your bed for the best night's sleep" }
      ]
    },
    {
      "type": "tier",
      "name": "Tier List (multi-line)",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "tiers",
          "label": "Tiers (one per line as \"LEFT|RIGHT\")",
          "default": "20% OFF|2 Items\n25% OFF|3 Items\n30% OFF|4+ Items"
        }
      ]
    },
    {
      "type": "cta",
      "name": "CTA Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Button Text", "default": "Shop Labor Day Sale" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Labor Day Banner" }]
}
{% endschema %}
