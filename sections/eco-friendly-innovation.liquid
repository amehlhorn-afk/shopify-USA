{{ 'section-friendly-innovation.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-friendly-innovation">
  <div class="page-width">
    <div class="block__friendly-innovation-main">
      {% if section.settings.title != blank and section.settings.caption != blank %}
        <div class="block__friendly-innovation-header">
          {% if section.settings.title != blank %}
            <h2 class="primary_h2">{{ section.settings.title }}</h2>
          {% endif %}
          {% if section.settings.caption != blank %}
            <p class="body">{{ section.settings.caption }}</p>
          {% endif %}
        </div>
      {% endif %}
      {% if section.settings.img != blank %}
        <div class="block__friendly-innovation-img">
          {% if section.settings.bg_logo != blank %}
            <img
              src="{{ section.settings.bg_logo | image_url: width:section.settings.bg_logo.width }}"
              alt="{{ section.settings.bg_logo.alt | default: shop.name  }}"
              width=""
              height=""
              class="block__friendly-innovation-bg"
              loading="lazy"
            >
          {% endif %}
          <img
            src="{{ section.settings.img | image_url: width:section.settings.img.width }}"
            alt="{{ section.settings.img.alt | default: shop.name }}"
            width=""
            height=""
            class="block__friendly-innovation-img"
            loading="lazy"
          >
        </div>
      {% endif %}
      <ul class="block__friendly-innovation-list">
        {% for block in section.blocks %}
          {% if block.settings.heading != blank or block.settings.caption != blank %}
            <li>
              <span class="body">{{ forloop.index }}</span>
              <div class="block__friendly-innovation-info">
                {% if block.settings.heading != blank %}
                  <h6 class="body">{{ block.settings.heading }}</h6>
                {% endif %}
                {% if block.settings.caption != blank %}
                  <p class="body">{{ block.settings.caption }}</p>
                {% endif %}
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Friendly Innovation",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "image_picker",
      "id": "bg_logo",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Image"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "Innovation_info",
      "name": "Innovation Info",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Friendly Innovation"
    }
  ]
}
{% endschema %}
