{{ 'section-find-fit.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-find-fit">
  <div class="page-width">
    <div class="block__find-fit-row{% if section.settings.enable_column_list %} items-center{% endif %}">
      <div class="{% if section.settings.enable_column_list %}block__find-fit-column-mobile-text{% else %}none{% endif %}">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="block__find-fit-text-caption body">{{ section.settings.caption }}</p>
        {% endif %}
      </div>
      {% if section.settings.img != blank %}
        <div class="block__find-fit-image-wrapper">
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid' %}
        </div>
      {% endif %}
      <div class="{% if section.settings.enable_column_list %}block__find-fit-column-text-wrapper{% else %}block__find-fit-text-wrapper{% endif %}">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="block__find-fit-text-caption body">{{ section.settings.caption }}</p>
        {% endif %}

        <ul class="block__find-fit-list gap-8 {% if section.settings.enable_column_list %}block__find-fit-list-column {% endif %}">
          {% for block in section.blocks %}
            <li class="block__find-fit-item items-start">
              {% if block.settings.img != blank %}
                <div class="block__find-fit-icon">
                  {% render 'custom-image', image: block.settings.img, class: 'img-fluid' %}
                </div>
              {% endif %}
              <div class="block__find-fit-text">
                {% if block.settings.heading != blank %}
                  <h5>{{ block.settings.heading }}</h5>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Find Fit",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "checkbox",
      "id": "enable_column_list",
      "label": "Column list",
      "info": "Enable block in column",
      "default": false
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefits_block",
      "name": "Benefits Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Find Fit"
    }
  ]
}
{% endschema %}