{{ 'section-detail-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} .block__detail-banner-overlay{
    background-color: {{ section.settings.overlay_color }};
    opacity: 0.{{ section.settings.overlay_opacity }};
  }
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .section-{{ section.id }} .block__detail-banner-content *{
      color: {{ section.settings.text_color }}; 
  }
  {%- if section.settings.text_color  != blank -%}
    .section-{{ section.id }} .block__detail-banner-content .block__detail-banner-text{
        opacity: 0.7; 
    }
  {%- endif -%}
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-detail-banner">
  <div class="page-width">
    {% assign page_value = page.metafields.custom.technology_detail.value %}
    <div class="block__detail-banner relative z-index-1">
      {% if section.settings.overlay %}
        <span class="block__detail-banner-overlay z-index--1 absolute"></span>
      {% endif %}
      {%- if section.settings.banner_video != blank -%}   
        <div class="section-detail-banner-bg absolute">
        {{
          section.settings.banner_video
          | video_tag: loop: true, controls: false, muted: true, autoplay: true, class: 'h-full w-full object-cover block quaternary-border-radius '
        }}
        </div>
      {% elsif section.settings.img != blank %}
        <div class="section-detail-banner-bg absolute">
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid desktop-bg object-cover' %}
          {% if section.settings.img_mobile != blank %}
            {% assign mobile_bg = section.settings.img_mobile %}
          {% else %}
            {% assign mobile_bg = section.settings.img %}
          {% endif %}
          {% render 'custom-image', image: mobile_bg, class: 'img-fluid mobile-bg object-cover' %}
        </div>
      {% endif %}
      <div class="block__detail-banner-content text-center h2">
        <h1 class="block__detail-banner-title">
          {% if page_value.banner_text != blank %}{{ page_value.banner_text }}{% else %}{{ page.title }}{% endif %}
        </h1>
        {% if page_value.banner_caption != blank %}
          <p class="body block__detail-banner-text">{{ page_value.banner_caption }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Detail Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Background Image(Desktop)"
    },
    {
      "type": "image_picker",
      "id": "img_mobile",
      "label": "Select Background Image(Mobile)"
    },
    {
      "type": "video",
      "id": "banner_video",
      "label": "Banner Video"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "unit": "%",
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Detail Banner"
    }
  ]
}
{% endschema %}
