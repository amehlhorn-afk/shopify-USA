{{ 'section-career-info.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-career-info">
  <div class="page-width">
    <div class="block__career-info-row">
      {% if section.settings.img != blank %}
        <div class="block__career-info-img-wrapper">
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid object-cover' %}
        </div>
      {% endif %}
      <div class="block__career-info-text-wrapper">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body">{{ section.settings.caption }}</p>
        {% endif %}
        <div class="block__career-features-text">
          {% if section.settings.heading != blank %}
            <h5>{{ section.settings.heading }}</h5>
          {% endif %}
          <ul class="block__career-features-text-list">
            {% for block in section.blocks %}
              {% assign icon = block.settings.icon %}
              {% assign text = block.settings.text %}
              {% if icon != blank or text != blank %}
                <li>
                  <img
                    src="{{ icon |  image_url: width:icon.width }}"
                    alt="{{ icon.alt | default: text }}"
                    width=""
                    height="" loading="lazy"
                  >
                  <span class="body">{{ text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Career Info",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Useful Features"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "Career_features",
      "name": "Career Features",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Select Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Career Info"
    }
  ]
}
{% endschema %}
