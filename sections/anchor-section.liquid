          "default": "gifts-for-the-hot-sleeper"
        },

        {
          "type": "header",
          "content": "Container colors"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background color",
          "default": "#f7f7f7"
        },
        {
          "type": "color",
          "id": "bg_color_hover",
          "label": "Background color (hover)",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "bg_color_active",
          "label": "Background color (active)",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border color",
          "default": "rgba(0,0,0,0.06)"
        },
        {
          "type": "color",
          "id": "border_color_active",
          "label": "Border color (active)",
          "default": "rgba(0,0,0,0.1)"
        },

        {
          "type": "header",
          "content": "Text colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#1b2740"
        },
        {
          "type": "color",
          "id": "text_color_hover",
          "label": "Text color (hover)",
          "default": "#1b2740"
        },
        {
          "type": "color",
          "id": "text_color_active",
          "label": "Text color (active)",
          "default": "#1b2740"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Anchor collection nav",
      "category": "Custom",
      "blocks": [
        {
          "type": "anchor",
          "settings": {
            "label": "Gifts for the hot sleeper",
            "target_id": "gifts-for-the-hot-sleeper"
          }
        },
        {
          "type": "anchor",
          "settings": {
            "label": "Gifts for the Jetsetter",
            "target_id": "gifts-for-the-jetsetter"
          }
        },
        {
          "type": "anchor",
          "settings": {
            "label": "Gifts for the New Homeowners",
