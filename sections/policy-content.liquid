{{ 'section-policy-content.css' | asset_url | stylesheet_tag }}
{% style %}
     .section-{{ section.id }} .block__policy-content-main {
       max-width: {{ section.settings.content_width }}px;
     }
     .section-{{ section.id }} {
         padding-top: {{ section.settings.padding_top }}px;
         padding-bottom: {{ section.settings.padding_bottom }}px;
     }
     @media (max-width: 749px) {
         .section-{{ section.id }} {
             padding-top: {{ section.settings.padding_top_m }}px;
             padding-bottom: {{ section.settings.padding_bottom_m }}px;
         }
     }

    .policy-tabs {
       display: flex;
       justify-content: center; /* Center buttons horizontally */
       gap: 10px;
       margin-bottom: 20px;
       padding-top: 20px; /* Space above the tabs */
     }
  .block__policy-content-main h4 {
    margin-top: 22px;
  }
     .policy-tab {
       background-color: #00B5E3; /* Updated Bedgear Blue */
       color: white;
       padding: 10px 20px;
       border: none;
       cursor: pointer;
       font-size: 16px;
       border-radius: 4px;
       transition: background-color 0.3s ease;
     }

     .policy-tab:hover {
       background-color: #009dc4; /* Slightly darker on hover */
     }

     .policy-tab.active {
       font-weight: bold;
       box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
     }

     .policy-section {
       display: none;
     }

     .policy-section.active {
       display: block;
     }
{% endstyle %}

