<script>
  function showPolicySection(sectionId) {
    document.querySelectorAll('.policy-tab').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.policy-section').forEach(sec => sec.classList.remove('active'));

    document.getElementById(sectionId).classList.add('active');
    document.querySelector(`.policy-tab[onclick*="${sectionId}"]`).classList.add('active');
  }
</script>
