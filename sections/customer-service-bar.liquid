{%- comment -%}
  Reusable customer service / support bar.
  Can be placed on any page template — product, collection, page, etc.
  All copy and links are configurable via the theme editor.
{%- endcomment -%}

<div class="cs-bar">
  <div class="page-width">

    <div class="cs-bar__top">
      <div class="cs-bar__left">
        <span class="cs-bar__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
            <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
            <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
          </svg>
        </span>
        <div class="cs-bar__copy">
          <strong class="cs-bar__heading">{{ section.settings.heading }}</strong>
          <p class="cs-bar__text">{{ section.settings.body_text }}</p>
        </div>
      </div>
      {%- if section.settings.availability_label != blank -%}
        <p class="cs-bar__avail small-hide">{{ section.settings.availability_label }}</p>
      {%- endif -%}
    </div>

    <div class="cs-bar__actions">
      {%- if section.settings.chat_label != blank -%}
        <a
          href="{{ section.settings.chat_url }}"
          class="cs-bar__action"
          {% if section.settings.chat_url contains '#' %}data-chat-trigger{% endif %}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          {{ section.settings.chat_label }}
        </a>
        <span class="cs-bar__divider" aria-hidden="true">|</span>
      {%- endif -%}

      {%- if section.settings.phone_label != blank -%}
        <a href="tel:{{ section.settings.phone_number }}" class="cs-bar__action">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {{ section.settings.phone_label }}
        </a>
        <span class="cs-bar__divider" aria-hidden="true">|</span>
      {%- endif -%}

      {%- if section.settings.email_label != blank -%}
        <a href="mailto:{{ section.settings.email_address }}" class="cs-bar__action">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,12 2,6"/>
          </svg>
          {{ section.settings.email_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

{% style %}
  .cs-bar {
    border: 1.5px solid var(--brand-gray-200);
    border-radius: var(--brand-radius-lg);
    overflow: hidden;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  .cs-bar__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 28px;
    gap: 20px;
    background: var(--brand-white);
  }

  .cs-bar__left {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .cs-bar__icon {
    flex-shrink: 0;
    color: var(--brand-gray-500);
    margin-top: 2px;
  }

  .cs-bar__heading {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: var(--brand-gray-900);
    margin-bottom: 5px;
  }

  .cs-bar__text {
    font-size: 14px;
    color: var(--brand-gray-600);
    line-height: 1.55;
    margin: 0;
    max-width: 460px;
  }

  .cs-bar__avail {
    font-size: 14px;
    color: var(--brand-gray-500);
    white-space: nowrap;
    margin: 0;
    flex-shrink: 0;
  }

  .cs-bar__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 14px 28px;
    border-top: 1px solid var(--brand-gray-200);
    background: var(--brand-gray-50);
    flex-wrap: wrap;
  }

  .cs-bar__action {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    font-weight: 600;
    color: var(--brand-gray-800);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }

  .cs-bar__action:hover { color: var(--brand-cyan); }

  .cs-bar__divider {
    color: var(--brand-gray-300);
    font-size: 18px;
    line-height: 1;
    user-select: none;
  }

  @media screen and (max-width: 749px) {
    .cs-bar__top {
      flex-direction: column;
      align-items: flex-start;
      padding: 18px 20px;
      gap: 12px;
    }

    .cs-bar__actions { padding: 12px 20px; gap: 14px; }
    .cs-bar__text { max-width: 100%; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Customer Service Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need Help?"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Our sleep specialists are here 7 days a week \u2014 Mon\u2013Fri 9am\u20136pm ET, weekends 10am\u20134pm ET."
    },
    {
      "type": "text",
      "id": "availability_label",
      "label": "Availability label (right side, desktop)",
      "default": "Available 7 days a week"
    },
    {
      "type": "header",
      "content": "Live Chat"
    },
    {
      "type": "text",
      "id": "chat_label",
      "label": "Label",
      "default": "Live Chat"
    },
    {
      "type": "url",
      "id": "chat_url",
      "label": "URL (use # to trigger chat widget)"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Display label",
      "default": "1-866-BED-GEAR"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Number for tel: link (digits only)",
      "default": "18662334327"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Label",
      "default": "Email Us"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email address",
      "default": "support@bedgear.com"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom margin (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Customer Service Bar"
    }
  ]
}
{% endschema %}
