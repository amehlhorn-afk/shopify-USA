{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- comment -%} Adapt height padding using proper image ratio {%- endcomment -%}
{%- assign has_any_image = false -%}
{%- if section.settings.image != blank or section.settings.mobile_image != blank -%}
  {%- assign has_any_image = true -%}
{%- endif -%}
{%- if section.settings.image_height == 'adapt' and has_any_image -%}
  {%- liquid
    assign ratio_mobile  = section.settings.mobile_image.aspect_ratio | default: section.settings.image.aspect_ratio
    assign ratio_desktop = section.settings.image.aspect_ratio | default: ratio_mobile
  -%}
  {%- style -%}
    /* Use the MOBILE image ratio on small screens */
    @media screen and (max-width: 749px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before,
      #Banner-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: ratio_mobile | times: 100 }}%;
        content: '';
        display: block;
      }
    }
    /* Use the DESKTOP image ratio on large screens */
    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before {
        padding-bottom: {{ 1 | divided_by: ratio_desktop | times: 100 }}%;
        content: '';
        display: block;
      }
    }
    /* --- Fix: keep mobile image from getting super long --- */
@media (max-width: 749px) {
  /* kill the adapt padding on mobile */
  #Banner-{{ section.id }}::before,
  #Banner-{{ section.id }} .banner__media::before,
  #Banner-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
    padding-bottom: 0 !important;
    content: none !important;
    display: none !important;
  }

  /* clamp the mobile image height and crop elegantly */
  #Banner-{{ section.id }} .block__mobile-image,
  #Banner-{{ section.id }} .block__mobile-image img {
    height: 60vh;          /* try 50–70vh to taste */
    max-height: 520px;     /* optional hard cap for very tall phones */
    width: 100%;
    object-fit: cover;     /* keeps it visually balanced */
  }
}
  {%- endstyle -%}
{%- endif -%}

{%- style -%}
/* ===============================
   ACS customizations & helpers
   =============================== */

/* Make sure mobile image fills its frame */
@media (max-width: 749px) {
  #Banner-{{ section.id }} .block__mobile-image { width: 100%; height: 100%; }
  #Banner-{{ section.id }} .block__mobile-image img { width: 100%; height: 100%; object-fit: cover; }
}

/* Inline image wrapper (block) */
.banner__inline-image-wrapper {
  display: flex;
  justify-content: center;
  margin: 16px auto;
}
.banner__inline-image-wrapper img {
  height: auto;
  width: 160px;
  max-width: 100%;
}

/* Overlay & text color overrides */
{% if section.settings.overlay_color != blank %}
#Banner-{{ section.id }}::after {
  opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  background-color: {{ section.settings.overlay_color }};
}
{% endif %}

{% if section.settings.text_color != blank %}
#Banner-{{ section.id }} .banner__box.content-container .h2,
#Banner-{{ section.id }} .banner__box.content-container p {
  color: {{ section.settings.text_color }};
}
{% endif %}

/* Adaptive padding that gracefully expands with more lines of text */
#Banner-{{ section.id }} .banner__box {
  padding: clamp(16px, {{ section.settings.padding_y_mobile | default: 24 }}px, 96px)
           clamp(16px, {{ section.settings.padding_x_mobile | default: 20 }}px, 80px);
}
@media (min-width: 750px) {
  #Banner-{{ section.id }} .banner__box {
    padding-top: clamp(24px, {{ section.settings.padding_y_desktop | default: 40 }}px, 120px);
    padding-bottom: clamp(24px, {{ section.settings.padding_y_desktop | default: 40 }}px, 120px);
    padding-left: clamp(16px, {{ section.settings.padding_x_desktop | default: 32 }}px, 120px);
    padding-right: clamp(16px, {{ section.settings.padding_x_desktop | default: 32 }}px, 120px);
  }
}

/* Ensure TRUE left alignment when “Left” is chosen */
#Banner-{{ section.id }}.banner--content-align-left .banner__box,
#Banner-{{ section.id }}.banner--content-align-mobile-left .banner__box {
  text-align: left;
  margin-left: 0;
  margin-right: auto;
}

/* Bottom-right logo + visible meta/disclaimer text */
#Banner-{{ section.id }} { position: relative; }

#Banner-{{ section.id }} .acs-badge-wrap {
  position: absolute;
  right: {{ section.settings.logo_inset_right | default: 16 }}px;
  bottom: {{ section.settings.logo_inset_bottom | default: 16 }}px;
  z-index: 3;
  display: inline-flex;
  align-items: flex-end;
  gap: 12px;
  max-width: min({{ section.settings.meta_text_max_width | default: 260 }}px, 60vw);
  text-align: right;
  pointer-events: auto;
}
#Banner-{{ section.id }} .acs-badge-wrap .acs-meta-text {
  font-size: {% if section.settings.meta_text_size == 'caption' %}12px{% else %}14px{% endif %};
  line-height: 1.35;
  color: {{ section.settings.meta_text_color | default: section.settings.text_color | default: '#ffffff' }};
  opacity: 0.9;
}
#Banner-{{ section.id }} .acs-badge-wrap img {
  width: {{ section.settings.logo_width | default: 120 }}px;
  height: auto;
  display: block;
}

/* Mobile logo/meta nudges + widen disclaimer to content width */
@media (max-width: 749px) {
  #Banner-{{ section.id }} .acs-badge-wrap {
    right: {{ section.settings.logo_inset_right_mobile | default: 12 }}px;
    bottom: {{ section.settings.logo_inset_bottom_mobile | default: 12 }}px;
    gap: 8px;
  }
  /* Widen disclaimer/meta text on mobile so it lines up with main text */
  #Banner-{{ section.id }} .acs-badge-wrap {
    max-width: none;
    width: calc(100% - 40px); /* match content width with side padding */
    justify-content: space-between;
    text-align: left;
  }
  #Banner-{{ section.id }} .acs-badge-wrap .acs-meta-text {
    max-width: 100%;
    white-space: normal;
    text-align: left;
  }
}

/* Control vertical position of content on mobile (Top/Middle/Bottom) */
@media (max-width: 749px) {
  #Banner-{{ section.id }} .banner__content {
    display: flex;
    flex-direction: column;
  }
  #Banner-{{ section.id }}.banner--mobile-position-top .banner__content { justify-content: flex-start; }
  #Banner-{{ section.id }}.banner--mobile-position-middle .banner__content { justify-content: center; }
  #Banner-{{ section.id }}.banner--mobile-position-bottom .banner__content { justify-content: flex-end; }
}

/* Optional: fix desktop height to 300px */
@media (min-width: 750px) {
  #Banner-{{ section.id }}.acs-desktop-h-300 {
    min-height: 300px;
    height: 300px;
  }
  #Banner-{{ section.id }}.acs-desktop-h-300 .banner__media,
  #Banner-{{ section.id }}.acs-desktop-h-300 .banner__media img {
    height: 300px;
    min-height: 300px;
    max-height: 300px;
    object-fit: cover;
    width: 100%;
  }
  #Banner-{{ section.id }}.acs-desktop-h-300 .banner__content {
    min-height: 300px;
  }
}
{%- endstyle -%}

{%- liquid
  assign full_width = '100vw'
  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'

  if section.settings.image_behavior == 'ambient'
    assign half_width = '60vw'
    assign full_width = '120vw'
    assign stacked_sizes = '(min-width: 750px) 60vw, 120vw'
    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
  elsif section.settings.image_behavior == 'fixed' or section.settings.image_behavior == 'zoom-in'
    assign half_width = '100vw'
    assign stacked_sizes = '100vw'
  else
    assign half_width = '50vw'
    assign stacked_sizes = '(min-width: 750px) 50vw, 100vw'
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="Banner-{{ section.id }}"
  class="banner
         banner--content-align-{{ section.settings.desktop_content_alignment }}
         banner--content-align-mobile-{{ section.settings.mobile_content_alignment }}
         banner--mobile-position-{{ section.settings.mobile_content_position }}
         banner--{{ section.settings.image_height }}
         {% if section.settings.stack_images_on_mobile and section.settings.image != blank and section.settings.image_2 != blank %} banner--stacked{% endif %}
         {% if section.settings.image_height == 'adapt' and section.settings.image != blank %} banner--adapt{% endif %}
         {% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}
         {% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}
         {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}
         {% if section.settings.desktop_height_300 %} acs-desktop-h-300{% endif %}"
>
  {% assign alt = collection.title | default: shop.name %}

  {%- if section.settings.image != blank -%}
    <div class="banner__media block__desktop-image media{% if section.settings.image == blank and section.settings.image_2 == blank %} placeholder{% endif %}{% if section.settings.image_2 != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
        assign image_class = ''
        if section.settings.image_2 != blank
          assign image_class = 'banner__media-image-half'
        endif
        if section.settings.image_2 != blank and section.settings.stack_images_on_mobile
          assign sizes = stacked_sizes
        elsif section.settings.image_2 != blank
          assign sizes = half_width
        else
          assign sizes = full_width
        endif
      -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          height: image_height,
          class: image_class,
          sizes: sizes,
          alt: alt,
          widths: widths,
          fetchpriority: fetch_priority
      }}

      {%- if section.settings.logo_mode == 'image' and section.settings.logo_image != blank -%}
        <div class="acs-badge-wrap" style="right: {{ section.settings.logo_inset_right }}px; bottom: {{ section.settings.logo_inset_bottom }}px;">
          {%- if section.settings.show_visible_meta and section.settings.visible_meta_text != blank -%}
            <div class="acs-meta-text">{{ section.settings.visible_meta_text }}</div>
          {%- endif -%}
          {%- if section.settings.logo_link != blank -%}
            <a href="{{ section.settings.logo_link }}" aria-label="{{ section.settings.logo_alt | escape }}">
              {{ section.settings.logo_image | image_url: width: 600 | image_tag: alt: section.settings.logo_alt }}
            </a>
          {%- else -%}
            {{ section.settings.logo_image | image_url: width: 600 | image_tag: alt: section.settings.logo_alt }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.settings.image_2 != blank -%}
    <div class="banner__media media{% if section.settings.image != blank %} banner__media-half{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height_2 = section.settings.image_2.width | divided_by: section.settings.image_2.aspect_ratio
        assign image_class_2 = ''
        if section.settings.image != blank
          assign image_class_2 = 'banner__media-image-half'
        endif
        if section.settings.stack_images_on_mobile
          assign sizes = stacked_sizes
        else
          assign sizes = half_width
        endif
      -%}
      {{
        section.settings.image_2
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image_2.width,
          height: image_height_2,
          class: image_class_2,
          sizes: sizes,
          alt: alt,
          widths: widths,
          fetchpriority: fetch_priority
      }}
    </div>
  {%- endif -%}

  {% if section.settings.mobile_image != blank -%}
    <div class="banner__media media block__mobile-image{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {%- liquid
        assign image_height = section.settings.mobile_image.width | divided_by: section.settings.mobile_image.aspect_ratio
        assign image_class = ''
        if section.settings.image_2 != blank
          assign image_class = 'banner__media-image-half'
        endif
        assign sizes = full_width
      -%}
      {{
        section.settings.mobile_image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.mobile_image.width,
          height: image_height,
          class: image_class,
          sizes: sizes,
          alt: alt,
          widths: widths,
          fetchpriority: fetch_priority
      }}
    </div>
  {% endif %}

  <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.color_scheme }} gradient">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="banner__heading inline-richtext {{ block.settings.heading_size }} h2" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h1>
          {%- when 'text' -%}
            <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- when 'buttons' -%}
            <div class="banner__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a {% if block.settings.button_link_1 == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.button_link_1 }}" {% endif %}
                   class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}">
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a {% if block.settings.button_link_2 == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.button_link_2 }}" {% endif %}
                   class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}">
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- endif -%}
            </div>
          {%- when 'inline_image' -%}
            {% if block.settings.image %}
              <div class="banner__inline-image-wrapper">
                {{ block.settings.image | image_url: width: 600 | image_tag }}
              </div>
            {% endif %}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.logo_mode == 'section' and section.settings.logo_image != blank -%}
    <div class="acs-badge-wrap" aria-hidden="false">
      {%- if section.settings.show_visible_meta and section.settings.visible_meta_text != blank -%}
        <div class="acs-meta-text">{{ section.settings.visible_meta_text }}</div>
      {%- endif -%}
      {%- if section.settings.logo_link != blank -%}
        <a href="{{ section.settings.logo_link }}" aria-label="{{ section.settings.logo_alt | escape }}">
          {{ section.settings.logo_image | image_url: width: 600 | image_tag: alt: section.settings.logo_alt }}
        </a>
      {%- else -%}
        {{ section.settings.logo_image | image_url: width: 600 | image_tag: alt: section.settings.logo_alt }}
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{%- comment -%} JSON-LD meta description (non-visual) {%- endcomment -%}
{%- if section.settings.meta_description != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPageElement",
    "name": {{ section.settings.ld_name | default: shop.name | json }},
    "description": {{ section.settings.meta_description | json }},
    {% if section.settings.image %}"image": {{ section.settings.image | image_url: width: 1200 | json }},{% endif %}
    "position": {{ section.index | plus: 0 }}
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "ACS Image Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Desktop Image" },
    { "type": "image_picker", "id": "image_2", "label": "Optional Second Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },

    { "type": "select", "id": "image_height", "label": "Image Height", "options": [
      { "value": "adapt", "label": "Adapt to Image" },
      { "value": "small", "label": "Small" },
      { "value": "medium", "label": "Medium" },
      { "value": "large", "label": "Large" }
    ], "default": "medium" },

    { "type": "select", "id": "desktop_content_position", "label": "Content Position (Desktop)", "options": [
      { "value": "top-left", "label": "Top Left" },
      { "value": "top-center", "label": "Top Center" },
      { "value": "top-right", "label": "Top Right" },
      { "value": "middle-left", "label": "Middle Left" },
      { "value": "middle-center", "label": "Middle Center" },
      { "value": "middle-right", "label": "Middle Right" },
      { "value": "bottom-left", "label": "Bottom Left" },
      { "value": "bottom-center", "label": "Bottom Center" },
      { "value": "bottom-right", "label": "Bottom Right" }
    ], "default": "middle-left" },

    { "type": "select", "id": "desktop_content_alignment", "label": "Content Alignment (Desktop)", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },

    { "type": "select", "id": "mobile_content_alignment", "label": "Content Alignment (Mobile)", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },

    { "type": "select", "id": "mobile_content_position", "label": "Content Vertical Position (Mobile)", "options": [
      { "value": "top", "label": "Top" },
      { "value": "middle", "label": "Middle" },
      { "value": "bottom", "label": "Bottom" }
    ], "default": "middle" },

    { "type": "checkbox", "id": "show_text_box", "label": "Show Text Box", "default": true },
    { "type": "checkbox", "id": "stack_images_on_mobile", "label": "Stack Images on Mobile", "default": true },
    { "type": "checkbox", "id": "show_text_below", "label": "Show Text Below Image on Mobile", "default": true },

    { "type": "checkbox", "id": "desktop_height_300", "label": "Force desktop height to 300px", "default": true },

    { "type": "color", "id": "text_color", "label": "Text Color" },
    { "type": "color", "id": "overlay_color", "label": "Overlay Background Color", "default": "#000000" },
    { "type": "range", "id": "image_overlay_opacity", "min": 0, "max": 100, "step": 10, "unit": "%", "label": "Overlay Opacity", "default": 0 },

    { "type": "range", "id": "padding_y_desktop", "min": 16, "max": 120, "step": 2, "unit": "px", "label": "Vertical padding (desktop)", "default": 40 },
    { "type": "range", "id": "padding_y_mobile", "min": 8, "max": 96, "step": 2, "unit": "px", "label": "Vertical padding (mobile)", "default": 24 },
    { "type": "range", "id": "padding_x_desktop", "min": 0, "max": 120, "step": 2, "unit": "px", "label": "Horizontal padding (desktop)", "default": 32 },
    { "type": "range", "id": "padding_x_mobile", "min": 0, "max": 80, "step": 2, "unit": "px", "label": "Horizontal padding (mobile)", "default": 20 },

    { "type": "text", "id": "ld_name", "label": "Structured Data: Name (optional)" },
    { "type": "textarea", "id": "meta_description", "label": "Structured Data: Description (JSON-LD)" },

    { "type": "checkbox", "id": "show_visible_meta", "label": "Show visible meta/disclaimer text next to logo", "default": false },
    { "type": "textarea", "id": "visible_meta_text", "label": "Visible meta/disclaimer text" },
    { "type": "color", "id": "meta_text_color", "label": "Meta text color", "default": "#FFFFFF" },
    { "type": "select", "id": "meta_text_size", "label": "Meta text size", "options": [
      { "value": "caption", "label": "Caption" },
      { "value": "body", "label": "Body" }
    ], "default": "body" },
    { "type": "range", "id": "meta_text_max_width", "label": "Meta text max width (px)", "min": 120, "max": 480, "step": 10, "default": 260 },

    { "type": "radio", "id": "logo_mode", "label": "Logo placement", "options": [
      { "value": "none", "label": "None" },
      { "value": "section", "label": "Bottom-right of section" },
      { "value": "image", "label": "Bottom-right over image" }
    ], "default": "none" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text", "default": "Brand logo" },
    { "type": "url", "id": "logo_link", "label": "Logo link" },
    { "type": "range", "id": "logo_width", "label": "Logo width (px)", "min": 40, "max": 320, "step": 4, "default": 120 },
    { "type": "range", "id": "logo_inset_right", "label": "Logo right inset (px)", "min": 0, "max": 80, "step": 2, "default": 16 },
    { "type": "range", "id": "logo_inset_bottom", "label": "Logo bottom inset (px)", "min": 0, "max": 80, "step": 2, "default": 16 },
    { "type": "range", "id": "logo_inset_right_mobile", "label": "Logo right inset (mobile px)", "min": 0, "max": 80, "step": 2, "default": 12 },
    { "type": "range", "id": "logo_inset_bottom_mobile", "label": "Logo bottom inset (mobile px)", "min": 0, "max": 80, "step": 2, "default": 12 }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Heading Text", "default": "Big bold banner heading" },
        { "type": "select", "id": "heading_size", "label": "Size", "options": [
          { "value": "h2", "label": "H2" },
          { "value": "h1", "label": "H1" },
          { "value": "h0", "label": "Huge" },
          { "value": "hxl", "label": "XL" },
          { "value": "hxxl", "label": "XXL" }
        ], "default": "h1" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 3,
      "settings": [
        { "type": "inline_richtext", "id": "text", "label": "Text" },
        { "type": "select", "id": "text_style", "label": "Style", "options": [
          { "value": "body", "label": "Body" },
          { "value": "subtitle", "label": "Subtitle" },
          { "value": "caption-with-letter-spacing", "label": "Caption" }
        ], "default": "body" }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label_1", "label": "Button 1 Label", "default": "Shop Now" },
        { "type": "url", "id": "button_link_1", "label": "Button 1 Link" },
        { "type": "checkbox", "id": "button_style_secondary_1", "label": "Secondary Style?", "default": false },
        { "type": "text", "id": "button_label_2", "label": "Button 2 Label" },
