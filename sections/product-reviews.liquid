{%- comment -%}
  PowerReviews — full reviews section for the PDP.

  Credentials (from shopify-USA / PowerReviews account):
    api_key:           47fff520-f385-4739-afdf-0e90788492b6
    merchant_group_id: 2014345704
    merchant_id:       1806575603
    page_id:           product.id  (Shopify product ID — consistent with existing data)

  Components rendered on this page:
    ReviewSnippet  → #pr-reviewsnippet  (injected by snippets/powerreviews-rating.liquid
                                          as a custom_liquid block near the product title)
    ReviewDisplay  → #pr-reviewdisplay  (full review list, rendered here)
    QuestionDisplay→ #pr-questiondisplay (Q&A tab, rendered here)

  Script loading:
    ui.js is loaded via a <script> tag in this section so it only loads
    on pages that include this section (product pages). Shopify deduplicates
    section scripts automatically.
{%- endcomment -%}

{%- liquid
  assign pr_domain = shop.url
-%}

<div class="product-reviews" id="product-reviews">
  <div class="page-width">

    <div class="product-reviews__header">
      <h2 class="product-reviews__heading">Customer Reviews</h2>
    </div>

    {%- comment -%} PowerReviews full review display {%- endcomment -%}
    <div id="pr-reviewdisplay" class="product-reviews__display"></div>

    {%- comment -%} PowerReviews Q&A (optional — remove div to disable) {%- endcomment -%}
    <div id="pr-questiondisplay" class="product-reviews__questions"></div>

  </div>
</div>

{%- comment -%} PowerReviews UI script — loads once per page {%- endcomment -%}
<script src="https://ui.powerreviews.com/stable/4.1/ui.js" defer="defer"></script>

<script>
  // Queue shim — pwr() calls made before ui.js loads are safely deferred
  window.pwr = window.pwr || function () {
    (window.pwr.q = window.pwr.q || []).push(arguments);
  };

  (function () {
    var PR_CREDENTIALS = {
      api_key:           '47fff520-f385-4739-afdf-0e90788492b6',
      locale:            'en_US',
      merchant_group_id: '2014345704',
      merchant_id:       '1806575603'
    };

    var PR_PAGE_ID = '{{ product.id }}';

    // Feedless product data — tells PowerReviews about this product
    // without requiring a nightly product feed file.
    var PR_PRODUCT = {
      name:          {{ product.title | json }},
      url:           {{ pr_domain | append: product.url | json }},
      image_url:     {{ product.featured_image | image_url: width: 600 | prepend: 'https:' | json }},
      description:   {{ product.description | strip_html | strip_newlines | json }},
      category_name: {{ product.type | default: 'Default' | json }},
      upc:           {{ product.barcode | remove: ' ' | remove: '-' | json }},
      brand_name:    {{ product.vendor | json }},
      price:         {{ product.price | money_without_currency | json }},
      variants: [
        {%- for variant in product.variants -%}
          {
            page_id_variant: {{ variant.sku | default: variant.id | json }},
            upc:             {{ variant.barcode | remove: ' ' | remove: '-' | json }},
            asin:            ''
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    };

    // Schema.org structured data for enhanced Google SEO
    var PR_SUBJECT = {
      '@context': 'https://schema.org',
      '@type':    'Product',
      name:       {{ product.title | json }},
      brand: {
        '@type': 'Brand',
        name:    {{ product.vendor | json }}
      },
      description: {{ product.description | strip_html | json }},
      image: [
        {%- for image in product.images limit: 5 -%}
          {{ image | image_url: width: 600 | prepend: 'https:' | json }}
          {%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      offers: [
        {%- for variant in product.variants -%}
          {
            '@type':        'Offer',
            price:          {{ variant.price | money_without_currency | json }},
            priceCurrency:  {{ cart.currency.iso_code | json }},
            itemCondition:  'https://schema.org/NewCondition',
            availability:   'https://schema.org/{{ variant.available | default: false | json: false | replace: 'false', 'OutOfStock' | replace: 'true', 'InStock' }}',
            url:            {{ pr_domain | append: variant.url | json }},
            itemOffered: {
              '@type': 'IndividualProduct',
              name:    {{ product.title | append: ': ' | append: variant.title | json }}
              {%- if variant.barcode -%}
                ,gtin: {{ variant.barcode | json }}
              {%- endif -%}
            },
            seller: {
              '@type': 'Organization',
              name:    {{ shop.name | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    };

    function initPowerReviews() {
      var components = {};
      var elements   = [];

      // ReviewSnippet — inline stars near the title (DOM injected by powerreviews-rating snippet)
      if (document.getElementById('pr-reviewsnippet')) {
        components.ReviewSnippet = 'pr-reviewsnippet';
      }

      // ReviewDisplay — full review list (this section)
      if (document.getElementById('pr-reviewdisplay')) {
        components.ReviewDisplay = 'pr-reviewdisplay';
      }

      // Q&A (optional)
      if (document.getElementById('pr-questiondisplay')) {
        components.QuestionDisplay = 'pr-questiondisplay';
      }

      if (Object.keys(components).length === 0) return;

      elements.push(Object.assign({}, PR_CREDENTIALS, {
        page_id:           PR_PAGE_ID,
        review_wrapper_url: '{{ pr_domain }}/pages/write-a-review?pr_page_id={{ product.id }}',
        product:           PR_PRODUCT,
        subject:           PR_SUBJECT,
        components:        components
      }));

      // CategorySnippets on collection / search pages
      document.querySelectorAll('[data-pr-component="CategorySnippet"]').forEach(function (el) {
        if (el.dataset.prMounted) return;
        el.id = 'pr-cat-' + Math.floor(Math.random() * 1e8);
        elements.push(Object.assign({}, PR_CREDENTIALS, {
          page_id:                         el.dataset.prPageId,
          ENABLE_CLIENT_SIDE_STRUCTURED_DATA: false,
          components: { CategorySnippet: el.id }
        }));
      });

      if (elements.length > 0) {
        pwr('render', elements);
      }
    }

    // Run after DOM is ready; ui.js is deferred so it will also be ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPowerReviews);
    } else {
      initPowerReviews();
    }
  })();
</script>

{% style %}
  .product-reviews {
    padding: 72px 0;
    border-top: 1px solid var(--brand-gray-200);
    background: var(--brand-white);
  }

  .product-reviews__header {
    margin-bottom: 32px;
  }

  .product-reviews__heading {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--brand-gray-900);
  }

  /* ── PowerReviews global brand overrides ── */
  .product-reviews .p-w-r,
  .product-reviews .p-w-r * {
    font-family: var(--font-body-family) !important;
  }

  /* Star colour */
  .product-reviews .pr-star-v4-100-filled,
  .product-reviews .pr-star-v4-75-filled,
  .product-reviews .pr-star-v4-50-filled,
  .product-reviews .pr-star-v4 {
    color: #f59e0b !important;
  }

  /* Primary action buttons (Write a Review, Submit, etc.) */
  .product-reviews .pr-btn-primary,
  .product-reviews .pr-btn-review,
  .product-reviews .pr-snippet-write-review-link {
    background-color: var(--brand-navy) !important;
    border-color:     var(--brand-navy) !important;
    border-radius:    var(--brand-radius) !important;
    font-weight:      700 !important;
    color:            #ffffff !important;
  }

  .product-reviews .pr-btn-primary:hover,
  .product-reviews .pr-btn-review:hover {
    background-color: var(--brand-cyan) !important;
    border-color:     var(--brand-cyan) !important;
    color:            var(--brand-navy) !important;
  }

  /* Links */
  .product-reviews .p-w-r a {
    color: var(--brand-cyan) !important;
  }

  /* Review cards */
  .product-reviews .pr-review-wrap {
    border-bottom: 1px solid var(--brand-gray-200) !important;
  }

  /* Headline text */
  .product-reviews .pr-review-author-name,
  .product-reviews .pr-review-rating-headline {
    color: var(--brand-gray-900) !important;
    font-weight: 700 !important;
  }

  /* Body text */
  .product-reviews .pr-review-text {
    color: var(--brand-gray-600) !important;
    line-height: 1.65 !important;
  }

  /* Histogram bars */
  .product-reviews .pr-ratings-histogram-bar-container .pr-histogram-fill {
    background-color: var(--brand-navy) !important;
  }

  @media screen and (max-width: 749px) {
    .product-reviews { padding: 48px 0; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Product Reviews",
  "settings": [],
  "presets": [{ "name": "Product Reviews" }]
}
{% endschema %}
