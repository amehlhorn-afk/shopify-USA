{%- comment -%}
  PowerReviews reviews section — custom-styled to match BEDGEAR design reference.

  Structure:
    1. Support bar  — "Need Help?" with Live Chat / Phone / Email links
    2. Section header — eyebrow + large count headline + cyan line
    3. PowerReviews ReviewDisplay — PR renders rating histogram + review cards;
       CSS below transforms the default output into the 3-column card grid
       shown in the design reference.

  Credentials (from shopify-USA):
    api_key: 47fff520-f385-4739-afdf-0e90788492b6
    merchant_group_id: 2014345704  |  merchant_id: 1806575603
    page_id: product.id
{%- endcomment -%}

{%- liquid
  assign pr_domain = shop.url
-%}

{%- comment -%} ── 1. Support Bar ── {%- endcomment -%}
<div class="pr-support-bar">
  <div class="page-width">
    <div class="pr-support-bar__inner">
      <div class="pr-support-bar__left">
        <span class="pr-support-bar__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
            <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
            <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
          </svg>
        </span>
        <div class="pr-support-bar__copy">
          <strong class="pr-support-bar__heading">{{ section.settings.support_heading }}</strong>
          <p class="pr-support-bar__text">{{ section.settings.support_text }}</p>
        </div>
      </div>
      <p class="pr-support-bar__avail small-hide">{{ section.settings.support_availability }}</p>
    </div>

    <div class="pr-support-bar__actions">
      {%- if section.settings.chat_label != blank -%}
        <a href="{{ section.settings.chat_url }}" class="pr-support-bar__action">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          {{ section.settings.chat_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.phone_label != blank -%}
        <span class="pr-support-bar__divider" aria-hidden="true">|</span>
        <a href="tel:{{ section.settings.phone_url }}" class="pr-support-bar__action">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ section.settings.phone_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.email_label != blank -%}
        <span class="pr-support-bar__divider" aria-hidden="true">|</span>
        <a href="mailto:{{ section.settings.email_url }}" class="pr-support-bar__action">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
          {{ section.settings.email_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- comment -%} ── 2. Reviews section ── {%- endcomment -%}
<div class="product-reviews" id="product-reviews">
  <div class="page-width">

    <div class="product-reviews__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="product-reviews__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="product-reviews__headline">
        <span class="product-reviews__headline-count">{{ section.settings.headline_count }}</span>
        {%- if section.settings.headline_cyan != blank -%}
          <span class="product-reviews__headline-cyan">{{ section.settings.headline_cyan }}</span>
        {%- endif -%}
      </h2>
    </div>

    {%- comment -%} PowerReviews renders rating histogram + review cards here {%- endcomment -%}
    <div id="pr-reviewdisplay" class="product-reviews__display"></div>
    <div id="pr-questiondisplay" class="product-reviews__questions"></div>

  </div>
</div>

{%- comment -%} ── PowerReviews init ── {%- endcomment -%}
<script src="https://ui.powerreviews.com/stable/4.1/ui.js" defer="defer"></script>
<script>
  window.pwr = window.pwr || function () {
    (window.pwr.q = window.pwr.q || []).push(arguments);
  };

  (function () {
    var PR_CREDENTIALS = {
      api_key:           '47fff520-f385-4739-afdf-0e90788492b6',
      locale:            'en_US',
      merchant_group_id: '2014345704',
      merchant_id:       '1806575603'
    };

    var PR_PRODUCT = {
      name:          {{ product.title | json }},
      url:           {{ pr_domain | append: product.url | json }},
      image_url:     {{ product.featured_image | image_url: width: 600 | prepend: 'https:' | json }},
      description:   {{ product.description | strip_html | strip_newlines | json }},
      category_name: {{ product.type | default: 'Default' | json }},
      upc:           {{ product.barcode | remove: ' ' | remove: '-' | json }},
      brand_name:    {{ product.vendor | json }},
      price:         {{ product.price | money_without_currency | json }},
      variants: [
        {%- for variant in product.variants -%}
          {
            page_id_variant: {{ variant.sku | default: variant.id | json }},
            upc: {{ variant.barcode | remove: ' ' | remove: '-' | json }},
            asin: ''
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    };

    var PR_SUBJECT = {
      '@context': 'https://schema.org',
      '@type':    'Product',
      name:       {{ product.title | json }},
      brand:      { '@type': 'Brand', name: {{ product.vendor | json }} },
      description: {{ product.description | strip_html | json }},
      image: [
        {%- for image in product.images limit: 5 -%}
          {{ image | image_url: width: 600 | prepend: 'https:' | json }}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      offers: [
        {%- for variant in product.variants -%}
          {
            '@type': 'Offer',
            price: {{ variant.price | money_without_currency | json }},
            priceCurrency: {{ cart.currency.iso_code | json }},
            itemCondition: 'https://schema.org/NewCondition',
            availability: 'https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}',
            url: {{ pr_domain | append: variant.url | json }},
            itemOffered: {
              '@type': 'IndividualProduct',
              name: {{ product.title | append: ': ' | append: variant.title | json }}
              {%- if variant.barcode -%}, gtin: {{ variant.barcode | json }}{%- endif -%}
            },
            seller: { '@type': 'Organization', name: {{ shop.name | json }} }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    };

    function initPowerReviews() {
      var components = {};
      if (document.getElementById('pr-reviewsnippet'))   components.ReviewSnippet   = 'pr-reviewsnippet';
      if (document.getElementById('pr-reviewdisplay'))   components.ReviewDisplay   = 'pr-reviewdisplay';
      if (document.getElementById('pr-questiondisplay')) components.QuestionDisplay = 'pr-questiondisplay';
      if (Object.keys(components).length === 0) return;

      var elements = [Object.assign({}, PR_CREDENTIALS, {
        page_id:            '{{ product.id }}',
        review_wrapper_url: '{{ pr_domain }}/pages/write-a-review?pr_page_id={{ product.id }}',
        product:            PR_PRODUCT,
        subject:            PR_SUBJECT,
        components:         components
      })];

      // CategorySnippets on collection pages
      document.querySelectorAll('[data-pr-component="CategorySnippet"]').forEach(function (el) {
        if (el.dataset.prMounted) return;
        el.id = 'pr-cat-' + Math.floor(Math.random() * 1e8);
        elements.push(Object.assign({}, PR_CREDENTIALS, {
          page_id: el.dataset.prPageId,
          ENABLE_CLIENT_SIDE_STRUCTURED_DATA: false,
          components: { CategorySnippet: el.id }
        }));
      });

      pwr('render', elements);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPowerReviews);
    } else {
      initPowerReviews();
    }
  })();
</script>

{% style %}

  /* ═══════════════════════════════════════════
     SUPPORT BAR
  ═══════════════════════════════════════════ */
  .pr-support-bar {
    border: 1.5px solid var(--brand-gray-200);
    border-radius: var(--brand-radius-lg);
    margin: 0 0 64px;
    overflow: hidden;
  }

  .pr-support-bar .page-width { padding: 0; }

  .pr-support-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 28px;
    gap: 20px;
  }

  .pr-support-bar__left {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .pr-support-bar__icon {
    flex-shrink: 0;
    color: var(--brand-gray-500);
    margin-top: 2px;
  }

  .pr-support-bar__heading {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: var(--brand-gray-900);
    margin-bottom: 4px;
  }

  .pr-support-bar__text {
    font-size: 14px;
    color: var(--brand-gray-600);
    line-height: 1.55;
    margin: 0;
    max-width: 420px;
  }

  .pr-support-bar__avail {
    font-size: 14px;
    color: var(--brand-gray-500);
    white-space: nowrap;
    margin: 0;
    flex-shrink: 0;
  }

  .pr-support-bar__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 14px 28px;
    border-top: 1px solid var(--brand-gray-200);
    background: var(--brand-gray-50);
  }

  .pr-support-bar__action {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    font-weight: 600;
    color: var(--brand-gray-800);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pr-support-bar__action:hover { color: var(--brand-cyan); }

  .pr-support-bar__divider {
    color: var(--brand-gray-300);
    font-size: 18px;
    line-height: 1;
  }

  /* ═══════════════════════════════════════════
     SECTION HEADER
  ═══════════════════════════════════════════ */
  .product-reviews {
    padding: 0 0 80px;
    background: var(--brand-white);
  }

  .product-reviews__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--brand-cyan);
    margin: 0 0 10px;
  }

  .product-reviews__headline {
    display: flex;
    flex-direction: column;
    margin: 0 0 36px;
    gap: 0;
    line-height: 1.0;
  }

  .product-reviews__headline-count {
    display: block;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--brand-gray-900);
  }

  .product-reviews__headline-cyan {
    display: block;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--brand-cyan);
  }

  /* ═══════════════════════════════════════════
     POWERREVIEWS GLOBAL OVERRIDES
  ═══════════════════════════════════════════ */
  .product-reviews .p-w-r,
  .product-reviews .p-w-r * {
    font-family: var(--font-body-family) !important;
    box-sizing: border-box !important;
  }

  /* ── Rating summary card ── */
  .product-reviews .pr-review-snapshot {
    background: var(--brand-gray-50) !important;
    border: 1.5px solid var(--brand-gray-200) !important;
    border-radius: var(--brand-radius-lg) !important;
    padding: 28px 32px !important;
    margin-bottom: 40px !important;
  }

  .product-reviews .pr-review-snapshot-simple .pr-snapshot-rating {
    font-size: 56px !important;
    font-weight: 900 !important;
    color: var(--brand-gray-900) !important;
    line-height: 1 !important;
  }

  /* Histogram bars */
  .product-reviews .pr-ratings-histogram-bar-container .pr-histogram-count {
    background: var(--brand-gray-200) !important;
    border-radius: 999px !important;
    height: 8px !important;
  }

  .product-reviews .pr-ratings-histogram-bar-container .pr-histogram-fill {
    background: #f59e0b !important;
    border-radius: 999px !important;
    height: 8px !important;
  }

  /* Summary stats labels */
  .product-reviews .pr-snapshot-consensus-value,
  .product-reviews .pr-snapshot-rating-decimal {
    font-size: 24px !important;
    font-weight: 800 !important;
    color: var(--brand-gray-900) !important;
  }

  .product-reviews .pr-snapshot-label {
    font-size: 10px !important;
    font-weight: 700 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    color: var(--brand-gray-500) !important;
  }

  /* ── Stars ── */
  .product-reviews .pr-star-v4-100-filled,
  .product-reviews .pr-star-v4-75-filled,
  .product-reviews .pr-star-v4-50-filled,
  .product-reviews .pr-star-v4 {
    color: #f59e0b !important;
  }

  /* ── 3-column review card grid ── */
  .product-reviews .pr-review-list {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 20px !important;
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* Individual review card */
  .product-reviews .pr-review {
    background: var(--brand-white) !important;
    border: 1.5px solid var(--brand-gray-200) !important;
    border-radius: var(--brand-radius-lg) !important;
    padding: 24px !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 10px !important;
    break-inside: avoid !important;
  }

  /* Stars row */
  .product-reviews .pr-review .pr-review-rating {
    margin-bottom: 4px !important;
  }

  /* Author name + verified */
  .product-reviews .pr-review-author-name {
    font-size: 14px !important;
    font-weight: 700 !important;
    color: var(--brand-gray-900) !important;
  }

  .product-reviews .pr-badging-icon,
  .product-reviews .pr-verified-purchaser {
    color: var(--brand-cyan) !important;
    font-size: 12px !important;
    font-weight: 600 !important;
  }

  .product-reviews .pr-review-author {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    flex-wrap: wrap !important;
  }

  /* Review headline */
  .product-reviews .pr-review-rating-headline {
    font-size: 15px !important;
    font-weight: 700 !important;
    color: var(--brand-gray-900) !important;
    line-height: 1.3 !important;
    margin: 0 !important;
  }

  /* Review body — italic in quotes */
  .product-reviews .pr-review-text {
    font-size: 14px !important;
    color: var(--brand-gray-600) !important;
    line-height: 1.65 !important;
    font-style: italic !important;
    flex-grow: 1 !important;
  }

  /* Tag chips (attributes like HOT SLEEPER, SIDE SLEEPER) */
  .product-reviews .pr-attribute-value,
  .product-reviews .pr-attribute-key-value .pr-attribute-value-list li,
  .product-reviews .pr-rd-def-list dd {
    display: inline-block !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    color: var(--brand-gray-700) !important;
    border: 1.5px solid var(--brand-gray-300) !important;
    border-radius: var(--brand-radius) !important;
    padding: 4px 10px !important;
    background: transparent !important;
    margin-top: 8px !important;
  }

  /* Action buttons */
  .product-reviews .pr-btn-primary,
  .product-reviews .pr-snippet-write-review-link {
    background: var(--brand-navy) !important;
    border-color: var(--brand-navy) !important;
    border-radius: var(--brand-radius) !important;
    font-weight: 700 !important;
    color: #fff !important;
    transition: background 0.15s ease !important;
  }

  .product-reviews .pr-btn-primary:hover,
  .product-reviews .pr-snippet-write-review-link:hover {
    background: var(--brand-cyan) !important;
    border-color: var(--brand-cyan) !important;
    color: var(--brand-navy) !important;
  }

  .product-reviews .p-w-r a { color: var(--brand-cyan) !important; }

  /* Pagination */
  .product-reviews .pr-pagination .pr-page-btn[aria-current="true"] {
    background: var(--brand-navy) !important;
    border-color: var(--brand-navy) !important;
    color: #fff !important;
    border-radius: var(--brand-radius) !important;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .product-reviews .pr-review-list {
      grid-template-columns: repeat(2, 1fr) !important;
    }

    .pr-support-bar__inner { flex-direction: column; gap: 12px; }
    .pr-support-bar__inner .pr-support-bar__avail { display: none; }
  }

  @media screen and (max-width: 749px) {
    .product-reviews .pr-review-list {
      grid-template-columns: 1fr !important;
    }

    .pr-support-bar { margin-bottom: 40px; }
    .product-reviews { padding-bottom: 48px; }
  }

{% endstyle %}

{% schema %}
{
  "name": "Product Reviews",
  "settings": [
    {
      "type": "header",
      "content": "Support Bar"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Heading",
      "default": "Need Help?"
    },
    {
      "type": "textarea",
      "id": "support_text",
      "label": "Body text",
      "default": "Our sleep specialists are here 7 days a week \u2014 Mon\u2013Fri 9am\u20136pm ET, weekends 10am\u20134pm ET."
    },
    {
      "type": "text",
      "id": "support_availability",
      "label": "Availability label (desktop right)",
      "default": "Available 7 days a week"
    },
    {
      "type": "text",
      "id": "chat_label",
      "label": "Live chat label",
      "default": "Live Chat"
    },
    {
      "type": "url",
      "id": "chat_url",
      "label": "Live chat URL"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "1-866-BED-GEAR"
    },
    {
      "type": "text",
      "id": "phone_url",
      "label": "Phone number (for tel: link)",
      "default": "18662334327"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email Us"
    },
    {
      "type": "text",
      "id": "email_url",
      "label": "Email address",
      "default": "support@bedgear.com"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Verified Buyers"
    },
    {
      "type": "text",
      "id": "headline_count",
      "label": "Headline line 1 (black) — review count + label",
      "default": "6,406 reviews."
    },
    {
      "type": "text",
      "id": "headline_cyan",
      "label": "Headline line 2 (cyan)",
      "default": "One pattern."
    }
  ],
  "presets": [
    {
      "name": "Product Reviews"
    }
  ]
}
{% endschema %}
