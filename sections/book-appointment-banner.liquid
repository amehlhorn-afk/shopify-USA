{{ 'section-book-appointment-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_m }}px;
        padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
      .section-{{ section.id }} .block__book-appointment-banner-info {
        background-color: {{ section.settings.color }};
      }
  }
  {% if section.settings.text_color != blank %}
    .block__book-appointment-banner-info h2,.block__book-appointment-banner-info .h2,
    .block__book-appointment-banner-info h3,
    .block__book-appointment-banner-info p{color:{{ section.settings.text_color }};}
    {% endif %}
{% endstyle %}

<div class="section-{{ section.id }} book-appointment-banner">
  <div class="page-width">
    <div class="block__book-appointment-banner">
      <div class="block__book-appointment-banner-img">
        {% assign desktop_img = section.settings.img %}
        {% assign mobile_img = section.settings.img_mobile %}
        {% unless mobile_img != blank %}
          {% assign mobile_img = section.settings.img %}
        {% endunless %}
        {% if desktop_img != blank %}
          <img
            src="{{ desktop_img | image_url: width:desktop_img.width }}"
            alt="{{ desktop_img.alt | default: section.settings.title }}"
            width=""
            height=""
            class="book-appointment-banner-desktop"
            loading="lazy"
          >
          <img
            src="{{ mobile_img | image_url: width:mobile_img.width }}"
            alt="{{ mobile_img.alt | default: section.settings.title }}"
            width=""
            height=""
            class="book-appointment-banner-mobile"
            loading="lazy"
          >
        {% endif %} 
        {% if section.settings.overlay != blank%}
          <span class="w-full z-index-1 h-full block absolute block__overlay_opacity inset-0"
              style="background-color: {{ section.settings.overlay_color }}; opacity:{{ section.settings.overlay_opacity }}%;">
          </span>
        {% endif %}
      </div>
      <div class="block__book-appointment-banner-info text-{{ section.settings.text_align }}">
        {% if section.settings.title != blank %}
          <div class="h2">{{ section.settings.title }}</div>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="body">{{ section.settings.text }}</p>
        {% endif %}
        {% if section.settings.btn != blank %}
          <a href="{{ section.settings.url }}" target="_blank" class="block__scroll_sleep-study button-primary senary-border-radius h6">{{ section.settings.btn }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Book Appointment Banner",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Background Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "unit": "%",
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Background Image(Desktop)"
    },
    {
      "type": "image_picker",
      "id": "img_mobile",
      "label": "Select Background Image(Mobile)"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Book Appointment Banner"
    }
  ]
}
{% endschema %}