{{ 'section-sleeplab-img-with-text.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-sleeplab-img-with-text">
  <div class="page-width">
    <div class="block__sleeplab-img-with-text-row">
      {% for block in section.blocks %}
        <div class="block__sleeplab-img-with-text-item block__img-{{ block.settings.img_position }}">
          {% if block.settings.img != blank %}
            <div class="block__sleeplab-image-wrapper">
              {% if block.settings.video != blank  %}
                {{
                  block.settings.video
                  | video_tag:
                    loop: true,
                    controls: false,
                    muted: true,
                    autoplay: true,
                    loading: 'lazy',
                    class: 'h-full w-full object-cover block absolute inset-0'
                }}
              {% else %}
                {% render 'custom-image', image: block.settings.img, class: 'img-fluid' %}
              {% endif %}
            </div>
          {% endif %}
          <div class="block__sleeplab-text-wrapper">
            {% if block.settings.heading != blank %}
              <h6 class="small_body">{{ block.settings.heading }}</h6>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.caption != blank %}
              <p class="block__sleeplab-text-caption body">{{ block.settings.caption }}</p>
            {% endif %}
            {% if block.settings.btn != blank %}
              <a href="{{ block.settings.url }}" target="_blank" class="body block__scroll_sleep-study button-quaternary">{{ block.settings.btn }}</a>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="block__sleeplab-text-info" class="body">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "sleeplab Image With Text",
  "settings": [
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "sleeplab_info",
      "name": "Sleeplab Info",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Select Video"
        },
        {
          "type": "image_picker",
          "id": "img",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "img_position",
          "label": "Media Position",
          "default": "left",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "text",
          "id": "btn",
          "label": "Button"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "sleeplab Image With Text"
    }
  ]
}
{% endschema %}
