{{ 'section-video-multicolumn.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-video-multicolumn">
  <div class="page-width">
    <div class="block__video-multicolumn-header">
      {% if section.settings.title != blank %}
        <h2 class="primary_h2">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.caption != blank %}
        <p class="body">{{ section.settings.caption }}</p>
      {% endif %}
    </div>
    <div class="block__video-multicolumn-grid">
      {% for block in section.blocks %}
        <div class="block__video-multicolumn-item">
          <div class="block__benefits-perks-video block__benefits-perks-{%- if block.settings.video_url != blank -%}youtube{%- else -%}mp4{%- endif -%}">
            {% if block.settings.video_url != blank %}
              {%- liquid
                assign video_id = block.settings.video_url.id | default: block.settings.video_url.id
                assign loop = ''
                if block.settings.enable_video_looping
                  assign loop = '&loop=1&playlist=' | append: video_id
                endif 
              -%}
              <iframe
                src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1{{ loop }}"
                class="js-youtube"
                allow="autoplay; encrypted-media"
                allowfullscreen
                title="{{ section.settings.description | escape }}"
              ></iframe>
            {% elsif block.settings.video != blank %}
              {% assign poster = block.settings.video | image_url: width: block.settings.video.width %}
              {{ block.settings.video | video_tag: poster:poster, loop:true, width:"100%", height:"100%", playsinline:true }}
              <a href="javascript:void(0)" class="video_btn">{% render 'youtube-icon' %}</a>
            {% else %}
            <img src="{{ block.settings.img | image_url: width:block.settings.img.width }}" alt="{{ block.settings.img.alt | default: shop.name}}" width="" height="" loading="lazy">
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h4 class="primary_h4">{{ block.settings.title }}</h4>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="body">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
  const playButtons = document.querySelectorAll(".video_btn");

  playButtons.forEach((button) => {
    button.addEventListener("click", function () {
      const video = this.closest(".block__benefits-perks-video").querySelector("video");
      if (video) {
        video.play();
        this.style.display = "none"; // Hide play button
      }
    });
  });

  const videos = document.querySelectorAll(".block__benefits-perks-video video");

  videos.forEach((video) => {
    video.addEventListener("click", function () {
      if (!this.paused) {
        this.pause();
        const playButton = this.closest(".block__benefits-perks-video").querySelector(".video_btn");
        if (playButton) {
          playButton.style.display = "block"; // Show play button when paused
        }
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Video MultiColumn",
  "settings": [
    {
      "type": "header",
      "content": "Section Top Text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video-Block",
      "name": "video Block",
      "settings": [
        {
          "type": "video_url",
          "id": "video_url",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
          "label": "t:sections.video.settings.video_url.label",
          "info": "t:sections.video.settings.video_url.info"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "upload a video, Video will be show if youtube video is not available"
        },
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select Image",
          "info": "upload a Image, Image will be show if video is not available"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video MultiColumn"
    }
  ]
}
{% endschema %}
