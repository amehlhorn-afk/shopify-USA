{{ 'section-collaborations-info.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }

  .section-{{ section.id }} .collaborations-subheading {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: {{ section.settings.subheading_spacing_bottom }}px;
      color: {{ section.settings.subheading_color }};
      font-size: {{ section.settings.subheading_font_size }}px;
  }

  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }

      .section-{{ section.id }} .collaborations-subheading {
          font-size: {{ section.settings.subheading_font_size_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-collaborations-info">
  <div class="page-width">
    <div class="block__collaborations-info-row">
      {% if section.settings.img != blank %}
        <div class="block__collaborations-info-image">
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid' %}
        </div>
      {% endif %}
      <div class="block__collaborations-info-text">
        {% if section.settings.subheading != blank %}
          <p class="eyebrow collaborations-subheading">
            {{ section.settings.subheading }}
          </p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}

        {% if section.settings.caption != blank %}
          <p class="body">{{ section.settings.caption }}</p>
        {% endif %}

        <ul>
          {% if section.settings.logo1 != blank %}
            <li>{% render 'custom-image', image: section.settings.logo1, class: 'img-fluid' %}</li>
          {% endif %}
          {% if section.settings.logo2 != blank %}
            <li>{% render 'custom-image', image: section.settings.logo2, class: 'img-fluid' %}</li>
          {% endif %}
        </ul>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collaborations Info",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (Eyebrow)"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#6A6A6A"
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading font size (desktop)",
      "default": 12
    },
    {
      "type": "range",
      "id": "subheading_font_size_m",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading font size (mobile)",
      "default": 11
    },
    {
      "type": "range",
      "id": "subheading_spacing_bottom",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Space below subheading",
      "default": 8
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "image_picker",
      "id": "logo1",
      "label": "Select Logo Image 1"
    },
    {
      "type": "image_picker",
      "id": "logo2",
      "label": "Select Logo Image 2"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Collaborations Info"
    }
  ]
}
{% endschema %}
