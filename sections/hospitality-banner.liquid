{{ 'section-hospitality-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 1199px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
    }
  }

  @media (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_m }}px;
      padding-bottom: {{ section.settings.padding_bottom_m }}px;
    }
  }

  {% if section.settings.text_color != blank %}
  .section-{{ section.id }} .block__hospitality-banner-info p,
  .section-{{ section.id }} .block__hospitality-banner-info h2 {
    color: {{ section.settings.text_color }};
  }
  {% endif %}

  /* ===== OVERRIDE ANY DEFAULT MAX-WIDTH ON CONTENT WRAPPER ===== */
  .section-{{ section.id }} .block__hospitality-banner-info {
    width: 100%;
    max-width: 100%;
  }

  /* ===== HEADING FONT SIZE + HEADER–BODY SPACING + MAX WIDTH ===== */
  .section-{{ section.id }} .block__hospitality-banner-info h2.primary_h2 {
    display: block;
    width: 100%;
    font-size: {{ section.settings.heading_font_size }}px;

    /* NEW: adjustable spacing between header and body */
    margin-bottom: {{ section.settings.header_body_spacing }}px;

    /* adjustable max width */
    max-width: {{ section.settings.heading_max_width }}px !important;
  }

  @media (max-width: 749px) {
    .section-{{ section.id }} .block__hospitality-banner-info h2.primary_h2 {
      font-size: {{ section.settings.heading_font_size_m }}px;

      /* NEW: mobile adjustable spacing between header and body */
      margin-bottom: {{ section.settings.header_body_spacing_m }}px;

      /* mobile adjustable max width */
      max-width: {{ section.settings.heading_max_width_m }}px !important;
    }
  }

  /* Ensure heading max-width respects alignment */
  @media (min-width: 750px) {
    .section-{{ section.id }} .block__hospitality-banner-info.align-left h2 {
      margin-left: 0;
      margin-right: auto;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-center h2 {
      margin-left: auto;
      margin-right: auto;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-right h2 {
      margin-left: auto;
      margin-right: 0;
    }
  }

  /* ===== BODY TEXT: FULL OPACITY ===== */
  .section-{{ section.id }} .block__hospitality-banner-info p {
    opacity: 1 !important;
  }

  /* Prevent default top margin from adding extra spacing */
  .section-{{ section.id }} .block__hospitality-banner-info p.body {
    margin-top: 0;
  }

  /* ===== BODY COPY MAX WIDTH (Desktop) ===== */
  .section-{{ section.id }} .block__hospitality-banner-info p.body {
    display: block;
    width: 100%;

    /* adjustable max width */
    max-width: {{ section.settings.body_max_width }}px !important;
  }

  /* ===== MOBILE BODY FONT SIZE + MAX WIDTH ===== */
  @media (max-width: 749px) {
    .section-{{ section.id }} .block__hospitality-banner-info p.body {
      font-size: {{ section.settings.body_font_size_m }}px;

      /* mobile adjustable max width */
      max-width: {{ section.settings.body_max_width_m }}px !important;
    }
  }

  /* Ensure body max-width respects alignment */
  @media (min-width: 750px) {
    .section-{{ section.id }} .block__hospitality-banner-info.align-left p {
      margin-left: 0;
      margin-right: auto;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-center p {
      margin-left: auto;
      margin-right: auto;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-right p {
      margin-left: auto;
      margin-right: 0;
    }
  }

  /* ===== MEDIA VISIBILITY (desktop vs mobile) ===== */
  .section-{{ section.id }} .hospitality-banner-desktop {
    display: block;
  }

  .section-{{ section.id }} .hospitality-banner-mobile {
    display: none;
  }

  @media (max-width: 749px) {
    .section-{{ section.id }} .hospitality-banner-desktop {
      display: none;
    }

    .section-{{ section.id }} .hospitality-banner-mobile {
      display: block;
    }

    /* Make sure mobile media (img or video) fills the frame */
    .section-{{ section.id }} .block__hospitality-banner-img .hospitality-banner-mobile {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  /* ===== DESKTOP VIDEO SIZING ===== */
  @media (min-width: 750px) {
    .section-{{ section.id }} .block__hospitality-banner-img video.hospitality-banner-desktop {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  /* Match visual style (rounded corners, etc.) */
  .section-{{ section.id }} .block__hospitality-banner-img video.hospitality-banner-desktop,
  .section-{{ section.id }} .block__hospitality-banner-img video.hospitality-banner-mobile {
    border-radius: inherit;
  }

  /* ===== DESKTOP CONTENT ALIGNMENT CONTROL ===== */
  @media (min-width: 750px) {
    .section-{{ section.id }} .block__hospitality-banner-info.align-left {
      text-align: left;
      margin-left: 0;
      margin-right: auto;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-center {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-right {
      text-align: right;
      margin-left: auto;
      margin-right: 0;
    }
  }

  /*
    If your main CSS absolutely positions .block__hospitality-banner-info,
    replace the alignment rules above with this:

  @media (min-width: 750px) {
    .section-{{ section.id }} .block__hospitality-banner-info.align-left {
      left: 0;
      right: auto;
      transform: translateX(0);
      text-align: left;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-center {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      text-align: center;
    }

    .section-{{ section.id }} .block__hospitality-banner-info.align-right {
      left: auto;
      right: 0;
      transform: translateX(0);
      text-align: right;
    }
  }
  */
{% endstyle %}

<div class="section-{{ section.id }} hospitality-banner">
  <div class="page-width">
    <div class="block__hospitality-banner">
      {% if section.settings.overlay or section.settings.overlay_mo %}
        <div
          class="block__hospitality-banner-overlay {% if section.settings.overlay_mo %}block__hospitality-banner-overlay-mobile{% endif %}"
          {% if section.settings.color != blank %}
            style="background-color: {{ section.settings.color }}; opacity: 0.{{ section.settings.overlay_opacity }}"
          {% endif %}
        ></div>
      {% endif %}

      <div class="block__hospitality-banner-img">
        {%- assign desktop_img = section.settings.img -%}
        {%- assign mobile_img = section.settings.img_mobile -%}
        {%- unless mobile_img != blank -%}
          {%- assign mobile_img = section.settings.img -%}
        {%- endunless -%}

        {%- assign desktop_video = section.settings.video_desktop -%}
        {%- assign mobile_video = section.settings.video_mobile -%}
        {%- unless mobile_video != blank -%}
          {%- assign mobile_video = desktop_video -%}
        {%- endunless -%}

        {%- if desktop_video != blank -%}
          {%- comment -%}
            Desktop background video
          {%- endcomment -%}
          <video
            class="hospitality-banner-desktop"
            autoplay
            muted
            loop
            playsinline
            {% if desktop_video.preview_image %}
              poster="{{ desktop_video.preview_image | image_url: width: desktop_video.preview_image.width }}"
            {% endif %}
          >
            {%- for source in desktop_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>

          {%- comment -%}
            Mobile background video (falls back to desktop video if mobile is empty)
          {%- endcomment -%}
          <video
            class="hospitality-banner-mobile"
            autoplay
            muted
            loop
            playsinline
            {% if mobile_video.preview_image %}
              poster="{{ mobile_video.preview_image | image_url: width: mobile_video.preview_image.width }}"
            {% endif %}
          >
            {%- for source in mobile_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>

        {%- elsif desktop_img != blank -%}
          {%- comment -%}
            Fallback: images (original behavior)
          {%- endcomment -%}
          <img loading="lazy"
            src="{{ desktop_img | image_url: width:desktop_img.width }}"
            alt="{{ desktop_img.alt | default: shop.name }}"
            width=""
            height=""
            class="hospitality-banner-desktop"
          >
          <img loading="lazy"
            src="{{ mobile_img | image_url: width:mobile_img.width }}"
            alt="{{ mobile_img.alt | default: shop.name }}"
            width=""
            height=""
            class="hospitality-banner-mobile"
          >
        {%- endif -%}
      </div>

      <div class="block__hospitality-banner-info align-{{ section.settings.desktop_content_alignment }}">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="body">{{ section.settings.text }}</p>
        {% endif %}
        {% if section.settings.btn != blank %}
          <a href="{{ section.settings.url }}" class="{{ section.settings.btn_style }} small_body">
            {{- section.settings.btn -}}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hospitality Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "img_mobile",
      "label": "Select Background Image (Mobile)"
    },
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Background Video (Desktop)"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Background Video (Mobile)",
      "info": "If left empty, the desktop video will be used on mobile."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "btn_style",
      "label": "Button Style",
      "options": [
        { "value": "button-quaternary", "label": "Style 1" },
        { "value": "button-tertiary", "label": "Style 2" }
      ],
      "default": "button-quaternary"
    },

    {
      "type": "header",
      "content": "Section Style"
    },

    {
      "type": "select",
      "id": "desktop_content_alignment",
      "label": "Content Alignment (Desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },

    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "checkbox",
      "id": "overlay_mo",
      "label": "Enable Overlay (Mobile)"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Overlay Background Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 36
    },

    /* ===== NEW: HEADER–BODY SPACING CONTROLS ===== */
    {
      "type": "range",
      "id": "header_body_spacing",
      "label": "Space between header and body (Desktop)",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "header_body_spacing_m",
      "label": "Space between header and body (Mobile)",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 16
    },

    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 116,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_font_size_m",
      "label": "Heading Font Size (Mobile)",
      "min": 12,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 32
    },

    /* ===== HEADING MAX-WIDTH CONTROLS ===== */
    {
      "type": "range",
      "id": "heading_max_width",
      "label": "Heading Max Width (Desktop)",
      "min": 200,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "heading_max_width_m",
      "label": "Heading Max Width (Mobile)",
      "min": 160,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 320
    },

    /* ===== BODY MAX-WIDTH CONTROLS ===== */
    {
      "type": "range",
      "id": "body_max_width",
      "label": "Body Max Width (Desktop)",
      "min": 200,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "body_max_width_m",
      "label": "Body Max Width (Mobile)",
      "min": 160,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 320
    },

    {
      "type": "range",
      "id": "body_font_size_m",
      "label": "Body Font Size (Mobile)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Hospitality Banner"
    }
  ]
}
{% endschema %}
