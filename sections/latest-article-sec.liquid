{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}
{{ 'latest-article-sec.css' | asset_url | stylesheet_tag }}

<div class="block__latest-article-main section-{{ section.id }}-padding" {% if section.settings.bg_color != blank %}style="background-color: {{ section.settings.bg_color }};"{% endif %}>
    <div class="page-width">
        {% if section.settings.title != blank %}
        <div class="block__blog_header">
            <h2 class="primary_h2">{{ section.settings.title }}</h2>
        </div>
        {% endif %}
        <div class="block__blog-list-article block__row">
            <div class="block__item block__left-item">
                {%- assign selected_articles = section.blocks | where: "type", "featured_article" -%}
                {%- if selected_articles.size > 0 -%}
                    {%- assign main_article = selected_articles[0].settings.article -%}
                    {%- if main_article -%}
                        {% render 'latest-card-large', article: main_article, section: section %}
                    {%- endif -%}
                {%- else -%}    
                    {%- for article in section.settings.blog.articles limit: 1 -%}
                        {% render 'latest-card-large', article: article, section: section %}
                    {% endfor %}
                {%- endif -%}
                
            </div>
            <div class="block__item block__right-item flex flex-direction-column gap-20">
                {%- if selected_articles.size > 1 -%}
                    {%- for block in selected_articles offset: 1 limit: 2 -%}
                        {%- assign article = block.settings.article -%}
                        {% if article %}
                            {% render 'latest-card-small', article: article, section: section %}
                        {% endif %}
                    {%- endfor -%}
                {%- else -%}
                    {%- for article in section.settings.blog.articles offset: 1 limit: 2 -%}
                        {% render 'latest-card-small', article: article, section: section %}
                    {%- endfor -%}
                {%- endif -%}
            </div>
            <div class="block__item">
                {% for block in section.blocks %}
                    {% render block %}
                    {% if block.settings.text != blank %}
                        {{ block.settings.text }}
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{% style %}  
    @media (min-width:990px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.desktop_padding_top }}px;
            padding-bottom:{{ section.settings.desktop_padding_bottom }}px;
        }
    }
    @media (max-width:989px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.mobile_padding_top }}px;
            padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
        }
    }
{% endstyle %}

{% schema %}
{
"name": "Latest Articles",
"settings": [
    {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color"
    },
    {
        "type": "blog",
        "id": "blog",
        "label": "Blog"
    },
    {
        "type": "checkbox",
        "id": "show_image",
        "default": true,
        "label": "t:sections.main-blog.settings.show_image.label"
    },
    {
        "type": "text",
        "id": "title",
        "label": "Title"
    },
    {
        "type": "select",
        "id": "image_height",
        "options": [
            {
            "value": "adapt",
            "label": "t:sections.main-blog.settings.image_height.options__1.label"
            },
            {
            "value": "small",
            "label": "t:sections.main-blog.settings.image_height.options__2.label"
            },
            {
            "value": "medium",
            "label": "t:sections.main-blog.settings.image_height.options__3.label"
            },
            {
            "value": "large",
            "label": "t:sections.main-blog.settings.image_height.options__4.label"
            }
        ],
        "default": "medium",
        "label": "t:sections.main-blog.settings.image_height.label",
        "info": "t:sections.main-blog.settings.image_height.info"
    },
    {
        "type": "checkbox",
        "id": "show_date",
        "default": true,
        "label": "t:sections.main-blog.settings.show_date.label"
    },
    {
        "type": "checkbox",
        "id": "show_author",
        "default": false,
        "label": "t:sections.main-blog.settings.show_author.label"
    },
    {
        "type": "header",
        "content": "Desktop Space"
    },
    {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Desktop Padding Top",
        "default": 16
    },
    {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Desktop Padding Bottom",
        "default": 16
    },
    {
        "type": "header",
        "content": "Mobile Space"
    },
    {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Padding Top",
        "default": 16
    },
    {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Padding Bottom",
        "default": 16
    }
],
"blocks": [
    {
      "type": "@app",
    },
    {
      "type": "text",
      "name": "Text Block",
      "settings": [
        {
          "type": "html",
          "id": "text",
          "label": "Add Klaviyo Code"
        }
      ]
    },
    {
        "type": "featured_article", 
        "name": "Featured Article",
        "settings": [
            {
                "type": "article",
                "id": "article",
                "label": "Select Blog Post"
            }
        ]
    }
 ],
 "max_blocks": 4,
"presets": [
    {
        "name": "Latest Articles"
    }
]
}
{% endschema %}

