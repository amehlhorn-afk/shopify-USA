{%- comment -%}
  Renders: custom.pdp_faq_list_items [metaobject_reference]
  Coverage: 87 of 98 active products
  Position: Full-width section near bottom of PDP

  Metaobject type: pdp_faq_content (handle: pdp_faq_content.{product-handle})
  Expected fields (verify in Shopify Admin > Content > Metaobjects):
    - items  [list.metaobject_reference]  — each item has:
        - question  [single_line_text_field]
        - answer    [rich_text_field or multi_line_text_field]
{%- endcomment -%}

{%- liquid
  assign faq_obj = product.metafields.custom.pdp_faq_list_items.value
-%}

{%- if faq_obj != blank -%}
  {%- liquid
    assign faq_items = faq_obj.items.value | default: faq_obj.faq_items.value | default: faq_obj.questions.value
  -%}

  {%- if faq_items != blank -%}
    <div class="product-faq">
      <div class="page-width">
        <div class="product-faq__inner">

          <div class="product-faq__header">
            <p class="product-faq__eyebrow">FAQ</p>
            <h2 class="product-faq__heading">Frequently Asked Questions</h2>
          </div>

          <div class="product-faq__list">
            {%- for item in faq_items -%}
              {%- liquid
                assign question = item.question.value | default: item.q.value | default: item.heading.value | default: item.title.value
                assign answer = item.answer.value | default: item.a.value | default: item.body.value | default: item.content.value
              -%}
              {%- if question != blank -%}
                <details class="product-faq__item">
                  <summary class="product-faq__question">
                    <span>{{ question }}</span>
                    <span class="product-faq__caret" aria-hidden="true">
                      {%- render 'icon-caret' -%}
                    </span>
                  </summary>
                  {%- if answer != blank -%}
                    <div class="product-faq__answer">
                      {{ answer }}
                    </div>
                  {%- endif -%}
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>

        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

{% style %}
  .product-faq {
    padding: 72px 0;
    background: var(--brand-white);
    border-top: 1px solid var(--brand-gray-200);
  }

  .product-faq__inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }

  .product-faq__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--brand-cyan);
    margin-bottom: 10px;
  }

  .product-faq__heading {
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--brand-gray-900);
    line-height: 1.1;
    margin: 0;
  }

  .product-faq__list {
    border-top: 1px solid var(--brand-gray-200);
  }

  .product-faq__item {
    border-bottom: 1px solid var(--brand-gray-200);
  }

  .product-faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    cursor: pointer;
    list-style: none;
    font-size: 15px;
    font-weight: 600;
    color: var(--brand-gray-900);
    gap: 16px;
  }

  .product-faq__question::-webkit-details-marker {
    display: none;
  }

  .product-faq__caret {
    flex-shrink: 0;
    color: var(--brand-gray-400);
    transition: transform 0.2s ease;
  }

  details[open] .product-faq__caret {
    transform: rotate(180deg);
  }

  .product-faq__answer {
    font-size: 14px;
    color: var(--brand-gray-600);
    line-height: 1.75;
    padding-bottom: 20px;
  }

  .product-faq__answer p { margin: 0 0 10px; }
  .product-faq__answer p:last-child { margin-bottom: 0; }

  @media screen and (max-width: 749px) {
    .product-faq__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .product-faq {
      padding: 48px 0;
    }
  }
{% endstyle %}
