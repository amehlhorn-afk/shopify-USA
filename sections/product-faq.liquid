{%- comment -%}
  Metafield: custom.pdp_faq_list_items [metaobject_reference]
  Metaobject fields (flat numbered pattern, up to 14 items):
    - title_1..14    [single_line_text_field]   question
    - content_1..14  [multi_line_text_field]    answer
{%- endcomment -%}

{%- assign faq = product.metafields.custom.pdp_faq_list_items.value -%}

{%- if faq != blank -%}
  {%- comment -%} Check that at least one item has content {%- endcomment -%}
  {%- liquid
    assign faq_has_items = false
    for i in (1..14)
      assign title_key = 'title_'   | append: i
      if faq[title_key] != blank
        assign faq_has_items = true
        break
      endif
    endfor
  -%}

  {%- if faq_has_items -%}
    <div class="product-faq">
      <div class="page-width">
        <div class="product-faq__inner">

          <div class="product-faq__header">
            {%- if section.settings.eyebrow != blank -%}
              <p class="product-faq__eyebrow">{{ section.settings.eyebrow }}</p>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="product-faq__heading">{{ section.settings.heading }}</h2>
            {%- endif -%}
          </div>

          <div class="product-faq__list">
            {%- for i in (1..14) -%}
              {%- liquid
                assign title_key   = 'title_'   | append: i
                assign content_key = 'content_' | append: i
                assign q = faq[title_key]
                assign a = faq[content_key]
              -%}
              {%- if q != blank -%}
                <details class="product-faq__item">
                  <summary class="product-faq__question">
                    <span>{{ q }}</span>
                    <span class="product-faq__caret" aria-hidden="true">{%- render 'icon-caret' -%}</span>
                  </summary>
                  {%- if a != blank -%}
                    <div class="product-faq__answer">{{ a }}</div>
                  {%- endif -%}
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>

        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

{% style %}
  .product-faq {
    padding: 72px 0;
    background: var(--brand-white);
    border-top: 1px solid var(--brand-gray-200);
  }

  .product-faq__inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: start;
  }

  .product-faq__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--brand-cyan);
    margin-bottom: 10px;
  }

  .product-faq__heading {
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--brand-gray-900);
    line-height: 1.1;
    margin: 0;
  }

  .product-faq__list {
    border-top: 1px solid var(--brand-gray-200);
  }

  .product-faq__item {
    border-bottom: 1px solid var(--brand-gray-200);
  }

  .product-faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    cursor: pointer;
    list-style: none;
    font-size: 15px;
    font-weight: 600;
    color: var(--brand-gray-900);
    gap: 16px;
  }

  .product-faq__question::-webkit-details-marker { display: none; }

  .product-faq__caret {
    flex-shrink: 0;
    color: var(--brand-gray-400);
    transition: transform 0.2s ease;
  }

  details[open] .product-faq__caret { transform: rotate(180deg); }

  .product-faq__answer {
    font-size: 14px;
    color: var(--brand-gray-600);
    line-height: 1.75;
    padding-bottom: 20px;
  }

  .product-faq__answer p { margin: 0 0 10px; }
  .product-faq__answer p:last-child { margin-bottom: 0; }

  @media screen and (max-width: 749px) {
    .product-faq__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .product-faq { padding: 48px 0; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Product FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "presets": [{ "name": "Product FAQ" }]
}
{% endschema %}
