  .super-title {
    display: none;
  }
  .primary-title {
    font-weight: 500;
    font-size: 32px;
  }
  .rebuy-product-grid {
    padding-inline: 0;
  }
  .rebuy-product-block {
    padding: 10px;
    border-radius: 8px;
    text-align: left;
    /* background: #f5f5f5; */
  }
  .rebuy-product-media {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 335/248;
  }
  .rebuy-product-media a {
    display: flex;
    aspect-ratio: 335/248;
  }
  .rebuy-product-img {
    max-height: unset;
    min-width: 100%;
    object-fit: cover;
  }
  .rebuy-product-hover-img {
    max-height: unset;
    top: 50%;
    transform: translateY(-50%);
  }
  .rebuy-product-block:hover .rebuy-product-image .rebuy-product-hover-img {
    transform: scale(1.05) translateY(-50%);
  }
  .rebuy-product-title-link {
    font-size: 18px;
    font-weight: 400;
    text-decoration: underline;
    text-decoration-color: transparent;
    line-height: 22px;
  }
  .rebuy-product-block:hover .rebuy-product-title-link {
    text-decoration-color: #000000;
  }
  .rebuy-product-price {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .rebuy-product-options {
    margin-top: 0;
  }
  .rebuy-product-actions {
    margin-top: 10px;
  }
  .rebuy-option-name {
    width: 100%;
    text-align: left;
    font-weight: 500;
    display: block;
    line-height: 1;
    margin-block: 10px 5px;
    font-size: 15px;
  }
  .rebuy-select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
    background-position: bottom 50% right 14px;
    background-size: 10px 10px;
    padding: 7px 32px 7px 14px;
    font-size: 14px;
    color: #000000;
    background-color: #ffffff;
  }
  .rebuy-select option {
    font-weight: 500;
  }
  .rebuy-button {
    background: #000;
    color: #ffffff;
    font-size: unset;
  }
  .rebuy-product-block:hover .rebuy-button {
    background: #ffffff;
    color: #00b5e3;
  }
  .flickity-button,
  .rebuy-carousel__arrow {
    /*top: -30px; */
    top: 25%;
    background-position: center;
    background-repeat: no-repeat;
    border: solid 1px #dddedf;
  }
  .flickity-button svg,
