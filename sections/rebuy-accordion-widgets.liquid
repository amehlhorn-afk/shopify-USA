    }
  }
}
#rebuy-accordion-template--20785331961996__rebuy_accordion_widgets_jRTGdW.rebuy-accordion {
    padding: 80px 0 !important
}
#rebuy-accordion-template--20785331961996__rebuy_accordion_widgets_jRTGdW .rebuy-product-title-link {
            font-size: 16px !important;
            line-height: 24px;
        }


#rebuy-accordion-template--20785331961996__rebuy_accordion_widgets_jRTGdW .rebuy-accordion-container .rebuy-widget .rebuy-product-block {
