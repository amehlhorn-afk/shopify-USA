  @media (min-width: 750px) {
    .rebuy-product-title-link {
      font-size: 20px;
      line-height: 24px;
    }
    .rebuy-button,
    .rebuy-product-price {
      font-size: 16px;
    }
    .rebuy-product-media {
      border-radius: 0;
    }
    .rebuy-button {
      padding: 15px;
    }
  }

  @media (min-width: 990px) {
    .rebuy-carousel__arrow {
      top: 29%;
    }
    .flickity-button.next,
    .rebuy-carousel__arrow--next {
      right: -40px;
    }
    .flickity-button.previous,
    .rebuy-carousel__arrow--prev {
