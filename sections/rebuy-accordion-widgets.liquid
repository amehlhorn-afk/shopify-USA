{%- comment -%}
  Rebuy Carousel Accordion Section
  Allows adding up to 6 rebuy widgets with custom toggle titles
{%- endcomment -%}

<div id="rebuy-accordion-{{ section.id }}" class="{{ section.settings.custom_class }} rebuy-accordion">
  <div class="rebuy-accordion-container">
    <div class="rebuy-accordion-toggles">
        {% for block in section.blocks %}
          <button
            class="rebuy-accordion-toggle{% if forloop.first %} is-active{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.title }}
          </button>
        {% endfor %}
    </div>

    {% for block in section.blocks %}
      <div
        class="rebuy-accordion-panel{% if forloop.first %} is-active{% endif %}"
        data-rebuy-id="{{ block.settings.widget_id }}"
        {{ block.shopify_attributes }}
      ></div>
    {% endfor %}
  </div>
</div>

{%- comment -%} Render widget templates for each block {%- endcomment -%}
{% for block in section.blocks %}
  {% render 'rebuy-accordion-widget-template', widget_id: block.settings.widget_id %}
{% endfor %}

<script>
  document.addEventListener('rebuy.loaded', () => {
    const accordion = document.getElementById('rebuy-accordion-{{ section.id }}');
    if (!accordion) return;

    const toggles = accordion.querySelectorAll('.rebuy-accordion-toggle');
    const panels = accordion.querySelectorAll('.rebuy-accordion-panel');
    const combinedWidgetIds = Array.from(panels).map(p => p.dataset.rebuyId);

    document.addEventListener('rebuy.ready', function (event) {
      const widget = event.detail.widget;
      if (combinedWidgetIds.includes(String(widget.id))) {
        // console.log("combined widget is ready", widget.data.config, widget);

        const panelIndex = combinedWidgetIds.indexOf(String(widget.id));
        const toggle = toggles[panelIndex];
        if (toggle) {
          toggle.addEventListener('click', () => {
            const allTogglesAndPanels = accordion.querySelectorAll('.rebuy-accordion-toggle, .rebuy-accordion-panel');
            allTogglesAndPanels.forEach(el => el.classList.remove('is-active'));
            toggle.classList.add('is-active');
            const panel = accordion.querySelector(`.rebuy-accordion-panel[data-rebuy-id="${widget.id}"]`);
            panel?.classList.add('is-active');
          });
        }
      }
    });
  });
</script>

<style>
.collection.block__main-product-grid {
  display: none !important;
}

#rebuy-accordion-{{ section.id }} {
  background: transparent;
  padding: 48px 20px;
  margin: 0 auto;
  max-width: 1600px;
  overflow: hidden;
}
#rebuy-accordion-{{ section.id }} .rebuy-accordion-container {
  position: relative;
  margin: auto;
}
#rebuy-accordion-{{ section.id }} + [data-rebuy-id] {
  display: none;
}
#rebuy-accordion-{{ section.id }} .rebuy-accordion-toggles {
  max-width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: nowrap;
  gap: 20px;
  z-index: 1;
  min-width: 100%;
  padding: 0 0 20px 0;
}
#rebuy-accordion-{{ section.id }} .rebuy-accordion-toggle {
  position: relative;
  white-space: nowrap;
  text-transform: uppercase;
  font-weight: 600;
  color: #000000;
  padding: 10px 22px;
  border: unset;
  border-radius: 4px;
  letter-spacing: 1px;
  background: #f5f5f5;
  font-family:  var(--font-heading-family);
  transition:
    background 0.3s ease,
    color 0.3s ease,
    border 0.3s;
}
#rebuy-accordion-{{ section.id }} .rebuy-accordion-toggle.is-active,
#rebuy-accordion-{{ section.id }} .rebuy-accordion-toggle:hover {
  background: #009FC7;
  color: #ffffff;
  border: unset;
}

#rebuy-accordion-{{ section.id }} .rebuy-accordion-toggle.is-active:after {
  width: 100%;
}

#rebuy-accordion-{{ section.id }} .rebuy-accordion-panel {
  display: block;
  opacity: 0;
  visibility: hidden;
  max-height: 0;
  overflow: hidden;
}
#rebuy-accordion-{{ section.id }} .rebuy-accordion-panel.is-active {
  opacity: 1;
  visibility: visible;
  max-height: 2000px;
  overflow: visible;
}

@media (max-width: 768px) {
  #rebuy-accordion-{{ section.id }} .rebuy-accordion {
    padding: 20px;
  }
  #rebuy-accordion-{{ section.id }} .rebuy-accordion-toggles {
    gap: 10px 20px;
    flex-wrap: wrap;
  }
  #rebuy-accordion-{{ section.id }} .rebuy-accordion-toggle {
    padding: 6px 16px;
  }
  #rebuy-accordion-{{ section.id }} .rebuy-accordion-toggles::-webkit-scrollbar {
    height: 0;
  }
}
@media (min-width: 990px) {
  #rebuy-accordion-{{ section.id }} {
    padding: 30px 50px;
  }
}

#rebuy-accordion-{{ section.id }} .rebuy-accordion-container .rebuy-widget {
