{{ 'section-fit-check-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} fit-check-banner" {% if section.settings.bg_color !=" blank" %} style="background-color: {{ section.settings.bg_color }};"{% endif %}>
  <div class="page-width">
    <div class="block__fit-check-banner-main">
      <div class="block__fit-check-banner" style="background-color: {{ section.settings.color }};">
        <div class="block__fit-check-banner-info">
          {% if section.settings.title != blank %}
            <h2 class="primary_h2">{{ section.settings.title }}</h2>
          {% endif %}
          {% if section.settings.text != blank %}
            <p class="body">{{ section.settings.text }}</p>
          {% endif %}
          {% if section.settings.btn != blank %}
            <a href="{{ section.settings.url }}" class="{{ section.settings.btn_style }} body">
              {{- section.settings.btn -}}
            </a>
          {% endif %}
        </div>
        <div class="block__fit-check-banner-img">
          {% assign desktop_img = section.settings.img %}
          {% if desktop_img != blank %}
            {% render 'custom-image', image: desktop_img, class: 'img-fluid' %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
{%  style  %} 
  {% if section.settings.text_color != blank %}
  .block__fit-check-banner-info h2,.block__fit-check-banner-info p,.block__fit-check-banner-info p a{
    color:{{ section.settings.text_color}};
    opacity: 1;
  }
  {% endif %}
{% endstyle %}
{% schema %}
{
  "name": "Fit Check Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section Text Color"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Background Image(Desktop)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "btn_style",
      "label": "Button Style",
      "options": [
        {
          "value": "button-quaternary",
          "label": "Style 1"
        },
        {
          "value": "button-tertiary",
          "label": "Style 2"
        }
      ],
      "default": "button-quaternary"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Fit Check Banner"
    }
  ]
}
{% endschema %}
