{{ 'section-collab-product-multicolumn.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
  
  {% for block in section.blocks %}
    .section-{{ section.id }} .block-{{ block.id }} .block__collab-product-multicolumn-img img {
      width: {{ block.settings.img_width }}%;
      height: auto;
    }
    @media (max-width: 749px) {
      .section-{{ section.id }} .block-{{ block.id }} .block__collab-product-multicolumn-img img {
        width: {{ block.settings.img_width_mobile }}%;
      }
    }
  {% endfor %}
{% endstyle %}

<div class="section-{{ section.id }} collab-product-multicolumn">
  <div class="page-width">
    <div class="block__collab-product-multicolumn-header">
      {% if section.settings.title != blank %}
        <h2 class="primary_h2">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.caption != blank %}
        <p class="body">{{ section.settings.caption }}</p>
      {% endif %}
    </div>
    <div class="block__collab-product-multicolumn-grid">
      {% for block in section.blocks %}
        <div class="block__collab-product-multicolumn-item block-{{ block.id }}">
          {% if block.settings.bg != blank %}
            {% render 'custom-image', image: block.settings.bg, class: 'img-fluid' %}
          {% endif %}
          {% if block.settings.img != blank %}
            <div class="block__collab-product-multicolumn-img">
              {% if block.settings.url != blank %}
                <a href="{{ block.settings.url }}">
                  {% render 'custom-image', image: block.settings.img, class: 'img-fluid' %}
                </a>
              {% endif %}
            </div>
          {% endif %}
          <div class="block__collab-product-multicolumn-info">
            {% if block.settings.title != blank %}
              <h4 class="primary_h4">{{ block.settings.title }}</h4>
            {% endif %}
            {% if block.settings.caption != blank %}
              <p class="small_body">{{ block.settings.caption }}</p>
            {% endif %}
            {% if block.settings.btn != blank %}
              <a href="{{ block.settings.url }}" class="button-tertiary body">{{ block.settings.btn }}</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collab Product column",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Product Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "bg",
          "label": "Background Image"
        },
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select Product Image"
        },
        {
          "type": "range",
          "id": "img_width",
          "min": 10,
          "max": 200,
          "step": 5,
          "unit": "%",
          "label": "Product Image Width (Desktop)",
          "default": 100
        },
        {
          "type": "range",
          "id": "img_width_mobile",
          "min": 10,
          "max": 200,
          "step": 5,
          "unit": "%",
          "label": "Product Image Width (Mobile)",
          "default": 100
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "text",
          "id": "btn",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collab Product Multicolumn"
    }
  ]
}
{% endschema %}