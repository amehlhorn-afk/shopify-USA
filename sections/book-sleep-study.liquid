{{ 'section-book-sleep-study.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-book-sleep-study" id="book-sleep-study">
  <div class="page-width">
    <div class="block__book-sleep-study-header">
      {% if section.settings.title != blank %}
        <h2 class="primary_h2">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.caption != blank %}
        <p class="body">{{ section.settings.caption }}</p>
      {% endif %}
    </div>
    <div class="block__book-sleep-study-grid">
      {% for block in section.blocks %}
        <div class="block__book-sleep-study-item block__book-sleep-study-{%- if block.settings.tag != blank -%}popular{%- endif -%}">
          {% if block.settings.tag != blank %}
            <span class="block__book-sleep-study-tag small_body">{{ block.settings.tag }}</span>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <p>{{ block.settings.description }}</p>
          {% endif %}
          {% if block.settings.benefit_title != blank %}
            <div class="block__book-sleep-study-benefit">
              <p>
                <span class="small_body">{{ block.settings.benefit_title }}</span>
              </p>
            </div>
          {% endif %}
          <ul class="block__book-sleep-study-benefit-list"> 
            {% for i in (1..5) %}
              {% capture text %}text{{i}}{% endcapture %}
              {% assign text = block.settings[text] %}
              {% if text != blank %}
                <li>
                  {% render 'icon-verified' -%}
                  <span class="medium_body">{{ text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
          {% if block.settings.btn != blank %}
            <a href="{{ block.settings.url }}" target="_blank" class="{%- if block.settings.tag != blank -%}button-quaternary{% else %}button-primary{% endif %} medium_body">{{ block.settings.btn }}</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Book Sleep Study",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "sleep-study",
      "name": "Sleep Study Experience",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "benefit_title",
          "label": "Benefit Title",
          "default": "What You Will Get"
        },
        {
          "type": "header",
          "content": "Benefit Bullet point Text"
        },
        {
          "type": "text",
          "id": "text1",
          "label": "Benefit Text 1"
        },
        {
          "type": "text",
          "id": "text2",
          "label": "Benefit Text 2"
        },
        {
          "type": "text",
          "id": "text3",
          "label": "Benefit Text 3"
        },
        {
          "type": "text",
          "id": "text4",
          "label": "Benefit Text 4"
        },
        {
          "type": "text",
          "id": "text5",
          "label": "Benefit Text 5"
        },
        {
          "type": "text",
          "id": "btn",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Book Sleep Study"
    }
  ]
}
{% endschema %}
