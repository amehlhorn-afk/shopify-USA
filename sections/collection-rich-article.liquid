{% javascript %}
/* Smooth expand/collapse + section-level options for FAQ; supports FAQ groups AND section wrapper */
(function () {
  try {
    /* Scope to THIS section instance */
    var root = document.getElementById('collection-rich-article-{{ section.id }}');
    if (!root) return;

    var faqs = Array.prototype.slice.call(root.querySelectorAll('.crab-faq'));
    var startCollapsed = root.dataset.startCollapsed === "true";
    var accordion = root.dataset.accordion === "true";

    function setHeight(det, open) {
      var wrap = det.querySelector('.faq-a-wrap');
      var summary = det.querySelector('summary.faq-q');
      if (!wrap || !summary) return;
      wrap.style.maxHeight = open ? wrap.scrollHeight + 'px' : '0px';
      summary.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    function closeOthers(current) {
      var group = current.closest('.crab-faq-group') || root;
      Array.prototype.slice.call(group.querySelectorAll('.crab-faq')).forEach(function (det) {
        if (det !== current && det.open) {
          det.open = false;
          setHeight(det, false);
        }
      });
    }

    /* Initialize FAQs */
    faqs.forEach(function (det) {
      if (startCollapsed) det.open = false;
      setHeight(det, det.open);
      det.addEventListener('toggle', function () {
        setHeight(det, det.open);
        if (accordion && det.open) closeOthers(det);
      });
    });

    /* Keep FAQ heights accurate */
    if ('ResizeObserver' in window) {
      var ro = new ResizeObserver(function () {
        faqs.forEach(function (det) { if (det.open) setHeight(det, true); });
      });
      faqs.forEach(function (det) {
        var wrap = det.querySelector('.faq-a-wrap');
        if (wrap) ro.observe(wrap);
      });
    } else {
      window.addEventListener('resize', function () {
        faqs.forEach(function (det) { if (det.open) setHeight(det, true); });
      });
    }

    /* Section-level collapsible */
    var sectionIsCollapsible = root.dataset.sectionCollapsible === "true";
    if (sectionIsCollapsible) {
      var sectionDetails = root.querySelector('.crab-section-collapsible');
      var sectionBody = sectionDetails && sectionDetails.querySelector('.crab-collapsible-body');
      var sectionSummary = sectionDetails && sectionDetails.querySelector('.crab-section-summary');

      function setSectionHeight(open) {
        if (!sectionBody) return;
        sectionBody.style.maxHeight = open ? sectionBody.scrollHeight + 'px' : '0px';
        if (sectionSummary) sectionSummary.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      if (sectionDetails) {
        var startCollapsedSection = root.dataset.sectionStartCollapsed === "true";
        if (startCollapsedSection) sectionDetails.open = false;

        /* Initial measurement */
        setSectionHeight(sectionDetails.open);

        /* Recalc on toggle (+ microtask for late layout) */
        sectionDetails.addEventListener('toggle', function () {
          setSectionHeight(sectionDetails.open);
          if (sectionDetails.open) requestAnimationFrame(function(){ setSectionHeight(true); });
        });

        /* Recalc on size/content changes */
        if ('ResizeObserver' in window) {
          var ro2 = new ResizeObserver(function () {
            if (sectionDetails.open) setSectionHeight(true);
          });
          if (sectionBody) ro2.observe(sectionBody);
        } else {
          window.addEventListener('resize', function () {
            if (sectionDetails.open) setSectionHeight(true);
          });
        }

        /* Re-measure when images finish loading inside the body */
        if (sectionBody) {
          sectionBody.querySelectorAll('img').forEach(function(img){
            if (img.complete) return;
            img.addEventListener('load', function(){
              if (sectionDetails.open) setSectionHeight(true);
            });
          });
        }
      }
    }
  } catch (e) {}
})();
{% endjavascript %}
