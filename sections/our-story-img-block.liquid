{{ 'our-story-img-block.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} our-story-img-block">
  <div class="page-width">
    <div class="block__our-story-img-row">
      {% for block in section.blocks %}
        <div class="block__our-story-img-wrapper">
          {% if block.settings.img != blank %}
            <div class="block__our-story-image">
              {% if block.settings.url != blank %}
                <a href="{{ block.settings.url }}" class="block__our-story-image-url">
                {% render 'custom-image', image: block.settings.img, class: 'img-fluid' %}
                </a>
              {% endif %}
              
            </div>
          {% endif %}
          <div class="block__our-story-img-content">
            {% if block.settings.title != blank %}
              <h4 class="block__our-story-image-title primary_h4">{{ block.settings.title }}</h4>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="block__our-story-image-text small_body">{{ block.settings.text }}</p>
            {% endif %}
            {% if block.settings.btn_text != blank %}
              <a href="{{ block.settings.url }}" class="block__our-story-image-btn">
                {{ block.settings.btn_text }}
                {% render 'right-arrow' %}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Story Image Block",
  "settings": [
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "story_block",
      "name": "Story Iamge Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Caption"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story Image Block"
    }
  ]
}
{% endschema %}
