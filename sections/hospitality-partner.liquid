{{ 'section-hospitality-partner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 992px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
   {% if section.settings.text_color != blank %}
    .block__hospitality-partner-info h2,
    .block__hospitality-partner-info p,.block__hospitality-partner-info p a{color:{{ section.settings.text_color }};}
  {% endif %}
{% endstyle %}

<div class="section-{{ section.id }} section-hospitality-partner">
  <div class="page-width">
    <div
      class="block__hospitality-partner-row"
      {% if section.settings.bg_color != blank %}
        style="background-color: {{ section.settings.bg_color }};"
      {% endif %}
    > {% if section.settings.overlay != blank%}
          <span class="w-full h-full block absolute block__overlay_opacity inset-0 quaternary-border-radius z-index-0"
                style="background-color: {{ section.settings.overly_color }}; opacity:{{ section.settings.overlay_opacity }}%;">
          </span>
        {% endif %}
      <div class="block__hospitality-partner-info z-index-1">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body block__hospitality-partner-caption">{{ section.settings.caption }}</p>
        {% endif %}
        {% if section.settings.btn != blank %}
          <a href="{{ section.settings.url }}" target="_blank" class="button-primary senary-border-radius h6">{{ section.settings.btn }}</a>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="body block__hospitality-partner-text">{{ section.settings.text }}</p>
        {% endif %}
      </div>
      {% if section.settings.img != blank %}
        <div class="block__hospitality-partner-img">
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid object-cover' %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hospitality Partner",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay"
    },
    {
      "type": "color",
      "id": "overly_color",
      "label": "Overlay Background Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "unit": "%",
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Image"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Hospitality Partner"
    }
  ]
}
{% endschema %}
