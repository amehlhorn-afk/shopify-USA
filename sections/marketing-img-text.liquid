{{ 'section-marketing-img-text.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-marketing-img-text">
  <div class="page-width">
    <div class="block__marketing-img-text-row">
      <div class="block__marketing-text-wrapper">
        {% if section.settings.title != blank %}
          <h3 class="block__marketing-text-title">{{ section.settings.title }}</h3>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body block__marketing-text-caption">{{ section.settings.caption }}</p>
        {% endif %}
        <div class="block__marketing-benefit">
          {% if section.settings.benefit_title != blank %}
            <h5>{{ section.settings.benefit_title }}</h5>
          {% endif %}
          <div class="block__marketing-benefit-row">
            {% for block in section.blocks %}
              {% assign benefit_icon = block.settings.benefit_icon %}
              {% assign benefit_title = block.settings.benefit_title %}
              {% assign benefit_text = block.settings.benefit_text %}
              {% assign benefit_text_color = block.settings.color %}
              <div class="block__marketing-benefit-item">
                <div class="block__marketing-benefit-icon">
                  {% if benefit_icon != blank %}
                    <img loading="lazy"
                      src="{{ benefit_icon | image_url: width:benefit_icon.width }}"
                      alt="{{ benefit_icon.alt | default: shop.name}}"
                      width=""
                      height=""
                    >
                  {% endif %}
                </div>
                <div class="block__marketing-benefit-info">
                  {% if benefit_title != blank %}
                    <h4 style="color: {{ benefit_text_color }};">{{ benefit_title }}</h4>
                  {% endif %}
                  {% if benefit_text != blank %}
                    <p style="color: {{ benefit_text_color }};">{{ benefit_text }}</p>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        {% if section.settings.text != blank %}
          <div class="block__marketing-benefit-text">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>
      {% if section.settings.img != blank %}
        <div class="block__marketing-image-wrapper">
          {% if section.settings.img_mobile != blank %}
            {% assign img_mobile = section.settings.img_mobile %} 
            {% else %}
            {% assign img_mobile = section.settings.img %} 
          {% endif %}
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid desktop-img' %}
          {% render 'custom-image', image: img_mobile, class: 'img-fluid mobile-img' %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Marketing Img Text",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Image(Desktop)"
    },
    {
      "type": "image_picker",
      "id": "img_mobile",
      "label": "Select Image(Mobile)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "benefit_title",
      "label": "Benefit Title",
      "default": "Benefits and features"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "info": "For heading use H6 tag"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Benefit",
      "settings": [
        {
          "type": "color",
          "id": "color",
          "label": "Text Color"
        },
        {
          "type": "image_picker",
          "id": "benefit_icon",
          "label": "Select Image"
        },
        {
          "type": "text",
          "id": "benefit_title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "benefit_text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marketing Img Text"
    }
  ]
}
{% endschema %}
