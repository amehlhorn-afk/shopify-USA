{{ 'sale-countdown.css' | asset_url | stylesheet_tag }}

{% style %}
  @media (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.desktop_padding_top }}px;
      padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    }
  }
  @media (max-width: 989px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
  
  .block__sale-countdown-left-inner {
    text-align: center;
  }
  
  .block__sale-countdown-left-inner p {
    padding-top: 0rem;
  }
  
  .block__sale-countdown-left-inner a {
    display: block;
    width: fit-content;
    margin: 1.5em auto;
    background-color: white;
    color: #AB2144;
    text-decoration: none;
    padding: 8px 24px;
    border-radius: 24px;
    font-weight: 500;
    font-size: 14px;
    transition: all 0.3s ease;
  }
  
  .block__sale-countdown-left-inner a:hover {
    background-color: #f0f0f0;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  
  .block__sale-countdown-left-inner h3::after {
    content: "20% OFF ALL BEAUTY";
    display: block;
    font-weight: 900;
    text-align: center;
    font-size: 32px;
    line-height: 1em !important;
    margin: 5px auto;
  }
  
  .block__sale-countdown-center-inner.relative {
    width: 40%;
    max-width: 600px;
  }
  
  @media only screen and (min-width: 750px) {
    .block__sale-countdown-left-inner h3 {
      font-size: 22px;
    }
  }
  
  @media screen and (min-width: 1200px) {
    .block__sale-countdown-wrapper {
      padding: 2em 4em 2em 5em;
    }
  }
  
  @media screen and (max-width: 990px) {
    .block__sale-countdown-left-inner h3 {
      font-size: 20px;
    }
    
    .block__sale-countdown-left-inner {
      margin: 0 auto;
    }
    
    .block__sale-countdown-wrapper div {
      max-width: 100%;
    }
    
    .block__sale-countdown-center-inner {
      top: unset;
      margin: 0 auto;
    }
    
    .block__sale-image.absolute {
      transform: none;
      position: relative;
    }
    
    .block__sale-countdown-right-inner {
      margin: 0 auto;
    }
  }
{% endstyle %}

<div class="section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="block__sale-countdown-main color-{{ section.settings.section_color_scheme }}">
      <div class="block__sale-countdown-wrapper flex items-center justify-between relative">
        <div class="block__sale-countdown-left-inner">
          {% if section.settings.sale_title != blank %}
            <h3>{{ section.settings.sale_title }}</h3>
          {% endif %}
          {% if section.settings.sale_subtitle != blank %}
            <p>
              {{ section.settings.sale_subtitle }}
              {% if section.settings.description_link_text != blank and section.settings.description_link_url != blank %}
                <a href="{{ section.settings.description_link_url }}">{{ section.settings.description_link_text }}</a>
              {% endif %}
            </p>
          {% endif %}
        </div>
        {% if section.settings.center_image != blank %}
          <div class="block__sale-countdown-center-inner relative">
            <div class="block__sale-image absolute">
              {% render 'custom-image', image: section.settings.center_image, class: 'object-cover block h-full w-full' %}
            </div>
          </div>
        {% endif %}
        <div
          class="block__sale-countdown-right-inner"
          {% if section.settings.enable_timer_countdown and section.settings.add_date != blank %}
            data-date="{{ section.settings.add_date }}"
          {% endif %}
        >
          {% if section.settings.enable_timer_countdown and section.settings.add_date != blank %}
            {% render 'countdown-timer' %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
{% if section.settings.enable_timer_countdown and section.settings.add_date != blank %}
  <script src="{{ 'countdown.js'  |  asset_url }}" defer="defer"></script>
{% endif %}

{% schema %}
{
  "name": "Sale Countdown",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Countdown Timer"
    },
    {
      "type": "checkbox",
      "id": "enable_timer_countdown",
      "default": false,
      "label": "Enable Timer countdown"
    },
    {
      "type": "text",
      "id": "add_date",
      "info": "Format: March 25, 1952 || 25 March, 1952",
      "label": "Add Upcoming date"
    },
    {
      "type": "text",
      "id": "sale_title",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "sale_subtitle",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "description_link_text",
      "label": "Description Link Text",
      "info": "Optional link text to add after description"
    },
    {
      "type": "url",
      "id": "description_link_url",
      "label": "Description Link URL"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Sale Countdown",
      "settings": {}
    }
  ]
}
{% endschema %}