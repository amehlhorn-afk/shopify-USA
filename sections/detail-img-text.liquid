{{ 'section-detail-img-text.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-detail-img-text">
  <div class="page-width">
    {% assign page_value = page.metafields.custom.technology_detail.value %}
    <div class="block__detail-img-text-row">
      {% if page_value.features_info_image != blank %}
        <div class="block__detail-img-wrapper">
          {% render 'custom-image', image: page_value.features_info_image, class: 'img-fluid object-cover' %}
        </div>
      {% endif %}
      <div class="block__detail-text-wrapper">
        {% if page_value.features_info_title != blank %}
          <h2 class="primary_h2">{{ page_value.features_info_title }}</h2>
        {% endif %}
        {% if page_value.features_info_caption != blank %}
          <p class="body">{{ page_value.features_info_caption }}</p>
        {% endif %}
        <div class="block__detail-features-text">
          {% if section.settings.heading != blank %}
            <h5>{{ section.settings.heading }}</h5>
          {% endif %}
          <ul class="block__detail-features-text-list">
            {% for i in (1..3) %}
              {% capture icon %}icon{{i}}{% endcapture %}
              {% capture text %}text{{i}}{% endcapture %}
              {% assign icon = page_value[icon] %}
              {% assign text = page_value[text] %}
              {% if icon != blank or text != blank %}
                <li>
                  <img
                    src="{{ icon |  image_url: width:icon.width }}"
                    alt="{{ icon.alt | default: text}}"
                    width=""
                    height=""
                    loading="lazy"
                  >
                  <span class="body">{{ text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Detail Img With Text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Useful Features"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Detail Img With Text"
    }
  ]
}
{% endschema %}
