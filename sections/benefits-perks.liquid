{{ 'section-benefits-perks.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-benefits-perks">
  <div class="page-width">
    <div class="block__benefits-perks-header">
      {% if section.settings.title != blank %}
        <h2 class="primary_h2">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.caption != blank %}
        <p class="body">{{ section.settings.caption }}</p>
      {% endif %}
    </div>
    <div class="block__benefits-perks-grid">
      {% for block in section.blocks %}
        <div class="block__benefits-perks-item">
          {% if block.settings.img != blank %}
            <div class="block__benefits-perks-icon">
              {% render 'custom-image', image: block.settings.img, class: 'img-fluid object-cover' %}
            </div>
          {% endif %}
          <div class="block__benefits-perks-info">
            {% if block.settings.title != blank %}
              <h6>{{ block.settings.title }}</h6>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="body">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="block__benefits-perks-bottom">
      {% if section.settings.heading != blank %}
        <h4>{{ section.settings.heading }}</h4>
      {% endif %}
      {% if section.settings.btn != blank %}
        <a href="{{ section.settings.url }}" target="_blank" class="button-quaternary">{{ section.settings.btn }}</a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Benefits Perks",
  "settings": [
    {
      "type": "header",
      "content": "Section Top Text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Bottom Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "Benefits-icon-text",
      "name": "Benefits Icon With Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Perks"
    }
  ]
}
{% endschema %}
