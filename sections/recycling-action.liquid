{{ 'section-recycling-action.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-recycling-action">
  <div class="page-width">
    {% if section.settings.title != blank and section.settings.caption != blank %}
      <div class="block__recycling-action-header">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body">{{ section.settings.caption }}</p>
        {% endif %}
      </div>
    {% endif %}
    <div class="block__recycling-action-grid">
      {% for block in section.blocks %}
        <div class="block__recycling-action-item">
          {% if block.settings.title != blank %}
            <h2 class="h1">{{ block.settings.title }}</h2>
          {% endif %}
          {% if block.settings.text != blank %}
            <span class="body">
              {%- render 'up-arrow-icon' -%}
              {{- block.settings.text -}}
            </span>
          {% endif %}
          {% if block.settings.caption != blank %}
            <p>{{ block.settings.caption }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Recycling Action",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "recycling_action",
      "name": "Recycling Action",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Recycling Action"
    }
  ]
}
{% endschema %}
