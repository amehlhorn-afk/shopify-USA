{{ 'section-our-gallery.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-our-gallery">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <h2 class="primary_h2 block__our-gallery-title">{{ section.settings.title }}</h2>
    {% endif %}
    <div class="block__our-gallery-row">
      {% for block in section.blocks %}
        {% if block.settings.img != blank %}
          <div class=" block__our-gallery-img_{{ forloop.index }} ">
            <a href="{{ block.settings.url }}" class="block__our-gallery-img block">
            {% render 'custom-image', image: block.settings.img, class: 'img-fluid object-cover' %}
            </a>
          </div>
        {% endif %}
      {% endfor %} 
    </div>
    <div class="block__our-gallery-btn">
      <a href="{{ section.settings.url }}" target="_blank" class="button-quaternary small_body">{{ section.settings.btn }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Gallery Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "gallery_grid",
      "name": "Gallery Grid",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select Image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Image URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery Grid"
    }
  ]
}
{% endschema %}
