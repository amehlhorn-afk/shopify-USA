{% liquid
  assign bg = section.settings.background_color
  assign card_bg = section.settings.card_background_color
  assign max_w = section.settings.max_width
  assign pad_y = section.settings.padding_y
  assign pad_x = section.settings.padding_x
  assign gap = section.settings.gap
  assign radius = section.settings.card_radius
  assign shadow = section.settings.card_shadow
  assign h_size = section.settings.heading_size
  assign desc_size = section.settings.description_size
  assign img_radius = section.settings.image_radius
  assign columns_desktop = section.settings.columns_desktop

  assign section_h_size = section.settings.section_heading_size
  assign section_desc_size = section.settings.section_description_size
  assign header_align = section.settings.header_alignment
%}

<section
  class="cg"
  style="
    --cg-bg: {{ bg }};
    --cg-card-bg: {{ card_bg }};
    --cg-max: {{ max_w }}px;
    --cg-pad-y: {{ pad_y }}px;
    --cg-pad-x: {{ pad_x }}px;
    --cg-gap: {{ gap }}px;
    --cg-radius: {{ radius }}px;
    --cg-shadow: {{ shadow }};
    --cg-h-size: {{ h_size }}px;
    --cg-desc-size: {{ desc_size }}px;
    --cg-img-radius: {{ img_radius }}px;
    --cg-cols: {{ columns_desktop }};
    --cg-sec-h-size: {{ section_h_size }}px;
    --cg-sec-desc-size: {{ section_desc_size }}px;
  "
>
  <div class="cg__wrap">

    {% if section.settings.section_heading != blank or section.settings.section_description != blank %}
      <header class="cg__header cg__header--{{ header_align }}">
        {% if section.settings.section_heading != blank %}
          <h2 class="cg__section-heading">{{ section.settings.section_heading }}</h2>
        {% endif %}

        {% if section.settings.section_description != blank %}
          <div class="cg__section-desc rte">
            {{ section.settings.section_description }}
          </div>
        {% endif %}
      </header>
    {% endif %}

    <div class="cg__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'card' %}
            <article class="cg__card cg__card--img-{{ block.settings.image_position }}" {{ block.shopify_attributes }}>
              
              {% if block.settings.image != blank and block.settings.image_position == 'top' %}
                {% assign aspect = block.settings.image_aspect %}
                <div class="cg__media" style="--cg-aspect: {{ aspect }};">
                  {{
                    block.settings.image
                    | image_url: width: 1600
                    | image_tag:
                      loading: 'lazy',
                      class: 'cg__img',
                      widths: '400, 600, 800, 1000, 1200, 1600',
                      sizes: '(min-width: 990px) calc((var(--cg-max) - (var(--cg-gap) * (var(--cg-cols) - 1))) / var(--cg-cols)), 100vw'
                  }}
                </div>
              {% endif %}

              <div class="cg__content">
                {% if block.settings.heading != blank %}
                  <h3 class="cg__heading">{{ block.settings.heading }}</h3>
                {% endif %}

                {% if block.settings.description != blank %}
                  <div class="cg__desc rte">
                    {{ block.settings.description }}
                  </div>
                {% endif %}

                {% if block.settings.cta_text != blank %}
                  <div class="cg__cta-wrap">
                    <a href="{{ block.settings.cta_link }}" class="cg__cta">
                      {{ block.settings.cta_text }}
                    </a>
                  </div>
                {% endif %}
              </div>

              {% if block.settings.image != blank and block.settings.image_position == 'bottom' %}
                {% assign aspect = block.settings.image_aspect %}
                <div class="cg__media" style="--cg-aspect: {{ aspect }};">
                  {{
                    block.settings.image
                    | image_url: width: 1600
                    | image_tag:
                      loading: 'lazy',
                      class: 'cg__img',
                      widths: '400, 600, 800, 1000, 1200, 1600',
                      sizes: '(min-width: 990px) calc((var(--cg-max) - (var(--cg-gap) * (var(--cg-cols) - 1))) / var(--cg-cols)), 100vw'
                  }}
                </div>
              {% endif %}
            </article>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .cg {
    background: var(--cg-bg);
    padding: var(--cg-pad-y) var(--cg-pad-x);
  }

  .cg__wrap {
    max-width: var(--cg-max);
    margin: 0 auto;
  }

  .cg__header {
    margin: 0 0 22px 0;
    max-width: 900px;
  }

  /* Alignment controls */
  .cg__header--left { text-align: left; margin-right: auto; margin-left: 0; }
  .cg__header--center { text-align: center; margin-left: auto; margin-right: auto; }
  .cg__header--right { text-align: right; margin-left: auto; margin-right: 0; }

  .cg__section-heading {
    margin: 0 0 10px 0;
    font-size: var(--cg-sec-h-size);
    line-height: 1.15;
    font-weight: 750;
    letter-spacing: -0.02em;
  }

  .cg__section-desc {
    font-size: var(--cg-sec-desc-size);
    line-height: 1.6;
    color: rgba(0,0,0,0.7);
  }

  .cg__grid {
    display: grid;
    grid-template-columns: repeat(var(--cg-cols), minmax(0, 1fr));
    gap: var(--cg-gap);
  }

  .cg__card {
    background: var(--cg-card-bg);
    border-radius: var(--cg-radius);
    box-shadow: var(--cg-shadow);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .cg__content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cg__heading {
    margin: 0;
    font-size: var(--cg-h-size);
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .cg__desc {
    font-size: var(--cg-desc-size);
    line-height: 1.55;
    color: rgba(0,0,0,0.7);
    margin: 0;
  }

  .cg__cta-wrap {
    margin-top: 8px;
  }

  .cg__cta {
    display: inline-block;
    padding: 12px 28px;
    background: #00B5E3;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .cg__cta:hover {
    background: #0099C7;
    transform: translateY(-1px);
  }

  .cg__media {
    width: 100%;
    border-radius: var(--cg-img-radius);
    overflow: hidden;
    aspect-ratio: var(--cg-aspect);
    background: rgba(0,0,0,0.04);
  }

  .cg__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 989px) {
    .cg__grid { grid-template-columns: 1fr; }
    .cg__card { padding: 22px; }
    .cg__header { margin-bottom: 18px; }
  }
</style>

{% schema %}
{
  "name": "Card Grid (Manual Blocks)",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Section heading"
    },
    {
      "type": "richtext",
      "id": "section_description",
      "label": "Section description",
      "default": "<p>Section description</p>"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Heading/description alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "section_heading_size",
      "label": "Section heading size (px)",
      "min": 18,
      "max": 64,
      "step": 1,
      "default": 34
    },
    {
      "type": "range",
      "id": "section_description_size",
      "label": "Section description size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },

    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Card heading size (px)",
      "min": 16,
      "max": 48,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Card description size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 14
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#F3F4F6"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 900,
      "max": 1800,
      "step": 20,
      "default": 1520
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Card gap (px)",
      "min": 8,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius (px)",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius (px)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "text",
      "id": "card_shadow",
      "label": "Card shadow (CSS box-shadow)",
      "default": "0 10px 30px rgba(0,0,0,0.06)"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "People First"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Our people are our greatest asset. As a BEDGEAR employee, we invest in your personal and professional growth, and we embrace your unique perspectives, experiences, and background.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position",
          "default": "bottom",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "type": "select",
          "id": "image_aspect",
          "label": "Image aspect ratio",
          "default": "16 / 9",
          "options": [
            { "value": "16 / 9", "label": "16:9" },
            { "value": "4 / 3", "label": "4:3" },
            { "value": "1 / 1", "label": "1:1" },
            { "value": "21 / 9", "label": "21:9" }
          ]
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Card Grid (Manual Blocks)",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}