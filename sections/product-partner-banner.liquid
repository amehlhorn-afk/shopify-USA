{%- comment -%}
  Partnership / Athlete Banner — Dallas Mavericks
  Blocks: up to 4 athlete blocks. When group_image is set, renders split layout (group + 1 card).
  Quote renders BELOW the image card, not overlaid on it.
{%- endcomment -%}

{%- assign athlete_blocks = section.blocks | where: 'type', 'athlete' -%}
{%- assign has_group = false -%}
{%- if section.settings.group_image != blank -%}
  {%- assign has_group = true -%}
{%- endif -%}

<section class="partner-banner" id="PartnerBanner-{{ section.id }}">

  {%- comment -%} ── Header ── {%- endcomment -%}
  <div class="partner-banner__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="partner-banner__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="partner-banner__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="partner-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── Athlete grid ── {%- endcomment -%}
  {%- if athlete_blocks.size > 0 or has_group -%}
  <div class="partner-banner__athletes{% if has_group %} partner-banner__athletes--split{% endif %}">

    {%- assign first_block = athlete_blocks | first -%}

    {%- if has_group -%}

      {%- comment -%} Group image — LEFT (3/4) {%- endcomment -%}
      <div class="partner-banner__group-media">
        {{ section.settings.group_image | image_url: width: 1400
          | image_tag: loading: 'lazy', widths: '700,1000,1400', sizes: '(min-width:990px) 75vw, 100vw', class: 'partner-banner__group-img' }}
      </div>

      {%- comment -%} Athlete card — RIGHT (1/4) {%- endcomment -%}
      {%- if first_block != blank -%}
      <div class="partner-banner__card-wrap" {{ first_block.shopify_attributes }}>
        <div class="partner-banner__card">
          {%- if first_block.settings.image != blank -%}
            <div class="partner-banner__card-media">
              {{ first_block.settings.image | image_url: width: 600
                | image_tag: loading: 'lazy', widths: '300,400,600', sizes: '(min-width:990px) 25vw, 50vw', class: 'partner-banner__card-img' }}
            </div>
          {%- endif -%}
          <div class="partner-banner__card-overlay">
            <div class="partner-banner__card-info">
              {%- if first_block.settings.name != blank -%}
                <p class="partner-banner__card-name">{{ first_block.settings.name }}</p>
              {%- endif -%}
              {%- if first_block.settings.position != blank -%}
                <p class="partner-banner__card-position">{{ first_block.settings.position }}</p>
              {%- endif -%}
              {%- if first_block.settings.product_name != blank -%}
                <span class="partner-banner__card-product">{{ first_block.settings.product_name }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
        {%- if first_block.settings.quote != blank -%}
          <blockquote class="partner-banner__card-quote">&ldquo;{{ first_block.settings.quote }}&rdquo;</blockquote>
        {%- endif -%}
      </div>
      {%- endif -%}

    {%- else -%}

      {%- comment -%} No group image — all athlete blocks {%- endcomment -%}
      {%- for block in athlete_blocks -%}
      <div class="partner-banner__card-wrap" {{ block.shopify_attributes }}>
        <div class="partner-banner__card">
          {%- if block.settings.image != blank -%}
            <div class="partner-banner__card-media">
              {{ block.settings.image | image_url: width: 600
                | image_tag: loading: 'lazy', widths: '300,400,600', sizes: '(min-width:990px) 25vw, 50vw', class: 'partner-banner__card-img' }}
            </div>
          {%- endif -%}
          <div class="partner-banner__card-overlay">
            <div class="partner-banner__card-info">
              {%- if block.settings.name != blank -%}
                <p class="partner-banner__card-name">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.position != blank -%}
                <p class="partner-banner__card-position">{{ block.settings.position }}</p>
              {%- endif -%}
              {%- if block.settings.product_name != blank -%}
                <span class="partner-banner__card-product">{{ block.settings.product_name }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
        {%- if block.settings.quote != blank -%}
          <blockquote class="partner-banner__card-quote">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
        {%- endif -%}
      </div>
      {%- endfor -%}

    {%- endif -%}

  </div>
  {%- endif -%}

  {%- comment -%} ── Footer: logo lockup + stats ── {%- endcomment -%}
  <div class="partner-banner__footer">

    {%- if section.settings.logo_lockup != blank -%}
    <div class="partner-banner__logos">
      {{ section.settings.logo_lockup | image_url: width: 500
        | image_tag: loading: 'lazy', class: 'partner-banner__lockup-logo', alt: 'BEDGEAR — Official Sleep Partner of the Dallas Mavericks' }}
    </div>
    {%- endif -%}

    <div class="partner-banner__stats">
      {%- for i in (1..3) -%}
        {%- liquid
          assign val_key   = 'stat_' | append: i | append: '_value'
          assign label_key = 'stat_' | append: i | append: '_label'
          assign icon_key  = 'stat_' | append: i | append: '_icon'
          assign val       = section.settings[val_key]
          assign label     = section.settings[label_key]
          assign icon      = section.settings[icon_key]
        -%}
        {%- if val != blank or label != blank -%}
          <div class="partner-banner__stat">
            {%- if icon == 'shield' -%}
              <span class="partner-banner__stat-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </span>
            {%- endif -%}
            {%- if val != blank -%}<span class="partner-banner__stat-value">{{ val }}</span>{%- endif -%}
            {%- if label != blank -%}<span class="partner-banner__stat-label">{{ label }}</span>{%- endif -%}
          </div>
          {%- unless forloop.last -%}
            <div class="partner-banner__stat-divider" aria-hidden="true"></div>
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

</section>

{% style %}
  .partner-banner {
    background: #0a1628;
    width: 100%;
  }

  /* ── Header ── */
  .partner-banner__header {
    text-align: center;
    padding: 56px 24px 32px;
  }

  .partner-banner__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #00b5e3;
    margin: 0 0 14px;
  }

  .partner-banner__heading {
    font-family: 'din-condensed', 'DIN Condensed', 'DINCondensed-Bold', 'Arial Narrow', sans-serif;
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0;
    line-height: 1.0;
    color: #fff;
    margin: 0 0 16px;
  }

  .partner-banner__subheading {
    font-size: clamp(14px, 1.6vw, 20px);
    font-style: italic;
    font-weight: 400;
    color: #00b5e3;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Athlete grid — inset with gap ── */
  .partner-banner__athletes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    padding: 0 32px 32px;
    box-sizing: border-box;
    align-items: start;
  }

  .partner-banner__athletes--split {
    grid-template-columns: 3fr 1fr;
  }

  /* ── Card wrapper: image on top, quote below ── */
  .partner-banner__card-wrap {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Image card ── */
  .partner-banner__card {
    position: relative;
    overflow: hidden;
    height: 250px;
    border-radius: 10px;
    background: #0d1e38;
  }

  .partner-banner__card-media {
    position: absolute;
    inset: 0;
  }

  .partner-banner__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .partner-banner__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0) 25%,
      rgba(0,0,0,0.6) 65%,
      rgba(0,0,0,0.92) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px 16px;
  }

  .partner-banner__card-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .partner-banner__card-name {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    margin: 0;
    line-height: 1.2;
  }

  .partner-banner__card-position {
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    margin: 0;
    line-height: 1.3;
  }

  .partner-banner__card-product {
    display: inline-block;
    margin-top: 8px;
    padding: 4px 10px;
    background: #00b5e3;
    color: #0a1628;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 2px;
    line-height: 1.3;
    align-self: flex-start;
  }

  /* ── Quote — below the image card ── */
  .partner-banner__card-quote {
    font-size: 12px;
    font-style: italic;
    color: rgba(255,255,255,0.75);
    line-height: 1.5;
    margin: 0;
    padding: 0;
  }

  /* ── Group image ── */
  .partner-banner__group-media {
    overflow: hidden;
    border-radius: 10px;
    background: #0d1e38;
    line-height: 0;
    height: 250px;
  }

  .partner-banner__group-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Footer ── */
  .partner-banner__footer {
    padding: 40px 24px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 8px;
  }

  .partner-banner__logos {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .partner-banner__lockup-logo {
    height: 192px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* ── Stats ── */
  .partner-banner__stats {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .partner-banner__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 0 40px;
    text-align: center;
  }

  .partner-banner__stat-icon {
    color: #00b5e3;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2px;
  }

  .partner-banner__stat-value {
    font-size: 22px;
    font-weight: 800;
    color: #00b5e3;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .partner-banner__stat-label {
    font-size: 11px;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
    max-width: 120px;
  }

  .partner-banner__stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .partner-banner__header { padding: 40px 20px 24px; }

    .partner-banner__athletes {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 0 16px 16px;
    }

    .partner-banner__athletes--split {
      grid-template-columns: 1fr;
    }

    .partner-banner__lockup-logo { height: 120px; }
    .partner-banner__footer { padding: 32px 20px 40px; gap: 24px; }
    .partner-banner__stat { padding: 0 16px; }
    .partner-banner__stat-value { font-size: 18px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Partner Banner",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Official Sleep Partner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted at the Highest Level"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Dallas Mavericks sleep on BEDGEAR."
    },
    {
      "type": "header",
      "content": "Group Image (split layout)"
    },
    {
      "type": "image_picker",
      "id": "group_image",
      "label": "Group photo — when set, shows group image left + 1 athlete card right"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_lockup",
      "label": "Logo lockup (combined BEDGEAR + partner)"
    },
    {
      "type": "header",
      "content": "Stat 1"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Value",
      "default": "8+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Label",
      "default": "Seasons as official sleep partner"
    },
    {
      "type": "select",
      "id": "stat_1_icon",
      "label": "Icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Stat 2"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Value",
      "default": "365-Night Trial"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Label",
      "default": "To love your pillow"
    },
    {
      "type": "select",
      "id": "stat_2_icon",
      "label": "Icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": "shield"
    },
    {
      "type": "header",
      "content": "Stat 3"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Value",
      "default": "1-Year Warranty"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Label",
      "default": "So you can rest easy"
    },
    {
      "type": "select",
      "id": "stat_3_icon",
      "label": "Icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": "shield"
    }
  ],
  "blocks": [
    {
      "type": "athlete",
      "name": "Athlete",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Athlete photo"
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Quote (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Player Name"
        },
        {
          "type": "text",
          "id": "position",
          "label": "Position & Team",
          "default": "Position · Team"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product pill"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Partner Banner",
      "blocks": [
        { "type": "athlete" },
        { "type": "athlete" },
        { "type": "athlete" },
        { "type": "athlete" }
      ]
    }
  ]
}
{% endschema %}
