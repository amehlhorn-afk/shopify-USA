{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}
{{ 'blog-banner-sec.css' | asset_url | stylesheet_tag }}

<div class="block__blog-banner-main section-{{ section.id }}-padding" 
    {% if section.settings.bg_color != blank %}
        style="background-color: {{ section.settings.bg_color }};"
    {% elsif section.settings.bg_image != blank %}
        style="background-image: url({{ section.settings.bg_image | image_url }}); background-size: cover; background-position: center;"
    {% endif %}>
    <div class="page-width">
        <div class="block__blog-articles block__row gap-30 items-center ">
             {% assign article = section.settings.selected_article %}
             {%- if section.settings.show_image  and article.image -%}
                <div class="article-card__image-wrapper relative">
                  <a href="{{ article.url }}" class="inline-block">
                    <div
                        class="article-card__image Zoomhover media media--hover-effect tertiary-border-radius relative"
                        {% if section.settings.media_height == 'adapt' %}
                        style="padding-bottom: {{ 1 | divided_by: article.image.aspect_ratio | times: 100 }}%;"
                        {% endif %}
                    >
                        <img
                        srcset="
                            {%- if article.image.src.width >= 165 -%}{{ article.image.src | image_url: width: 165 }} 165w,{%- endif -%}
                            {%- if article.image.src.width >= 360 -%}{{ article.image.src | image_url: width: 360 }} 360w,{%- endif -%}
                            {%- if article.image.src.width >= 533 -%}{{ article.image.src | image_url: width: 533 }} 533w,{%- endif -%}
                            {%- if article.image.src.width >= 720 -%}{{ article.image.src | image_url: width: 720 }} 720w,{%- endif -%}
                            {%- if article.image.src.width >= 1000 -%}{{ article.image.src | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {%- if article.image.src.width >= 1500 -%}{{ article.image.src | image_url: width: 1500 }} 1500w,{%- endif -%}
                            {{ article.image.src | image_url }} {{ article.image.src.width }}w
                        "
                        src="{{ article.image.src | image_url: width: 533 }}"
                        sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
                        alt="{{ article.image.src.alt | escape }}"
                        class="motion-reduce tertiary-border-radius"
                        {% unless lazy_load == false %}
                            loading="lazy"
                        {% endunless %}
                        width="{{ article.image.width }}"
                        height="{{ article.image.height }}"
                        >
                        {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
                        
                    </div>
                  </a>
                  {%  for tag  in article.tags limit: 1 %} 
                        <label class="absolute extreme_small_body secondary-border-radius inline-block center text-capitalize">{{tag}}</label>
                    {% endfor %} 
                </div>
              {%- endif -%}

              <div class="block__card__content">
                <div class="block__card__information">
                    {%- if section.settings.show_date -%}
                    <span class="flex items-center gap-10">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="19" viewBox="0 0 16 19" fill="none">
                            <path d="M5.34375 3H10.4062V1.59375C10.4531 1.07812 10.7344 0.796875 11.25 0.75C11.7656 0.796875 12.0469 1.07812 12.0938 1.59375V3H13.5C14.1328 3.02344 14.6602 3.24609 15.082 3.66797C15.5039 4.08984 15.7266 4.61719 15.75 5.25V16.5C15.7266 17.1328 15.5039 17.6602 15.082 18.082C14.6602 18.5039 14.1328 18.7266 13.5 18.75H2.25C1.61719 18.7266 1.08984 18.5039 0.667969 18.082C0.246094 17.6602 0.0234375 17.1328 0 16.5V5.25C0.0234375 4.61719 0.246094 4.08984 0.667969 3.66797C1.08984 3.24609 1.61719 3.02344 2.25 3H3.65625V1.59375C3.70312 1.07812 3.98438 0.796875 4.5 0.75C5.01562 0.796875 5.29688 1.07812 5.34375 1.59375V3ZM1.6875 16.5C1.71094 16.8516 1.89844 17.0391 2.25 17.0625H13.5C13.8516 17.0391 14.0391 16.8516 14.0625 16.5V7.5H1.6875V16.5Z" fill="white"/>
                        </svg>
                        {{ article.published_at | time_tag: format: 'date' }}
                    </span>
                    {%- endif -%}
                    {%- if section.settings.show_author -%}
                    <span>{{ article.author }}</span>
                    {%- endif -%}
                    <h3 class="underline-links-hover">
                        <a href="{{ article.url }}" class="full-unstyled-link">
                        {{- article.title | truncate: 50 | escape -}}
                        </a>
                    </h3>
                    {%- if article.excerpt -%}
                        {%- if article.excerpt.size > 0 or article.content.size > 0 -%}
                        <p>
                            {%- if article.excerpt.size > 0 -%}
                            {{ article.excerpt | strip_html | truncatewords: 30 }}
                            {%- else -%}
                            {{ article.content | strip_html | truncatewords: 30 }}
                            {%- endif -%}
                        </p>
                        {%- endif -%}
                    {%- endif -%}
                    
                    {% if section.settings.button_text != blank %}
                    <div class="block__button-wrapper">
                        <a {% if section.settings.button_url !=blank %}href="{{ section.settings.button_url }}" {%  else %} href="{{ article.url }}" {% endif %} class="button button-offset senary-border-radius">{{ section.settings.button_text }}</a>
                    </div>
                    {% endif %}
                </div>
            </div>
          </div>
    </div>
</div>

{% style %}  
    @media (min-width:990px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.desktop_padding_top }}px;
            padding-bottom:{{ section.settings.desktop_padding_bottom }}px;
        }
    }
    @media (max-width:989px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.mobile_padding_top }}px;
            padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
        }
    }
    @media (min-width:750px){
       .block__blog-banner-main  .article-card__image{padding-bottom:{{ section.settings.image_set_by_padding }}%;}
    }
    @media (max-width:749px){
        .block__blog-banner-main .article-card__image{padding-bottom:{{ section.settings.image_set_by_padding_mobile }}%;}
    }
{% endstyle %}

{% schema %}
{
"name": "Blog Banner",
"settings": [
    {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color"
    },
    {
        "type": "image_picker",
        "id": "bg_image",
        "label": "Background Image"
    },
    {
        "type": "text",
        "id": "image_set_by_padding",
        "label": "Image Set By Padding On Desktop",
        "info": "Example: 50 – The value will be counted as a percentage."
    },
    {
        "type": "text",
        "id": "image_set_by_padding_mobile",
        "label": "Image Set By Padding On Mobile",
        "info": "Example: 50 – The value will be counted as a percentage."
    },
    {
        "type": "article",
        "id": "selected_article",
        "label": "Select an Article"
    },
    {
        "type": "checkbox",
        "id": "show_image",
        "default": true,
        "label": "t:sections.main-blog.settings.show_image.label"
    },
    {
        "type": "text",
        "id": "button_text",
        "label": "Button Text"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "Button Url"
    },
    {
        "type": "select",
        "id": "image_height",
        "options": [
            {
            "value": "adapt",
            "label": "t:sections.main-blog.settings.image_height.options__1.label"
            },
            {
            "value": "small",
            "label": "t:sections.main-blog.settings.image_height.options__2.label"
            },
            {
            "value": "medium",
            "label": "t:sections.main-blog.settings.image_height.options__3.label"
            },
            {
            "value": "large",
            "label": "t:sections.main-blog.settings.image_height.options__4.label"
            }
        ],
        "default": "medium",
        "label": "t:sections.main-blog.settings.image_height.label",
        "info": "t:sections.main-blog.settings.image_height.info"
    },
    {
        "type": "checkbox",
        "id": "show_date",
        "default": true,
        "label": "t:sections.main-blog.settings.show_date.label"
    },
    {
        "type": "checkbox",
        "id": "show_author",
        "default": false,
        "label": "t:sections.main-blog.settings.show_author.label"
    },
    {
        "type": "header",
        "content": "Desktop Space"
    },
    {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Desktop Padding Top",
        "default": 16
    },
    {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Desktop Padding Bottom",
        "default": 16
    },
    {
        "type": "header",
        "content": "Mobile Space"
    },
    {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Padding Top",
        "default": 16
    },
    {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Padding Bottom",
        "default": 16
    }
],
"presets": [
    {
        "name": "Blog Banner"
    }
]
}
{% endschema %}

