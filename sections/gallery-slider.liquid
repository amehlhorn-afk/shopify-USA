{{ 'section-gallery-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'gallery-slider.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-gallery-slider">
  <div class="block__gallery-slider-header">
    <button class="gallery-slider-arrow gallery-slider-prev">
      {{- 'icon-prev-arrow.svg' | inline_asset_content -}}
    </button>
    {% if section.settings.title != blank %}
      <h2 class="primary_h2">{{ section.settings.title }}</h2>
    {% endif %}
    <button class="gallery-slider-arrow gallery-slider-next">
      {{- 'icon-next-arrow.svg' | inline_asset_content -}}
    </button>
  </div>
  <div class="block__gallery-slider swiper-container swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="block__gallery-slide swiper-slide">
          {% if block.settings.img != blank %}
            <div class="block__gallery-slider-img">
              {% if block.settings.url != blank %}
                <a href="{{ block.settings.url }}"></a>
              {% endif %}
              {% render 'custom-image', image: block.settings.img, class: 'img-fluid object-cover' %}
            </div>
          {% endif %}
          <div class="block__gallery-slider-info">
            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="body">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
        {% assign forloop = forloop.index %}
      {% endfor %}
      {% if forloop < 4 %}
        {% for block in section.blocks %}
          <div class="block__gallery-slide swiper-slide">
            {% if block.settings.img != blank %}
              <div class="block__gallery-slider-img">
                {% if block.settings.url != blank %}
                  <a href="{{ block.settings.url }}"></a>
                {% endif %}
                {% render 'custom-image', image: block.settings.img, class: 'img-fluid object-cover' %}
              </div>
            {% endif %}
            <div class="block__gallery-slider-info">
              {% if block.settings.title != blank %}
                <h3>{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="body">{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<script>
 var mySwiper = new Swiper(".block__gallery-slider", {
    spaceBetween: 1,
    slidesPerView: 1.2,
    centeredSlides: true,
    roundLengths: true,
    loop: true,
    loopAdditionalSlides: 60,
    navigation: {
      nextEl: ".gallery-slider-next",
      prevEl: ".gallery-slider-prev"
    }
  });

</script>

{% schema %}
{
  "name": "Gallery Slider",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Title"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "support",
      "name": "Support",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery Slider"
    }
  ]
}
{% endschema %}
