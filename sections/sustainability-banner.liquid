{{ 'section-sustainability-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
  {% if section.settings.text_color != blank %}
    .block__sustainability-banner-content h3,
    .block__sustainability-banner-content p{color:{{ section.settings.text_color }};}
    {% endif %}
{% endstyle %}

<div class="section-{{ section.id }} section-sustainability-banner">
  <div class="page-width">
    <div class="block__sustainability-banner relative z-index-1">
      {% if section.settings.img != blank %}
        <div class="section-sustainability-banner-bg absolute">
          {% render 'custom-image', image: section.settings.img, class: 'img-fluid desktop-bg object-cover' %}
          {% if section.settings.img_mobile != blank %}
            {% assign mobile_bg = section.settings.img_mobile %}
          {% else %}
            {% assign mobile_bg = section.settings.img %}
          {% endif %}
          {% render 'custom-image', image: mobile_bg, class: 'img-fluid mobile-bg object-cover' %}
          {% if section.settings.overlay != blank%}
          <span class="w-full z-index-1 h-full block absolute block__overlay_opacity inset-0"
              style="background-color: {{ section.settings.overlay_color }}; opacity:{{ section.settings.overlay_opacity }}%;">
          </span>
        {% endif %}
        </div>
      {% endif %}
      <div class="block__sustainability-banner-content text-left">
        {% if section.settings.title != blank %}
          <h3 class="block__sustainability-banner-title">
            {{ section.settings.title }}
          </h3>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body block__sustainability-banner-text">{{ section.settings.caption }}</p>
        {% endif %} 
        {% if section.settings.btn != blank %}
          <a href="{{ section.settings.url }}" target="_blank" class="body button-primary">{{ section.settings.btn }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Sustainability Banner",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "checkbox",
      "id": "overlay",
      "label": "Enable Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Background Color"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "unit": "%",
      "step": 1,
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Background Image(Desktop)"
    },
    {
      "type": "image_picker",
      "id": "img_mobile",
      "label": "Select Background Image(Mobile)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Sustainability Banner"
    }
  ]
}
{% endschema %}
