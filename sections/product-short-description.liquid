{%- comment -%}
  Metafield: custom.short_description [single_line_text_field / multi_line_text_field]
  Direct value — no metaobject wrapper, no .value needed.
{%- endcomment -%}

{%- assign short_desc = product.metafields.custom.short_description -%}

{%- if short_desc != blank -%}
  <div class="product-short-description">
    {{- short_desc -}}
  </div>
{%- endif -%}

{% style %}
  .product-short-description {
    font-size: 15px;
    color: var(--brand-gray-600);
    line-height: 1.65;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--brand-gray-200);
    padding-bottom: 16px;
  }
  .product-short-description p { margin: 0; }
{% endstyle %}
