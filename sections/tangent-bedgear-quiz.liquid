<script type="text/javascript" src="{{ 'tangent-script.js' | asset_url }}" defer></script>
<link rel="stylesheet" crossorigin href="https://a.tangent.ai/quiz-inline/2.0.30/assets/index-v2.0.30.css">
<script type="module" crossorigin src="https://a.tangent.ai/quiz-inline/2.0.30/assets/index-v2.0.30.js"></script>
<link rel="stylesheet" href="{{ 'tangent-styles.css' | asset_url }}">


<h1 style="display:none">{{ page.title }}</h1>
<div class="block__main-quiz color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div id="quiz-container" class="page-width">
    <div id="video-container">
      <video
        autoplay
        muted
        loop
        position="relative"
        aspect-ration="3:2"
        width="100%"
        playsinline
        poster="{{ '67ea52f3a5f62bd5bac84f7d.jpg' | file_img_url }}"
      >
        <source src="https://cdn.shopify.com/videos/c/o/v/aba9167c7fdb4ec0a2e422c832e3109b.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </div>
    <div id="quiz-block">
      <div
        style="display: none;"
        id="progress-bar-block"
      >
        <p class="question-progress-status">Question <span class="question-index-status">1 out of 7</span></p>
        <div class="progress-container">
          <div id="progress-bar" class="progress-bar">
            <p class="floating-index-status">1 out of 7</p>
          </div>
          <div id="bars-container"></div>
        </div>
      </div>
      <div
        data-formid="67ea52f3a5f62bd5bac84f7d"
        data-shopid="67268903052"
        data-offset="100"
        id="tangent-main-container"
        style="width: 100%;"
        data-locale="en"
      ></div>
    </div>
  </div>
</div>
{% style %}  
  @media (min-width:990px){
      .section-{{ section.id }}-padding{
          padding-top:{{ section.settings.desktop_padding_top }}px;
          padding-bottom:{{ section.settings.desktop_padding_bottom }}px;
      }
  }
  @media (max-width:989px){
      .section-{{ section.id }}-padding{
          padding-top:{{ section.settings.mobile_padding_top }}px;
          padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
      }
  }
{% endstyle %}
{% schema %}
{
  "name": "Tangent BeadGear Quiz",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
        "type": "header",
        "content": "Desktop Space"
    },
    {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Desktop Padding Top",
        "default": 16
    },
    {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Desktop Padding Bottom",
        "default": 16
    },
    {
        "type": "header",
        "content": "Mobile Space"
    },
    {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Padding Top",
        "default": 16
    },
    {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Padding Bottom",
        "default": 16
    }
  ],
  "presets": [
    {
      "name": "Tangent BeadGear Quiz"
    }
  ]
}
{% endschema %}
