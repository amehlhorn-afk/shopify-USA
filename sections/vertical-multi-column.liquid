{{ 'custom-multicolumn.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.desktop_padding_top }}px;
      padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    }
  }
  @media (max-width: 989px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }

  /* ===== Vertical Product Grid (Desktop & Mobile) ===== */
  #custom-multicolumn-{{ section.id }} .block__custom-multicolumn-wrapper {
    width: 100%;
  }

  /* The list becomes a simple vertical stack with consistent gaps */
  #custom-multicolumn-{{ section.id }} .block__custom-multicolumn-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Each "card"/block spans full width in the stack */
  #custom-multicolumn-{{ section.id }} .block__custom-multicolumn-inner {
    width: 100% !important;
  }

  /* Optional: tighten gap a bit on small screens */
  @media (max-width: 768px) {
    #custom-multicolumn-{{ section.id }} .block__custom-multicolumn-list {
      gap: 16px;
    }
  }

  /* Preserve your existing calculated width rule but it’s overridden by 100% above. */
  @media screen and (min-width: 1024px) {
    .block__custom-multicolumn-inner {
      width: calc(100% / {{ section.settings.columns_first_row }} - (20px *({{ section.settings.columns_first_row }} - 1)));
    }
  }
{%- endstyle -%}

<div id="custom-multicolumn-{{ section.id }}" class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="block__custom-multicolumn-main">
      <!-- REPLACED: swiper-container/swiper-wrapper with a simple vertical list -->
      <div class="block__custom-multicolumn-wrapper overflow-hidden">
        <div class="block__custom-multicolumn-list">
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when 'column' -%}
                <div class="block__custom-multicolumn-inner text-center">
                  <div class="mobile-link" data-src="{{ block.settings.link }}">
                    <div class="block__custom-multicolumn-media-inner flex justify-center items-center overflow-hidden w-full relative quaternary-border-radius">
                      {% if block.settings.image != blank %}
                        {% render 'custom-image',
                          image: block.settings.image,
                          class: 'block__media object-cover w-full h-full'
                        %}
                      {% else %}
                        {{
                          block.settings.video
                          | video_tag:
                            loop: true,
                            controls: false,
                            muted: true,
                            autoplay: true,
                            class: 'h-full w-full object-cover block block__media'
                        }}
                      {% endif %}
                      {% if block.settings.link != blank and block.settings.link_label != blank %}
                        <a
                          class="block__custom-multicolumn-btn button-tertiary senary-border-radius absolute font-weight-700"
                          href="{{ block.settings.link }}"
                        >
                          {{- block.settings.link_label -}}
                        </a>
                      {% endif %}
                    </div>
                    <div class="block__custom-multicolumn-content-inner inline-block relative font-weight-700">
                      {{ block.settings.text }}
                    </div>
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
      <!-- END vertical stack -->
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const root = document.getElementById('custom-multicolumn-{{ section.id }}');
    if (!root) return;

    // Mobile click-through (unchanged)
    function bindMobileLinks() {
      if (window.innerWidth <= 768) {
        root.querySelectorAll('.mobile-link').forEach(function (link) {
          if (link.dataset.bound === '1') return;
          link.dataset.bound = '1';
          link.addEventListener('click', function () {
            const url = link.getAttribute('data-src');
            if (url) window.location.href = url;
          });
        });
      }
    }
    bindMobileLinks();
    window.addEventListener('resize', bindMobileLinks, { passive: true });

    // NOTE: Swiper removed for this section to enforce vertical stacking on all breakpoints.
  });
</script>

{% schema %}
{
  "name": "Custom Multicolumn",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "hxxl", "label": "t:sections.all.heading_size.options__5.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "columns_first_row",
      "label": "Number of Columns in First Row",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 column" }
      ],
      "default": "1",
      "label": "Number of columns on mobile"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "Enable swipe on mobile"
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "header", "content": "Image" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "header", "content": "Video" },
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "header", "content": "Content" },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
          "label": "Description"
        },
        { "type": "header", "content": "Button" },
        { "type": "text", "id": "link_label", "label": "Link label" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Multicolumn",
      "blocks": [{ "type": "column" }]
    }
  ]
}
{% endschema %}
