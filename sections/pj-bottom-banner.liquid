{% schema %}
{
  "name": "Full Screen Text Banner",
  "tag": "section",
  "class": "text-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "SLEEP LIKE YOUR DAY DEPENDS ON IT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "BECAUSE IT DOES"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Below Heading"
    }
  ],
  "presets": [
    {
      "name": "Full Screen Text Banner"
    }
  ]
}
{% endschema %}

<div class="text-banner-section" style="background-image: url({{ section.settings.background_image | image_url }});">
  <div class="text-banner-content">
    <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="stroked-heading">{{ section.settings.heading }}</h1>
    {% if section.settings.logo %}
      <img class="banner-logo" src="{{ section.settings.logo | image_url: width: 200 }}" alt="Logo">
    {% endif %}
  </div>
</div>

<style>
.text-banner-section {
  position: relative;
  width: 100%;
  height: 100vh;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.text-banner-content {
  color: white;
  text-align: center;
  max-width: 90vw;
}

.eyebrow {
  color: #FFF;
  font-family: Roboto;
  font-size: 52px;
  font-style: normal;
  font-weight: 500;
  line-height: normal;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.stroked-heading {
  color: white;
  -webkit-text-stroke-width: 2.62px;
  -webkit-text-stroke-color: #FFF;
  font-family: Roboto;
  font-size: 157.059px;
  font-style: normal;
  font-weight: 700;
  line-height: 133.5px;
  text-transform: uppercase;
  margin: 0;
}

.banner-logo {
  margin-top: 90px;
  max-width: 140px;
  height: auto;
}

@media (max-width: 768px) {
  .eyebrow {
    font-size: 18px;
  }

  .stroked-heading {
    font-size: 64px;
    line-height: 72px;
    -webkit-text-stroke-width: 1.5px;
  }

  .banner-logo {
    margin-top: 60px;
    max-width: 100px;
  }
}
</style>
