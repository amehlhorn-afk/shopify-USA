{{ 'searvice-teams.css' | asset_url | stylesheet_tag }}
{% style %}  
    @media (min-width:750px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.desktop_padding_top }}px;
            padding-bottom:{{ section.settings.desktop_padding_bottom }}px;
        }
    }
    @media (max-width:749px){
        .section-{{ section.id }}-padding{
            padding-top:{{ section.settings.mobile_padding_top }}px;
            padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
        }
    }
{% endstyle %}
<div class="block__searvice-team section-{{ section.id }}-padding sec_bg_color" {% if section.settings.sec_bg_color != blank %}style="background-color:{{section.settings.sec_bg_color}};"{% endif %}>
    <div class="page-width">
        {% if section.settings.heading != blank %}
        <div class="block__heading flex gap-10 flex-direction-column justify-center center">
            {% if section.settings.subheading != blank %}
                <p>{{ section.settings.subheading }}</p>
            {% endif %}
            <h2 class="primary_h2">{{ section.settings.heading }}</h2>
        </div>
        {% endif %}
        <div class="block__support-cards justify-center flex gap-20 flex-wrap">
            {% for block in section.blocks %}
            <div class="block__card-item center  secondary-border-radius" {% if section.settings.box_bg_color != blank %}style="background-color:{{section.settings.box_bg_color}};"{% endif %}>
                {% if block.settings.icon_image != blank %}
                    <div class="block__image-wrapper">
                        <span class="senary-border-radius justify-center items-center inline-flex" {% if section.settings.icon_bg_color != blank %}style="background-color:{{section.settings.icon_bg_color}};"{% endif %}>
                            {% render 'custom-image', image: block.settings.icon_image, class: 'img-fluid' %}
                        </span>
                    </div>
                {% endif %}
                <div class="block__contnet-wrapper">
                    <h4 class="primary_h4">{{ block.settings.title }}</h4>
                    {% if block.settings.description != blank%}
                        <p class="medium_body">{{ block.settings.description }}</p>
                    {% endif %}
                    {% if block.settings.button_text != blank %}
                        <a href="{{ block.settings.button_url }}" class="button-quaternary button senary-border-radius">
                            {{ block.settings.button_text }}
                        </a>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>


{% schema %}
{
    "name": "Searvice Team Support",
    "settings": [
        {
            "type": "color",
            "id": "sec_bg_color",
            "label": "Section Background Color"
        },
        {
            "type": "color",
            "id": "box_bg_color",
            "label": "Box Background Color"
        },
        {
            "type": "color",
            "id": "icon_bg_color",
            "label": "Icon Background Color"
        },    
        {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "text",
            "id": "subheading",
            "label": "Subheading"
        },
        {
            "type": "header",
            "content": "Desktop Space"
        },
        {
            "type": "range",
            "id": "desktop_padding_top",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Desktop Padding Top",
            "default": 16
        },
        {
            "type": "range",
            "id": "desktop_padding_bottom",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Desktop Padding Bottom",
            "default": 16
        },
        {
            "type": "header",
            "content": "Mobile Space"
        },
        {
            "type": "range",
            "id": "mobile_padding_top",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Mobile Padding Top",
            "default": 16
        },
        {
            "type": "range",
            "id": "mobile_padding_bottom",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Mobile Padding Bottom",
            "default": 16
        }
    ],
    "blocks": [
    {
        "type": "support_card",
        "name": "Support Card",
        "settings": [
            {
                "type": "image_picker",
                "id": "icon_image",
                "label": "Upload Icon Image"
            },
            {
                "type": "inline_richtext",
                "id": "title",
                "label": "Title"
            },
            {
                "type": "inline_richtext",
                "id": "description",
                "label": "Description"
            },
            {
                "type": "text",
                "id": "button_text",
                "label": "Button Text"
            },
            {
                "type": "url",
                "id": "button_url",
                "label": "Button Url"
            }
        
        ]
    }
    ],
    "presets": [
    {
        "name": "Searvice Team Support"
    }
    ]
}
{% endschema %}
    
    
    