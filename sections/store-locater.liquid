                    <div class="block__location-search justify-end flex items-center gap-15">
                        <div class="block__search-item relative">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none"
                            class="block__menu-search absolute">
                            <path
