
{% comment %} 
{{ 'store-locater-sec.css' | asset_url | stylesheet_tag }}

<div class="block__store-locater section-{{ section.id }}-padding"  {% if section.settings.bg_color != blank %}style="background-color: {{ section.settings.bg_color }};"{% endif %}>
    <div class="page-width">
        <div class="block__header-top flex items-center justify-between gap-30">
            {% if section.settings.title != blank %}
                <h3>{{ section.settings.title }}</h3>
            {% endif %}
            <div class="tab-buttons flex items-center ">
                <label class="tab-btn active" data_id="{{ section.settings.tab_one_text |  handleize }}" data-params="{{ section.settings.tab_one_text |  handleize }}" data-trigger="retails_cls" data-filter="141893">
                    {{ section.settings.tab_one_icon }}
                    {{ section.settings.tab_one_text }}
                </label>
                <label class="tab-btn" data_id="{{ section.settings.tab_two_text |  handleize }}" data-params="{{ section.settings.tab_two_text | handleize }}" data-trigger="hospitality_cls" data-filter="141894">
                    {{ section.settings.tab_two_icon }}
                    {{ section.settings.tab_two_text }}
                </label>
            </div>
        </div>
        <div class="tab-content">
            <div id="{{ section.settings.tab_one_text |  handleize }}" class="tab-pane active">
                <div id='storerocket-widget' style='width:100%;' data-storerocket-filters='141893' data-storerocket-env='p' data-storerocket-id='aKpDxjopdR'><p style='text-align:center;font-size:13px;padding:10px;'>Store locator is loading from StoreRocket <a target='_blank' href='https://storerocket.io' style='font-size:13px;'>Store Locator App</a>..</p></div><script>(function(){var a=document.createElement('script');a.type='text/javascript';a.async=!0;a.src='https://cdn.storerocket.io/js/widget-mb.js';var b=document.getElementsByTagName('script')[0];b.parentNode.insertBefore(a,b);}());</script>
                <div class="storerocket-store-locator retails_cls"></div>
                <script src="//cdn.storerocket.io/widget.js"></script>
                <script>
                    StoreRocket.init({
                        selector: ".storerocket-store-locator",
                        account: "aKpDxjopdR"
                    });
                    </script> 
            </div>

            <div id="{{ section.settings.tab_two_text |  handleize }}" class="tab-pane">
              <div id='storerocket-widget' style='width:100%;' data-storerocket-filters='141894' data-storerocket-env='p' data-storerocket-id='aKpDxjopdR'><p style='text-align:center;font-size:13px;padding:10px;'>Store locator is loading from StoreRocket <a target='_blank' href='https://storerocket.io' style='font-size:13px;'>Store Locator App</a>..</p></div><script>(function(){var a=document.createElement('script');a.type='text/javascript';a.async=!0;a.src='https://cdn.storerocket.io/js/widget-mb.js';var b=document.getElementsByTagName('script')[0];b.parentNode.insertBefore(a,b);}());</script> 
                 <div class="storerocket-store-locator hospitality_cls"></div>
            </div>
        </div>
    </div>
</div>


<script>
    let tab_btn = document.querySelectorAll('.tab-btn');
    let tab_pane = document.querySelectorAll('.tab-pane');
    
    window.addEventListener('load', function(){
        let url = new URL(window.location.href);
        let locParam = url.searchParams.get('loc')
        if(locParam){
            tab_btn.forEach((btn) => {
                btn.classList.remove('active')
                if (!btn.dataset.params == locParam){
                    document.getElementById(btn.attributes.data_id.value).innerHTML = '';  
                }   
             });
            tab_pane.forEach(pane => {
            pane.classList.remove('active');
            });

            tab_btn.forEach(function(btn) {   
                if (btn.dataset.params === locParam) {
                     btn.classList.add('active');
                     console.log(btn.attributes.data_id.value, "DATA")
                     document.getElementById(btn.attributes.data_id.value).classList.add('active'); 
               }
            });
        }
         
    })

    tab_btn.forEach(function(e) {
           e.addEventListener('click', function(event) {
    
            let trigger_class = event.target.dataset.trigger;
            let filter =  event.target.dataset.filter;
            let params = event.target.dataset.params; 

            let newUrl = new URL(window.location.href);

            newUrl.searchParams.set('loc', params);
         
            window.history.replaceState({}, '', newUrl); 
          
            let locParam = newUrl.searchParams.get('loc'); 

            if(locParam){
                    tab_pane.forEach(pane => {
                        pane.classList.remove('active');
                    });
                    tab_btn.forEach(function(e) {
                        e.classList.remove('active'); 
                    });

                    if (params === locParam) {
                        event.target.classList.add('active');
                        document.getElementById(event.target.attributes.data_id.value).classList.add('active'); 
                    }
                    let scriptEl = 'script'
                    if(params == 'hospitality-locations'){
                        document.getElementById('retail-locations').innerHTML = ''; 
                        document.getElementById(event.target.attributes.data_id.value).innerHTML = `<div id='storerocket-widget' style='width:100%;' data-storerocket-env='p' data-storerocket-id='aKpDxjopdR'><p style='text-align:center;font-size:13px;padding:10px;'>Store locator is loading from StoreRocket <a target='_blank' href='https://storerocket.io' style='font-size:13px;'>Store Locator App</a>..</p></div><${scriptEl}>(function(){var a=document.createElement('script');a.type='text/javascript';a.async=!0;a.src='https://cdn.storerocket.io/js/widget-mb.js';var b=document.getElementsByTagName('script')[0];b.parentNode.insertBefore(a,b);}());</${scriptEl}> <div class="hospitality_cls"></div><${scriptEl} src="//cdn.storerocket.io/widget.js"></${scriptEl}>`
                        StoreRocket.init({
                        selector: ".hospitality_cls",
                        account: "aKpDxjopdR",
                        filters: "141894"
                     });
                    }else if(params == 'retail-locations'){
                        document.getElementById('hospitality-locations').innerHTML = ''; 
                        document.getElementById(event.target.attributes.data_id.value).innerHTML = `<div id='storerocket-widget' style='width:100%;'  data-storerocket-env='p' data-storerocket-id='aKpDxjopdR'><p style='text-align:center;font-size:13px;padding:10px;'>Store locator is loading from StoreRocket <a target='_blank' href='https://storerocket.io' style='font-size:13px;'>Store Locator App</a>..</p></div><${scriptEl}>(function(){var a=document.createElement('script');a.type='text/javascript';a.async=!0;a.src='https://cdn.storerocket.io/js/widget-mb.js';var b=document.getElementsByTagName('script')[0];b.parentNode.insertBefore(a,b);}());</${scriptEl}> <div class="retails_cls"></div>    <${scriptEl} src="//cdn.storerocket.io/widget.js"></${scriptEl}>`
                        StoreRocket.init({
                           selector: ".retails_cls",
                           account: "aKpDxjopdR",
                           filters: "141893"
                        });
                    }
                    }

        });
    });
</script> {% endcomment %}

{{ 'store-locater-sec.css' | asset_url | stylesheet_tag }}

<div class="block__store-locater section-{{ section.id }}-padding"  {% if section.settings.bg_color != blank %}style="background-color: {{ section.settings.bg_color }};"{% endif %}>
    <div class="page-width">
        <div class="block__header-top flex items-center justify-between gap-30">
            {% if section.settings.title != blank %}
