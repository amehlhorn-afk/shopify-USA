{{ 'section-collaborations-multirow.css' | asset_url | stylesheet_tag }}

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.color }};
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-collaborations-multirow">
  <div class="page-width">
    {% if section.settings.title != blank or section.settings.caption != blank %}
      <div class="block__collaborations-multirow-header">
        {% if section.settings.title != blank %}
          <h2 class="primary_h2">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.caption != blank %}
          <p class="body">{{ section.settings.caption }}</p>
        {% endif %}
      </div>
    {% endif %}
    <div class="block__collaborations-multirow-list">
      {% for block in section.blocks %}
        <div
          class="block__collaborations-multirow-wrapper block__collaborations-multirow-media-{{ block.settings.img_position }}"
          style="background-color: {{ block.settings.bg_color }};"
        >
          <div class="block__collaborations-multirow-img">
            {% if block.settings.video != blank %}
              {{
                block.settings.video
                | video_tag: loop: true, muted: true, autoplay: true, playsinline: true, width: '100%', height: '100%'
              }}
            {% else %}
              {% render 'custom-image', image: block.settings.img, class: 'img-fluid object-contain' %}
            {% endif %}
          </div>
          <div class="block__collaborations-multirow-info">
            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.caption != blank %}
              <div class="body block__collaborations-multirow-caption">{{ block.settings.caption }}</div>
            {% endif %}
            <div class="block__collaborations-multirow-btn">
              {% if block.settings.btn1 != blank %}
                <a href="{{ block.settings.url1 }}" class="body button-quaternary">{{ block.settings.btn1 }}</a>
              {% endif %}
              {% if block.settings.btn2 != blank %}
                <a href="{{ block.settings.url2 }}" class="body button-primary">{{ block.settings.btn2 }}</a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collaborations Multirow",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Select Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collaborations-multirow",
      "name": "Collaborations Multirow",
      "settings": [
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        },
        {
          "type": "select",
          "id": "img_position",
          "label": "Image Position",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "right"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select Image",
          "info": "upload a Image, Image will be show if video is not available"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "header",
          "content": "Button 1 Content"
        },
        {
          "type": "text",
          "id": "btn1",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "url1",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Button 2 Content"
        },
        {
          "type": "text",
          "id": "btn2",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "url2",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collaborations Multirow"
    }
  ]
}
{% endschema %}
