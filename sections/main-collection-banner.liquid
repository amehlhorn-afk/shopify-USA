{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (max-width: 749px) {
    .collection-hero--with-image .collection-hero__inner {
      padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
    }
  }
{%- endstyle -%}

{%- liquid
  comment
    Metafield overrides: custom.collection_title, custom.collection_description,
    custom.collection_image [13 collections]. Take priority over built-in fields.
  endcomment
  assign banner_title       = collection.metafields.custom.collection_title | default: collection.title
  assign banner_description = collection.metafields.custom.collection_description | default: collection.description
  assign banner_image       = collection.metafields.custom.collection_image
  if banner_image == blank
    assign banner_image = collection.image
  endif
  assign has_image = false
  if section.settings.show_collection_image and banner_image != blank
    assign has_image = true
  endif
-%}

<div class="collection-hero{% if has_image %} collection-hero--with-image{% endif %} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      <h1 class="collection-hero__title">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        {{- banner_title | escape -}}
      </h1>

      {%- if section.settings.show_collection_description and banner_description != blank -%}
        <div class="collection-hero__description rte">{{ banner_description }}</div>
      {%- endif -%}
    </div>

    {%- if has_image -%}
      <div class="collection-hero__image-container media gradient">
        {{-
          banner_image
          | image_url: width: 750
          | image_tag:
            loading: 'lazy',
            widths: '165, 360, 535, 750, 1070, 1500',
            sizes: '(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)',
            alt: banner_title
        -}}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
