{{ 'section-team-info-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'team-info-slider.js' | asset_url }}" defer="defer"></script>

{% style %}
  .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 1199px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
      }
  }
  @media (max-width: 749px) {
      .section-{{ section.id }} {
          padding-top: {{ section.settings.padding_top_m }}px;
          padding-bottom: {{ section.settings.padding_bottom_m }}px;
      }
  }
{% endstyle %}

<div class="section-{{ section.id }} section-team-info-slider">
  <div class="page-width">
    <div class="block__team-info-row">
      <div class="block__team-info-slider-img">
        <div class="block__team-info-img-slider swiper-container swiper">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.settings.img != blank %}
                <div class="block__team-info-img-slide swiper-slide">
                  {% render 'custom-image', image: block.settings.img, class: 'img-fluid object-cover' %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="block__team-info-slider-text">
        <div class="block__team-info-text-slider swiper-container swiper">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="block__team-info-text-slide swiper-slide">
                {% if block.settings.title != blank %}
                  <h2 class="primary_h2">{{ block.settings.title }}</h2>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="body block__team-info-description">{{ block.settings.description }}</p>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h6 class="block__team-info-heading">{{ block.settings.heading }}</h6>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="body block__team-info-text">{{ block.settings.text }}</p>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </div>
        <div class="block__team-info-slider-btn">
          <button class="block__team-info-slider-prev">
            {{- 'icon-prev-arrow.svg' | inline_asset_content -}}
          </button>
          <button class="block__team-info-slider-next">
            {{- 'icon-next-arrow.svg' | inline_asset_content -}}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Team Info Slider",
  "settings": [
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Top padding(Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding(Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "team_info_slider",
      "name": "Team Info Slider",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Select Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Name Text"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Info Slider"
    }
  ]
}
{% endschema %}
