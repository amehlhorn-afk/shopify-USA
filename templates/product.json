{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title",
          "settings": {}
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        },
        "tab_details": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Build, Materials & Care",
            "icon": "info",
            "content": "",
            "page": ""
          }
        },
        "tab_shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping, Warranty & Returns",
            "icon": "truck",
            "content": "Free standard shipping on orders over $50. Ships in 1\u20132 business days. 365-Night Trial \u2014 if it\u2019s not right, we make it right. 1-year manufacturer warranty on all defects.",
            "page": ""
          }
        },
        "tab_sizing": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Measurements & Dimensions",
            "icon": "ruler",
            "content": "",
            "page": ""
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "tab_details",
        "tab_shipping",
        "tab_sizing"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "gallery_layout": "stacked",
        "mobile_thumbnails": "show",
        "media_position": "left",
        "image_zoom": "lightbox",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 40,
        "padding_bottom": 20
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You May Also Like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": "2",
        "color_scheme": "scheme-2",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "padding_top": 48,
        "padding_bottom": 48
      }
    }
  },
  "order": [
    "main",
    "related-products"
  ]
}
