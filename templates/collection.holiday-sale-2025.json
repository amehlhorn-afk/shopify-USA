ne_hover_bg_color":"#00b5e3","button_outline_hover_text_color":"#00b5e3","button_outline_hover_border_color":"#00b5e3"}}},"block_order":["promo_tile_qrHMm8","promo_tile_XmxtQi","promo_tile_Rq3A4a","promo_tile_aKkWJQ"],"name":"Promo Trio","settings":{"section_heading":"Promotions","mobile_peek":20,"section_bg_color":"","section_bg_size":"cover","section_bg_position":"center center","section_bg_repeat":"no-repeat","pad_top_desktop":40,"pad_bottom_desktop":40,"pad_top_mobile":20,"pad_bottom_mobile":20,"card_height_desktop":240,"card_height_mobile":200,"headline_size_desktop":12,"subheadline_size_desktop":30,"description_size_desktop":16,"headline_size_mobile":14,"subheadline_size_mobile":32,"description_size_mobile":16}},"product-grid":{"type":"main-collection-product-grid","settings":{"products_per_page":12,"vertical_stack_layout":false,"horizontal_compact_layout":false,"enable_card_features":false,"compact_image_height_desktop":220,"columns_desktop":3,"color_scheme":"scheme-1","image_ratio":"adapt","image_shape":"default","show_secondary_image":true,"show_vendor":false,"show_rating":false,"show_clp_description":true,"show_clp_features":true,"quick_add":"standard","unable_custom_card":false,"custom_card_image":"shopify://shop_images/Modular-mattress_customcard.jpg","custom_card_heading":"Modular by Design. Personalized by You.","custom_card_description":"","custom_card_heading_size_desktop":26,"custom_card_heading_size_mobile":20,"custom_card_description_size_desktop":16,"custom_card_description_size_mobile":14,"custom_card_center_text":false,"custom_card_logo_position":"tl","custom_card_logo_offset_x":0,"custom_card_logo_offset_y":0,"custom_card_logo_offset_x_mobile":0,"custom_card_logo_offset_y_mobile":0,"custom_card_disclaimer":"","custom_card_figma_style":false,"custom_card_figma_max_width":"92%","custom_card_offset_x":0,"custom_card_offset_y":0,"custom_card_offset_x_mobile":0,"custom_card_offset_y_mobile":0,"custom_card_max_width_desktop":"92%","custom_card_max_width_mobile":"92%","custom_card_padding_desktop":16,"custom_card_padding_mobile":12,"custom_card_text_align_desktop":"left","custom_card_text_align_mobile":"left","enable_filtering":true,"filter_type":"vertical","enable_sorting":true,"columns_mobile":"2","padding_top":52,"padding_bottom":80}},"collection_rich_article_J3a3gw":{"type":"collection-rich-article","blocks":{"heading_gn34aG":{"type":"heading","settings":{"level":"h2","text":"About Performance® Mattresses","align":"center"}},"image_Ark9JE":{"type":"image","settings":{"image":"shopify://shop_images/04-M3-Mattress-Lifestyle1-WEB_0648f1b5-d1e2-4ef7-863a-0ea329829a32.jpg","alt":"","width":100,"float":"center","caption":"","align":"left"}},"text_8YQByV":{"type":"text","settings":{"content":"<p>A truly great night’s sleep starts with a mattress that works with your body — not against it. Other brands talk about “temperature regulation,” but only your body can regulate its temperature. That’s why BEDGEAR Performance® Mattresses are engineered to support this process. From cooling covers to advanced airflow channels, every detail is designed to boost breathability, wick away moisture, and help you stay cool from sunset to sunrise.</p>","align":"left"}},"heading_HJFfEM":{"type":"heading","settings":{"level":"h4","text":"Why Cooling Matters","align":"left"}},"text_URebt9":{"type":"text","settings":{"content":"<p>Traditional mattresses trap heat. They use dense foams and solid covers that restrict airflow, creating hot spots that jolt you awake. Our Performance® Mattresses solve this problem with layered airflow, moisture-wicking fabrics, and cooling covers that move heat away from your body. The result? Night sweats and sticky humidity no longer stand between you and deep, restorative rest.</p>","align":"left"}},"text_ynikHM":{"type":"text","settings":{"content":"<p>This technology matters no matter where you sleep:<br/><br/></p><ul><li><strong>Hot, humid climates like Florida, Texas, or Georgia: moisture-wicking fabrics prevent dampness.</strong></li><li><strong>Dry, desert climates like Arizona and Nevada: airflow layers prevent trapped heat.</strong></li><li><strong>Cold climates like Minnesota or New York: adaptive fabrics help balance body temperature year-round.</strong></li></ul>","align":"left"}},"heading_piVCpV":{"type":"heading","settings":{"level":"h4","text":"Why Support Matters","align":"left"}},"text_aetnwL":{"type":"text","settings":{"content":"<p>Temperature control is only half of the equation. Without proper support, your body can’t recharge. Every BEDGEAR mattress uses adaptive support layers that instantly respond to your movements. That means pressure relief at the hips, shoulders, and lower back, with full-body alignment that helps reduce stiffness and pain.<br/><br/>Whether you’re recovering from a HIIT workout, logging long hours at a desk, or simply chasing after kids, adaptive support helps you wake up ready for more.</p>","align":"left"}},"image_pWiPdM":{"type":"image","settings":{"image":"shopify://shop_images/M-series-collection-blog-content.jpg","alt":"","width":100,"float":"center","caption":"","align":"left"}},"heading_eHMFVY":{"type":"heading","settings":{"level":"h4","text":"What Sets BEDGEAR Apart","align":"left"}},"text_kKFVWz":{"type":"text","settings":{"content":"<ol><li><strong>Personalized Comfort</strong> – No two bodies are the same. That’s why BEDGEAR offers multiple comfort levels and modular firmness customization. Couples can choose their own feel on each side of the mattress — no more compromises.</li><li><strong>Advanced Cooling Technology</strong> – Airflow layers, breathable mesh, and instant-cooling covers help prevent overheating, night sweats, and humidity disruption.</li><li><strong>Designed for Recovery</strong> – Our mattresses are trusted by athletes, professionals, and parents to speed recovery, improve energy, and fight morning grogginess.</li><li><strong>Built to Last</strong> – Premium materials and modular construction ensure consistent support, airflow, and durability for years of performance sleep.</li></ol>","align":"left"}},"image_RrrW4b":{"type":"image","settings":{"image":"shopify://shop_images/9-M5-Mattress-WashableCover_noCopy-WEB.jpg","alt":"","width":100,"float":"center","caption":"","align":"left"}},"heading_kC8zdw":{"type":"heading","settings":{"level":"h4","text":"Best Mattresses for Every Need","align":"left"}},"heading_6jUbB9":{"type":"heading","settings":{"level":"h5","text":"Best Mattress for Hot Sleepers","align":"left"}},"text_RCqfXy":{"type":"text","settings":{"content":"<p>If you live in warm climates like Houston or Orlando, you know the toll heat takes on sleep. Our Night Ice models, including the <strong>M3 Night Ice</strong> and <strong>M5 Night Ice</strong>, combine three layers of cooling tech with breathable support layers to help you sleep cooler and deeper.</p>","align":"left"}},"quote_X4VDrL":{"type":"quote","settings":{"quote":"<p><strong>“As a runner in Austin, TX, I deal with constant overheating. BEDGEAR keeps me cool through the night.”</strong></p>","cite":"Fitness Coach, Austin, TX","align":"left"}},"heading_9FtKDF":{"type":"heading","settings":{"level":"h4","text":"Best Mattress for Athletes","align":"left"}},"text_ajKf9i":{"type":"text","settings":{"content":"<p>Recovery is critical. From basketball players in Los Angeles to runners in Chicago, athletes rely on BEDGEAR for:<br/><br/></p><ul><li>Adaptive comfort zones that support spinal alignment</li><li>Pressure point relief to speed up muscle recovery</li><li>Breathable airflow systems that fight overheating during deep sleep</li></ul>","align":"left"}},"text_P3VCbE":{"type":"text","settings":{"content":"<p>One likes soft, the other firm? One runs hot, the other cold? Our modular Independent Suspension Units™ let each sleeper choose their own feel, so couples can finally sleep in harmony.</p>","align":"left"}},"heading_LHh8N9":{"type":"heading","settings":{"level":"h4","text":"Best Mattress for Couples","align":"left"}},"text_qmtgag":{"type":"text","settings":{"content":"<p>One likes soft, the other firm? One runs hot, the other cold? Our <strong>modular Independent Suspension Units™</strong> let each sleeper choose their own feel, so couples can finally sleep in harmony.</p>","align":"left"}},"heading_GdURrW":{"type":"heading","settings":{"level":"h4","text":"Best Mattress for Back Pain","align":"left"}},"text_7J4eMw":{"type":"text","settings":{"content":"<p>Back pain is often caused by poor posture during sleep. The <strong>M5 Performance® Mattress</strong> and <strong>M5 Night Ice</strong> Mattress include enhanced React® Comfort Layers and adaptive coil systems that promote spinal alignment and reduce lower-back strain.</p>","align":"left"}},"quote_pf78EJ":{"type":"quote","settings":{"quote":"<p><strong>“I used to wake up every night with back pain. The M5 has changed everything — I wake up without stiffness.”</strong></p>","cite":"Customer, Denver, CO","align":"left"}},"heading_NhiY3U":{"type":"heading","settings":{"level":"h4","text":"Why the Right Mattress Matters","align":"left"}},"text_jTjbay":{"type":"text","settings":{"content":"<ul><li><strong>Temperature:</strong> Overheating is the #1 cause of sleep disruption. A cooling mattress helps balance core temperature for uninterrupted REM cycles.</li><li><strong>Support:</strong> Personalized comfort prevents pressure points and pain, allowing muscles and joints to repair.</li><li><strong>Durability:</strong> A sagging mattress sabotages recovery. Performance® construction ensures years of consistent support.</li></ul>","align":"left"}},"heading_JT6wPX":{"type":"heading","settings":{"level":"h6","text":"Also Read:","align":"left"}},"text_j7QwBP":{"type":"text","settings":{"content":"<p><a href=\"https://bedgear.com/blogs/health-and-wellness/how-to-prevent-night-sweats\" target=\"_blank\" title=\"https://bedgear.com/blogs/health-and-wellness/how-to-prevent-night-sweats\"><span style=\"text-decoration:underline\">How to Prevent Night Sweats</span></a></p><p><a href=\"https://bedgear.com/blogs/health-and-wellness/why-mama-needs-a-good-nights-sleep\" target=\"_blank\" title=\"https://bedgear.com/blogs/health-and-wellness/why-mama-needs-a-good-nights-sleep\"><span style=\"text-decoration:underline\">Why Mama Needs a Good Night's Sleep</span></a></p><p><a href=\"https://bedgear.com/blogs/news/how-sleep-affects-mental-health\" target=\"_blank\" title=\"https://bedgear.com/blogs/news/how-sleep-affects-mental-health\"><span style=\"text-decoration:underline\">How Sleep Affects Mental Health</span></a></p>","align":"left"}},"faq_KVaqFA":{"type":"faq","settings":{"question":"Do mattresses really affect athletic recovery?","answer":"<p>Yes. The mattress you sleep on plays a direct role in recovery by supporting muscle repair, improving circulation, and regulating body temperature. For athletes, the right mattress reduces tossing and turning, helping you reach the deep sleep stages that fuel performance.</p>","open_by_default":false}},"faq_PCHmVH":{"type":"faq","settings":{"question":"What firmness is best for side sleepers?","answer":"<p>Most side sleepers prefer medium to medium-firm. The modular M3 and M5 allow you to choose exactly what feels right.</p>","open_by_default":false}},"faq_GimwAN":{"type":"faq","settings":{"question":"What’s the difference between M3 and M5?","answer":"<p><strong>M3</strong>: Streamlined profile, modular firmness, airflow-focused cooling.</p><p><br/><strong>M5</strong>: Taller profile, enhanced React® Comfort Layer, additional cooling upgrades, deeper pressure relief.</p>","open_by_default":false}},"faq_6fRBnD":{"type":"faq","settings":{"question":"What’s the best firmness for back pain?","answer":"<p>A <strong>medium-firm mattress</strong> is generally the best choice for back pain—it provides enough support to keep your spine aligned while still cushioning pressure points. Too soft, and your hips or midsection may sink; too firm, and key areas like shoulders and hips may feel sharp pressure.</p>","open_by_default":false}},"faq_k9kcyX":{"type":"faq","settings":{"question":"Can mattress covers be washed?","answer":"<p>Most mattress covers can be washed, but always check the care label first. Many zip-off covers are machine washable in cold water with mild detergent, while others may require spot cleaning or dry cleaning to protect waterproofing, padding, or special fabrics.</p>","open_by_default":false}},"faq_qVcngE":{"type":"faq","settings":{"question":"What mattress is best for side sleepers?","answer":"<p>Side sleepers generally do best with a <strong>medium-soft to medium firmness mattress, </strong>something that lets the shoulders and hips sink just enough while keeping your spine aligned. Look for memory foam, latex, or hybrid designs with zoned or layered support to relieve pressure where you need it most.</p>","open_by_default":false}},"faq_CTbM4a":{"type":"faq","settings":{"question":"Do modular mattresses last longer?","answer":"<p>Yes. With interchangeable parts, you can replace components instead of the entire mattress, extending product lifespan.</p>","open_by_default":false}},"callout_imGeRB":{"type":"callout","settings":{"variant":"info","bordered":false,"accent_bar":true,"title":"Sources:","content":"<p><em>1. National Sleep Foundation Study, 2022: Found that 45% of adults report overheating as the #1 disruptor of quality sleep.<br/>2. Journal of Sports Recovery, 2021: Athletes who slept on cooling mattresses recorded a 22% faster muscle recovery rate compared to those on standard foam beds.<br/>3. Sleep & Spine Health Review, 2023: Medium-firm mattresses reduce back pain symptoms in 67% of participants after just 4 weeks.<br/>4. Global Bedding Market Insights Report, 2022: The performance bedding market is projected to grow 8.9% annually due to increased demand for recovery-focused sleep products.</em></p>","align":"left"}}},"block_order":["heading_gn34aG","image_Ark9JE","text_8YQByV","heading_HJFfEM","text_URebt9","text_ynikHM","heading_piVCpV","text_aetnwL","image_pWiPdM","heading_eHMFVY","text_kKFVWz","image_RrrW4b","heading_kC8zdw","heading_6jUbB9","text_RCqfXy","quote_X4VDrL","heading_9FtKDF","text_ajKf9i","text_P3VCbE","heading_LHh8N9","text_qmtgag","heading_GdURrW","text_7J4eMw","quote_pf78EJ","heading_NhiY3U","text_jTjbay","heading_JT6wPX","text_j7QwBP","faq_KVaqFA","faq_PCHmVH","faq_GimwAN","faq_6fRBnD","faq_k9kcyX","faq_qVcngE","faq_CTbM4a","callout_imGeRB"],"disabled":true,"name":"Rich Article","settings":{"section_title":"","global_align":"left","enable_toc":false,"toc_title":"On this page","show_heading_anchors":false,"body_size":16,"heading_weight":"700","accent_color":"#00b5e3","heading_color":"#000000","body_color":"#3d3d3d","max_width":800,"block_gap":20,"padding_top":24,"padding_bottom":24,"section_bg":"#F5F5F5","enable_section_collapse":false,"section_collapse_label":"Show content","section_start_collapsed":false,"section_collapsed_max_width":820,"section_summary_bg":"rgba(0,0,0,0)","section_summary_bg_open":"rgba(0,0,0,0)","faqs_start_collapsed":false,"faqs_accordion_mode":false,"quote_style":"bar_tint"}},"shop_our_product_GhgCFP":{"type":"shop-our-product","blocks":{"column_XbEy3m":{"type":"Column","settings":{"featured_product":"night-ice-performance-pillow"}},"column_RymeAF":{"type":"Column","settings":{"featured_product":"flow-cuddle-curve-pillow"}},"column_Vyb38C":{"type":"Column","settings":{"featured_product":"dri-tec-pillow-protector"}}},"block_order":["column_XbEy3m","column_RymeAF","column_Vyb38C"],"disabled":true,"settings":{"section_heading":"Shop Our Pillows","colunm_heading_1":"Our Pillows","colunm_heading_2":"Advantages","colunm_heading_3":"What goes inside","bottom_video":"shopify://files/videos/-1d16-4d41-949d-0d35a1d788f5.mp4","text_color":"#ffffff","overlay":false,"color":"#000000","overlay_opacity":2,"bottom_heading":"Find Your Pillow ID®","bottom_description":"Because one size does not fit all, 