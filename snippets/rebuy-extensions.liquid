
{% if localization.market.handle != 'us' %}
<!-- Utilize StorefrontHelper to enrich product JSON with locale-aware titles -->
<script async src="https://cdn.rebuyengine.com/onsite/js/storefront-helper.js"></script>
<script>
  // update product JSON every time products are loaded or changed
  document.addEventListener('rebuy.productsChange', (e) => {
    const widget = e.detail.widget;
    const storefrontHelper = new ShopifyStorefrontHelper();

    // loop over products in the widget and enrich product json
    widget.data.products.forEach((product) => storefrontHelper.updateProductJSON(product));
  });
</script>
{% endif %}


<!--  Launch: Customizations for Add On Widget -->
{% if template.name == "product" %}
<script>
/* Launch: Get product price from PDP product. Use in combined subtotal for addon widget */
window.rebuyProductPrice = {{ product.selected_or_first_available_variant.price | json }};
window.rebuyNonDefaultMarket = {{ localization.country.iso_code | json }} !== 'US';
</script>     

<script>
  /*  Launch: match Rebuy widgets default option to the pdp selected option */
  class FormWatcher {
    constructor(options) {
      this.debug = false;
      this.widget = null;
      this.widgetID = null;
      this.apiKey = Rebuy.shop.api_key;
      this.formSelector = '[action="/cart/add"] [name="id"]';
      this.callback = function(){};
      this.attrMap = null;

      /* Launch: Option name aliases for cross-product variant matching */
      this.optionAliases = [
        ['Size', 'Bedding Size', 'Bedding size'],
        ['Pillow Height', 'Pillow Size', 'Left Side', 'Right Side'],
        ['Color Swatch', 'Color']
      ];
  
      if (typeof options === 'function') {
        this.callback = options;
      }
  
      if (typeof options === 'object') {
        const keys = ['formSelector', 'callback'];
  
        for (const [key, value] of Object.entries(options)) {
          if (keys.includes(key)) {
            this[key] = value;
          }
        }
      }
  
      this.init();
      this.enableFormWatch();
    }
  
    log(...args) {
      if (this.debug === true) {
        console.log.apply(console, args);
      }
    }
  
    getProductHandle(path = window.location.pathname) {
      const handles = path.match(/\/products\/([^\/]*).*$/);
      return handles ? handles[1] : null;
    }
  
    getProductJSON(handle, callback=function(){}) { 
      const url = `https://rebuyengine.com/api/v1/products/static?limit=1&key=${this.apiKey}&handles=${handle}`;
    
      fetch(url)
      .then((response)=>{ return response.json() })
      .then((response) => {
        callback(response.data[0]);
      });
    }
  
    watchFormChange(callback=function(){}) {
      const input = document.querySelector(this.formSelector);
    
      if (input) {
          input.addEventListener('change', (event) => {
              this.log('Input changed to variant ID: ', input.value);
              callback(input.value);
          });
      }
    }
  
    getVariantByID(product, variantID) {
      return product.variants.find(variant => variant.id == variantID);
    }
    
    variantAvailable(variant) {
      return !(variant.inventory_management && variant.inventory_policy == 'deny' && variant.inventory_quantity <= 0);
    }
  
    selectVariant(product, variant) {
      this.log('selected variant', product.title, variant.title)
      product.selected_variant = variant;
      product.selected_variant_id = variant.id;
      product.option1 = variant.option1;
      product.option2 = variant.option2;
      product.option3 = variant.option3;
    }
  
    getVariantAttributeMap(product, variant) {
      const map = {};
    
      if (product && variant) {
          for (let i = 0; i < product.options.length; i++) {
              const option = product.options[i];
              const optionKey = `option${i+1}`;
              map[option.name] = [variant[optionKey]];
          }
      }
    
      return map;
    }

    /* Launch: Look up attrMap value by option name, falling back to aliases */
    getAttrMapValue(attrMap, optionName) {
      if (attrMap[optionName]) return attrMap[optionName];

      const aliasGroup = this.optionAliases.find(group => group.includes(optionName));
      if (aliasGroup) {
        for (const alias of aliasGroup) {
          if (attrMap[alias]) return attrMap[alias];
        }
      }

      return null;
    }

    autoSelectVariantsByAttributeMap(products, attrMap) {
      if (products && attrMap) {
        for (let i = 0; i < products.length; i++) {
            const product = products[i];
            const productMap = {
                option1: null,
                option2: null,
                option3: null
            };
    
            for (let x = 0; x < product.options.length; x++) {
              const option = product.options[x];
              const optionKey = `option${x+1}`;
    
              const attrValue = this.getAttrMapValue(attrMap, option.name);
              if (attrValue) {
                  this.log(attrValue, option);
                  productMap[optionKey] = option.values.filter(value => value.includes(attrValue));
              }
            }
          
            if (Object.keys(productMap).length > 0) {
              let bestVariant = null;
              let bestVariantRank = 0;

              for (let x = 0; x < product.variants.length; x++) {
                  const variant = product.variants[x];
                  let variantRank = 0;

                  for (let o = 1; o <= 3; o++) {
                      const optionKey = `option${o}`;

                      if (variant[optionKey] == null && productMap[optionKey] == null) {
                          // Both null — neutral match
                          variantRank++;
                      } else if (Array.isArray(productMap[optionKey]) && productMap[optionKey].includes(variant[optionKey])) {
                          // Exact/substring match from the filter — strong match
                          variantRank += 100;
                      } else {
                          // Partial word overlap: score by how many words the variant
                          // value shares with the PDP-selected value
                          const optionName = product.options[o - 1]?.name;
                          const pdpValues = this.getAttrMapValue(attrMap, optionName);
                          if (pdpValues && pdpValues.length > 0 && variant[optionKey]) {
                              const pdpWords = pdpValues[0].toLowerCase().split(/\s+/);
                              const variantWords = variant[optionKey].toLowerCase().split(/\s+/);
                              const sharedWords = variantWords.filter(w => pdpWords.includes(w));
                              variantRank += sharedWords.length;
                          }
                      }
                  }

                  // Track the highest-ranked variant regardless of stock
                  if (variantRank > bestVariantRank) {
                    bestVariant = variant;
                    bestVariantRank = variantRank;
                  }
                }

            // Only switch if the best match exists and is in stock;
            // if it's OOS, keep the widget product's current selection
            if (bestVariant && this.variantAvailable(bestVariant)) {
              this.selectVariant(product, bestVariant);
            }

          }

        }
      }
    }
  
    updateWidgets() {
      if (this.widget) {
        this.autoSelectVariantsByAttributeMap(this.widget.data.products, this.attrMap);
      } else {
        Rebuy.widgets.forEach(widget => {
          this.autoSelectVariantsByAttributeMap(widget.data.products, this.attrMap);
        });
      }
    }
  
    init() {
      const instance = this;
  
      instance.widget = Rebuy.widgets.find(widget => widget.id == instance.widgetID);
      document.addEventListener('rebuy.init', function(event){
        if (event.detail.widget.id == instance.widgetID) {
          instance.widget = event.detail.widget;
        }
      });
    }
  
    /* Launch: Fetch product from Shopify AJAX API for market-aware variant prices */
    getShopifyVariantPrices(handle, callback=function(){}) {
      fetch(`/products/${handle}.js`)
        .then(response => response.json())
        .then(product => {
          const priceMap = {};
          product.variants.forEach(variant => {
            priceMap[variant.id] = variant.price;
          });
          callback(priceMap);
        });
    }

    enableFormWatch() {
      const instance = this;
      const handle = this.getProductHandle();

      this.getProductJSON(handle, (product) => {
        /* Launch: Cache Shopify market-aware variant prices (skip for US/default market) */
        if (window.rebuyNonDefaultMarket) {
          this.getShopifyVariantPrices(handle, (priceMap) => {
            instance.shopifyVariantPrices = priceMap;
          });
        }

        this.watchFormChange((variantID) => {
            this.callback(product,variantID);
        });

        document.addEventListener('rebuy.ready', function(event){
          const input = document.querySelector(instance.formSelector);
          instance.callback(product, input.value);

          // if (event.detail.widget.id == instance.widgetID) {
          //   const input = document.querySelector(instance.formSelector);
          //   instance.callback(product, input.value);
          // }
        });
      });
    }
  }

  /* Launch: Update ATC button price to include selected addon products */
  function updateATCButtonPrice() {
    const priceSpans = document.querySelectorAll('.add-to-cart-price');
    if (!priceSpans.length || !window.rebuyProductPrice) return;

    let addonTotal = 0;
    let hasSelectedAddon = false;

    Rebuy.widgets.forEach(widget => {
      if (widget.data && widget.data.products) {
        widget.data.products.forEach(product => {
          if (product.selected && product.selected_variant) {
            addonTotal += Rebuy.util.amountToCents(product.selected_variant.price);
            hasSelectedAddon = true;
          }
        });
      }
    });

    const displayTotal = hasSelectedAddon
      ? window.rebuyProductPrice + addonTotal
      : window.rebuyProductPrice;
console.log("displaytotal: ", displayTotal)
    const formatted = Rebuy.util.formatMoney(displayTotal);
console.log("formatted: ", formatted)
    priceSpans.forEach(priceSpan => priceSpan.textContent = 'Add to cart - ' + formatted)
  }

  /* Launch: Listen for addon checkbox toggles to update ATC button price */
  document.addEventListener('click', function(event) {
    if (event.target.closest('.rebuy-addon__item')) {
      setTimeout(updateATCButtonPrice, 50);
    }
  });

  document.addEventListener('rebuy.loaded', function() {
    const watcher = new FormWatcher(function(product, variantID) {
      const variant = this.getVariantByID(product, variantID);

      /* Launch: Update PDP product price when variant changes, for combined subtotal.
         Uses Shopify AJAX API prices (market-aware) instead of Rebuy API prices. */
      if (variant && this.shopifyVariantPrices && this.shopifyVariantPrices[variant.id]) {
        window.rebuyProductPrice = this.shopifyVariantPrices[variant.id];
      } else if (variant && variant.price) {
        window.rebuyProductPrice = Rebuy.util.amountToCents(variant.price);
      }

      this.attrMap = this.getVariantAttributeMap(product, variant);

      this.log('product', product);
      this.log('variant', variant);
      this.log('attrMap', this.attrMap);
      this.log('widget', this.widget);

      this.updateWidgets();

      /* Launch: Force Rebuy widgets to re-render so the combined subtotal reflects the new PDP price */
      Rebuy.widgets.forEach(widget => {
        if (widget.component && widget.component.$forceUpdate) {
          widget.component.$forceUpdate();
        }
      });

      /* Launch: Update ATC button after variant change and widget re-render */
      setTimeout(updateATCButtonPrice, 50);
    });
  });
</script>

