{%- comment -%}
  Renders: custom.pdp_trust_icon_with_text [metaobject_reference]
  Coverage: 90 of 98 active products
  Position: Below ATC button — 3-column navy trust bar (matches PDP design)

  Metaobject type: pdp_image_with_text (handle: "free-shipping" etc.)
  Expected fields (verify in Shopify Admin > Content > Metaobjects):
    - items  [list.metaobject_reference]  — child trust items, each with:
        - icon   [file_reference or single_line_text_field]
        - text   [single_line_text_field]
        - label  [single_line_text_field]
{%- endcomment -%}

{%- liquid
  assign trust_obj = product.metafields.custom.pdp_trust_icon_with_text.value
-%}

{%- if trust_obj != blank -%}
  {%- liquid
    assign trust_items = trust_obj.items.value | default: trust_obj.trust_items.value
  -%}

  {%- if trust_items != blank -%}
    <div class="product-trust-strip" aria-label="Trust signals">
      {%- for item in trust_items -%}
        <div class="product-trust__item">
          {%- if item.icon != blank -%}
            <span class="product-trust__icon" aria-hidden="true">
              {{- item.icon | image_url: width: 40 | image_tag: loading: 'lazy', alt: '' -}}
            </span>
          {%- endif -%}
          <div class="product-trust__copy">
            {%- if item.text != blank -%}
              <span class="product-trust__label">{{ item.text }}</span>
            {%- elsif item.label != blank -%}
              <span class="product-trust__label">{{ item.label }}</span>
            {%- endif -%}
            {%- if item.subtext != blank -%}
              <span class="product-trust__subtext">{{ item.subtext }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
{%- endif -%}

{% style %}
  .product-trust-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--brand-navy);
    border-radius: var(--brand-radius);
    margin: 16px 0;
    overflow: hidden;
  }

  .product-trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 14px 8px;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--brand-white);
    gap: 6px;
  }

  .product-trust__item:last-child {
    border-right: none;
  }

  .product-trust__icon {
    display: block;
    opacity: 0.75;
  }

  .product-trust__icon img {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .product-trust__label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--brand-white);
  }

  .product-trust__subtext {
    display: block;
    font-size: 10px;
    opacity: 0.5;
    margin-top: 1px;
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .product-trust-strip {
      grid-template-columns: repeat(3, 1fr);
    }
    .product-trust__label {
      font-size: 10px;
    }
  }
{% endstyle %}
