{%- comment -%}
  Metafield: custom.product_features [metaobject_reference]
  Metaobject fields (flat numbered pattern):
    - pdp_feature_heading           [single_line_text_field]
    - pdp_features_title_1..5       [single_line_text_field]   pill label
    - pdp_features_image_1..5       [file_reference]           (not shown in pill view)
    - pdp_features_pop_up_text_1..5 [single_line_text_field]   (not shown in pill view)

  Rendered as: horizontal row of rounded pill chips above the product title.
{%- endcomment -%}

{%- assign feat = product.metafields.custom.product_features.value -%}

{%- if feat != blank -%}
  <ul class="product-feature-pills" role="list" aria-label="Product features">
    {%- for i in (1..5) -%}
      {%- assign title_key = 'pdp_features_title_' | append: i -%}
      {%- assign feat_title = feat[title_key] -%}
      {%- if feat_title != blank -%}
        <li class="product-feature-pills__item">{{ feat_title }}</li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
{%- endif -%}

{% style %}
  .product-feature-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 0 0 12px;
  }

  .product-feature-pills__item {
    font-size: 10px;
    font-weight: 500;
    color: var(--brand-gray-700);
    border: 1px solid var(--brand-gray-300);
    border-radius: 999px;
    padding: 3px 10px;
    white-space: nowrap;
    background: transparent;
    line-height: 1.4;
  }
{% endstyle %}
