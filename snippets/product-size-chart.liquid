{%- comment -%}
  Metafield: custom.pdp_size_chart [metaobject_reference]
  Metaobject fields (size_chart type):
    - product_type         [single_line_text_field]  e.g. "Pillow", "Sheet"
    - size_chart           [single_line_text_field]  button label / guide title
    - size_chart_icon      [file_reference]          optional icon
    - size_chart_list_item [multi_line_text_field]   size guide body content

  Rendered as: a "Size Guide" button that opens a modal dialog.
  Only shown when the metafield is set and has content.
{%- endcomment -%}

{%- assign sc = product.metafields.custom.pdp_size_chart.value -%}

{%- if sc != blank and sc.size_chart_list_item != blank -%}
  {%- assign sc_label = sc.size_chart | default: 'Size Guide' -%}
  {%- assign sc_id = 'size-chart-modal-' | append: section.id -%}
  {%- liquid
    assign pt_lower = product.type | downcase
    if pt_lower contains 'pillow'
      assign modal_title = 'Your Pillow Should Fit You as Perfectly as Your Favorite Running Shoe'
    else
      assign modal_title = sc_label
    endif
  -%}

  {%- comment -%} Trigger button {%- endcomment -%}
  <button
    type="button"
    class="product-size-chart__trigger"
    aria-haspopup="dialog"
    aria-controls="{{ sc_id }}"
    onclick="document.getElementById('{{ sc_id }}').showModal()"
  >
    {%- if sc.size_chart_icon != blank -%}
      <span class="product-size-chart__icon" aria-hidden="true">
        {{- sc.size_chart_icon | image_url: width: 32 | image_tag: loading: 'lazy', alt: '' -}}
      </span>
    {%- else -%}
      <span class="product-size-chart__icon product-size-chart__icon--default" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10H3"/><path d="M21 6H3"/><path d="M21 14H3"/><path d="M21 18H3"/></svg>
      </span>
    {%- endif -%}
    <span>{{ sc_label }}</span>
    <span class="product-size-chart__arrow" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </span>
  </button>

  {%- comment -%} Modal dialog {%- endcomment -%}
  <dialog
    id="{{ sc_id }}"
    class="product-size-chart__modal"
    aria-label="{{ sc_label }}"
    onclick="if(event.target===this)this.close()"
  >
    <div class="product-size-chart__modal-inner">
      <div class="product-size-chart__modal-header">
        <div class="product-size-chart__modal-header-top">
          <h2 class="product-size-chart__modal-title">{{ modal_title }}</h2>
          <button
            type="button"
            class="product-size-chart__modal-close"
            aria-label="Close size guide"
            onclick="this.closest('dialog').close()"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

      <div class="product-size-chart__modal-body">
        <div class="product-size-chart__content" id="{{ sc_id }}-content">{{ sc.size_chart_list_item }}</div>
      </div>
    </div>
  </dialog>

  {%- if pt_lower contains 'pillow' -%}
  <script>
  (function() {
    var modalId = {{ sc_id | json }};
    var contentId = modalId + '-content';

    function patchQuiz() {
      var content = document.getElementById(contentId);
      if (!content) return;

      // ── 1. Remove "Let's Fit You For Your Pillow Height." heading ──
      content.querySelectorAll('h1,h2,h3,h4,strong,b,p').forEach(function(el) {
        if (/let.?s fit you for your pillow height/i.test(el.textContent)) {
          el.style.display = 'none';
        }
      });

      // ── 2. Move description paragraph above the header divider ──
      var header = document.querySelector('#' + modalId + ' .product-size-chart__modal-header');
      if (header && !header.querySelector('.product-size-chart__modal-subtitle')) {
        var descEl = null;
        content.querySelectorAll('p').forEach(function(p) {
          if (!descEl && /four profiles/i.test(p.textContent)) descEl = p;
        });
        if (descEl) {
          var sub = document.createElement('p');
          sub.className = 'product-size-chart__modal-subtitle';
          sub.textContent = descEl.textContent.trim();
          header.appendChild(sub);
          descEl.style.display = 'none';
        }
      }

      // ── 3. Style quiz labels ──
      content.querySelectorAll('label').forEach(function(lbl) {
        lbl.classList.add('sc-quiz-pill');
      });

      // ── 4. Move "Sleepers" note below the CTA button ──
      var sleepersEl = null;
      content.querySelectorAll('*').forEach(function(el) {
        if (!sleepersEl && el.children.length === 0 && /sleepers with your profile/i.test(el.textContent)) {
          sleepersEl = el;
        }
      });
      var ctaBtn = content.querySelector('a[href], button:not([aria-label])');
      if (sleepersEl && ctaBtn) {
        var moveTarget = sleepersEl.parentElement && sleepersEl.parentElement !== content ? sleepersEl.parentElement : sleepersEl;
        ctaBtn.parentNode.insertBefore(moveTarget, ctaBtn.nextSibling);
      }

      // ── 5. Reformat result: Medium Low inline with 1.0 in same box ──
      var observer = new MutationObserver(function() { reformatResult(content); });
      observer.observe(content, { childList: true, subtree: true, characterData: true });
      reformatResult(content);
    }

    function reformatResult(content) {
      var profilePattern = /^(Low|Medium[\s\-]?Low|Medium|Medium[\s\-]?High|High)$/i;
      var nameEl = null;
      var numberEl = null;

      content.querySelectorAll('*').forEach(function(el) {
        if (el.classList && el.classList.contains('sc-result-badge')) return;
        if (el.children.length > 0) return;
        var txt = el.textContent.trim();
        if (profilePattern.test(txt)) nameEl = el;
        if (/^\d+\.\d+$/.test(txt) && el !== nameEl) numberEl = el;
      });

      if (!nameEl || !numberEl) return;

      var profileName = nameEl.textContent.trim();
      var profileNum  = numberEl.textContent.trim();

      var existing = content.querySelector('.sc-result-badge');
      if (existing) {
        var nameSpan = existing.querySelector('.sc-result-name');
        var numSpan  = existing.querySelector('.sc-result-num');
        if (nameSpan) nameSpan.textContent = profileName;
        if (numSpan)  numSpan.textContent  = profileNum;
        return;
      }

      // Build badge: "Medium Low  1.0" in one box
      var badge = document.createElement('div');
      badge.className = 'sc-result-badge';
      badge.innerHTML = '<span class="sc-result-name">' + profileName + '</span>'
                      + '<span class="sc-result-sep"></span>'
                      + '<span class="sc-result-num">' + profileNum + '</span>';

      nameEl.parentNode.insertBefore(badge, nameEl);
      nameEl.style.display = 'none';
      numberEl.style.display = 'none';
      if (numberEl.parentElement && numberEl.parentElement !== content &&
          numberEl.parentElement.children.length === 1) {
        numberEl.parentElement.style.display = 'none';
      }
    }

    // ── Move trigger inline with the last pill variant label, right-justified ──
    // Works across product types: "Pillow Height" on pillows, "Bedding Size" on sheets, etc.
    function moveTriggerInline() {
      var trigger = document.querySelector('.product-size-chart__trigger');
      // Find the last pill fieldset's legend (main size selector is typically last)
      var targetLabel = null;
      document.querySelectorAll('.product-form__input--pill').forEach(function(fs) {
        var legend = fs.querySelector('.form__label');
        if (legend) targetLabel = legend; // keep overwriting → ends up as the last one
      });
      // Use variant-selects as positioning parent — it spans full content width
      var variantParent = document.querySelector('variant-selects') || document.querySelector('variant-radios');
      if (trigger && targetLabel && variantParent) {
        var legendTop = targetLabel.getBoundingClientRect().top;
        var parentTop = variantParent.getBoundingClientRect().top;
        variantParent.style.position = 'relative';
        trigger.style.position = 'absolute';
        trigger.style.top = Math.round(legendTop - parentTop) + 'px';
        trigger.style.right = '0';
        trigger.style.margin = '0';
        variantParent.appendChild(trigger);
      }
    }
    // Wait for full DOM + variant-selects to settle before positioning
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(moveTriggerInline, 100);
        setTimeout(moveTriggerInline, 500);
      });
    } else {
      // DOMContentLoaded already fired (script is deferred or late)
      setTimeout(moveTriggerInline, 100);
      setTimeout(moveTriggerInline, 500);
    }

    // Run after the modal opens (dialog open event)
    var dialog = document.getElementById(modalId);
    if (dialog) {
      dialog.addEventListener('click', function(e) {
        // modal opens on button click; give widget JS time to render
        setTimeout(patchQuiz, 80);
      });
      // Also patch on toggle (for browser-native open)
      dialog.addEventListener('toggle', function() {
        if (dialog.open) setTimeout(patchQuiz, 80);
      });
    }
  })();
  </script>
  {%- endif -%}
{%- endif -%}

{% style %}
  /* ── Trigger button ── */
  .product-size-chart__trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 12px 0 0;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--brand-gray-700, #374151);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--brand-gray-300, #d1d5db);
  }

  .product-size-chart__trigger:hover {
    color: var(--brand-navy, #0a1628);
    text-decoration-color: var(--brand-navy, #0a1628);
  }

  .product-size-chart__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-cyan, #00b5e3);
  }

  .product-size-chart__icon img {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .product-size-chart__arrow {
    color: var(--brand-gray-400, #9ca3af);
    display: flex;
    align-items: center;
  }

  /* ── Modal ── */
  .product-size-chart__modal {
    position: fixed;
    inset: 0;
    margin: auto;
    max-width: min(560px, calc(100vw - 32px));
    max-height: calc(100dvh - 48px);
    width: 100%;
    border: none;
    border-radius: 12px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  }

  .product-size-chart__modal::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .product-size-chart__modal[open] {
    display: flex;
    flex-direction: column;
  }

  .product-size-chart__modal-inner {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    max-height: calc(100dvh - 48px);
  }

  .product-size-chart__modal-header {
    display: flex;
    flex-direction: column;
    padding: 20px 24px;
    border-bottom: 1px solid var(--brand-gray-200, #e5e7eb);
    background: var(--brand-white, #fff);
    flex-shrink: 0;
  }

  .product-size-chart__modal-header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
  }

  .product-size-chart__modal-title {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--brand-gray-900, #111827);
    max-width: calc(100% - 48px);
    text-transform: uppercase;
  }

  .product-size-chart__modal-subtitle {
    margin: 12px 0 0;
    font-size: 13px;
    font-weight: 400;
    color: var(--brand-gray-600, #4b5563);
    line-height: 1.5;
    width: 100%;
  }

  .product-size-chart__modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--brand-gray-100, #f3f4f6);
    cursor: pointer;
    color: var(--brand-gray-600, #4b5563);
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .product-size-chart__modal-close:hover {
    background: var(--brand-gray-200, #e5e7eb);
  }

  .product-size-chart__modal-body {
    overflow-y: auto;
    padding: 24px;
    background: var(--brand-white, #fff);
    -webkit-overflow-scrolling: touch;
  }

  .product-size-chart__content {
    font-size: 13px;
    color: var(--brand-gray-700, #374151);
    line-height: 1.7;
    text-align: left !important;
  }

  .product-size-chart__content * {
    text-align: left !important;
  }

  .product-size-chart__content p { margin: 0 0 8px; }
  .product-size-chart__content p:last-child { margin-bottom: 0; }
  .product-size-chart__content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .product-size-chart__content th,
  .product-size-chart__content td {
    padding: 8px 10px;
    text-align: left;
    border: 1px solid var(--brand-gray-200, #e5e7eb);
  }
  .product-size-chart__content th {
    background: var(--brand-gray-50, #f9fafb);
    font-weight: 700;
    color: var(--brand-gray-700, #374151);
  }

  /* ── Quiz option pills — match variant picker style ── */
  .product-size-chart__content .sc-quiz-pill,
  .product-size-chart__content label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1.5px solid #dde1e6;
    border-radius: 6px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    color: #111;
    transition: border-color 0.15s ease, background 0.15s ease;
    user-select: none;
    margin: 3px 4px 3px 0;
  }

  .product-size-chart__content input[type='radio']:checked + label,
  .product-size-chart__content input[type='radio']:checked + .sc-quiz-pill,
  .product-size-chart__content label.active,
  .product-size-chart__content label.selected,
  .product-size-chart__content label.is-active {
    border-color: #0a1628 !important;
    background: #e8f2ff !important;
    color: #0a1628 !important;
    font-weight: 600 !important;
  }

  .product-size-chart__content input[type='radio'] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  /* ── Combined result badge: "Medium Low  1.0" in one box ── */
  .sc-result-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 2.5px solid #00b5e3;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 18px;
    font-weight: 700;
    color: #00b5e3;
    margin: 16px 0;
    text-align: left !important;
  }

  .sc-result-name {
    font-size: 16px;
    font-weight: 600;
  }

  .sc-result-sep {
    width: 1px;
    height: 20px;
    background: rgba(0, 181, 227, 0.4);
    flex-shrink: 0;
  }

  .sc-result-num {
    font-size: 20px;
    font-weight: 700;
  }

  @media screen and (max-width: 749px) {
    .product-size-chart__modal {
      max-width: 100%;
      max-height: 85dvh;
      border-radius: 16px 16px 0 0;
      margin: auto 0 0;
    }
  }
{% endstyle %}
