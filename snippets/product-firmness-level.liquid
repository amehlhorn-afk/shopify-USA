{%- comment -%}
  Metafield: custom.firmness_level [file_reference]
  A product-specific firmness scale image (soft / medium / firm indicator).
  Shown between the review rating and the trust strip.
  Only visible when the metafield is set.
{%- endcomment -%}

{%- assign firmness_img = product.metafields.custom.firmness_level.value -%}

{%- if firmness_img != blank -%}
  <div class="product-firmness">
    {{-
      firmness_img
      | image_url: width: 600
      | image_tag:
        loading: 'lazy',
        widths: '300, 450, 600',
        sizes: '(min-width: 990px) 300px, 100vw',
        class: 'product-firmness__image',
        alt: 'Firmness level indicator'
    -}}
  </div>
{%- endif -%}

{% style %}
  .product-firmness {
    margin: 4px 0 8px;
  }

  .product-firmness__image {
    width: 100%;
    max-width: 320px;
    height: auto;
    display: block;
  }
{% endstyle %}
