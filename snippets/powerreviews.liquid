<!-- PowerReviews Code Start -->
<script src="https://ui.powerreviews.com/stable/4.1/ui.js" async></script>
{{ 'powerreviews.css' | asset_url | stylesheet_tag }}
<script>
  window.pwr = window.pwr || function () {
  	(pwr.q = pwr.q || []).push(arguments);
  };
  {%- assign powerreviews_domain = shop.url -%}
  // can use {{ shop.url }} or hardcode
  function prRandomNumber() {
  	return Math.round((Math.random()*100000000))
  };
  const pwrCredentials = {
  	api_key: '47fff520-f385-4739-afdf-0e90788492b6',
  	locale: 'en_US',
  	merchant_group_id: '2014345704',
  	merchant_id: '1806575603'
  }
  function loadPowerReviews() {
  let pwrElements = new Array;
  /* PDP Code Start */
  if (document.getElementById('pr-reviewdisplay') && !document.getElementById('pr-reviewdisplay').dataset.prMounted) {
  	var pdpComponents = {
  		ReviewSnippet: "pr-reviewsnippet",
  		ReviewDisplay: "pr-reviewdisplay"
  	}
  	if (document.getElementById('pr-questiondisplay')) {
  		pdpComponents.QuestionDisplay = "pr-questiondisplay";
  	}
   	pwrElements.push({
  		...pwrCredentials,
  		page_id: '{{ product.id }}',
  		review_wrapper_url: '{{ powerreviews_domain }}/pages/write-a-review?pr_page_id={{ product.id }}',
  	/* Feedless Product Code Start */
  		product: {
  			name: "{{ product.title | replace: "+", " " | remove: '"' }}",
  			url: "{{ powerreviews_domain }}{{ product.url }}",
  			image_url: "https:{{ product.featured_image | product_img_url: "large" }}",
  			description: "{{ product.description | strip_html | strip_newlines | escape }}",
  			category_name: {%- if product.type != '' -%}"{{ product.type }}"{%- else -%} "Default" {%- endif -%},
  			upc: "{{ product.barcode | remove:" " | remove: '-' }}",
  			brand_name: "{{ product.vendor }}",
  			price: "{{ product.price | money_without_currency }}",
  //			asin: "{{ product.metafields.my_fields.asin }}",
  			variants: [
  				{%- for variant in product.variants -%}
  					{
  						page_id_variant: "{% if variant.sku != blank %}{{variant.sku}}{% else %}{{variant.id}}{% endif %}",
  						upc: "{{ variant.barcode | remove:" " | remove: '-' }}",
  						asin: ""
  					}{%- if forloop.last == false -%}, {%- endif -%}
  				{%- endfor -%}
  			]
  		},
  	/* Feedless Product Code End */
  	/* Enhanced SEO Code Start */
  		subject: {
  			"@context": "https://schema.org",
  			"@type": "Product",
  			name: "{{ product.title | remove: '"'}}",
  			"brand": {
  				"@type": "Brand",
  				"name": "{{ product.vendor }}"
  			},
  			description: {{ product.description | strip_html | json }},
  			image: [
  				{%- for image in product.images limit: 5 -%}
  					"https:{{ image | image_url: width: 300 }}"
  					{%- unless forloop.last -%}, {%- endunless -%}
  				{%- endfor -%}
  			],
  			offers: [{%- for variant in product.variants -%} {
  				"@type": "Offer",
  				price: {{ variant.price | money_without_currency | json }},
  				priceCurrency: "{{ cart.currency.iso_code }}",
  				itemCondition: "https://schema.org/NewCondition",
  				availability: "https://schema.org/{%- if product.available -%}InStock{%- else -%}OutOfStock{%- endif -%}",
  				itemOffered: {
  					"@type": "individualProduct",
  					name: "{{ product.title | append: ": " | append: variant.title }}",
  					{%- if variant.barcode -%}
  						gtin: "{{ variant.barcode }}",
  					{%- endif -%}
  					image: {{ shop.url | append: variant.image.src | json }},							brand: "{{ product.vendor }}",
  					"seller": {
  						"@type": "Organization",
  						"name": "{{ shop.name }}"
  					},
  				},
  				url: {{ shop.url | append: variant.url | json }}
  			}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
  		},
  	/* Enhanced SEO Code End */
  		components: pdpComponents
  	})
  };
  /* PDP Code End */
  /* PLP Code Start */
  document.querySelectorAll('[data-pr-component="CategorySnippet"]').forEach(el => {
  	if (!el.dataset.prMounted) {
  		el.id = 'snippet-' + prRandomNumber();
  		pwrElements.push({
  			...pwrCredentials,
  			page_id: el.dataset.prPageId,
  			ENABLE_CLIENT_SIDE_STRUCTURED_DATA: false,
  			components: {
  				CategorySnippet: el.id
  			}
  		})
  	}
  });
  /* PLP Code End */
  /* IRL Gallery Code Start */
  if (document.getElementById('pr-irlsnippet') && !document.getElementById('pr-irlsnippet').dataset.prMounted) {
  	pwrElements.push({
  		...pwrCredentials,
  		components: {
  			IRLSnippet: 'pr-irlsnippet',
  		}
  	})
  }
  /* IRL Gallery Code End */
  /* WAR Form Code Start */
  if (document.getElementById('pr-write') && !document.getElementById('pr-write').dataset.prMounted) {
  	pwrElements.push({
  		...pwrCredentials,
  		page_id: '{{ product.id }}',
  		on_submit:function(config, data){
  			window.scrollTo(0,0);
  		},
  		components: {
  			Write: 'pr-write'
  		}
  	})
  }
  /* WAR Form Code End */
  if (pwrElements.length > 0) {
  	pwr("render",pwrElements);
  }
  }
  loadPowerReviews();

  setTimeout(() => {
        loadPowerReviews();
    }, 3000);

    function onElementInView(entries, observer) {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                // console.log("Lazy-loaded element is in the viewport");
                loadPowerReviews();
                observer.disconnect();
            }
        });
    }

    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.25
    };

    const lazyLoadElement = '.related-products';

    const observer = new IntersectionObserver(onElementInView, observerOptions);

    const element = document.querySelector(lazyLoadElement);
    if (element) {
        observer.observe(element);
    }
</script>

<!-- PowerReviews Code End -->
