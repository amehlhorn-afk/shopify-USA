{%- comment -%}
  Renders the PowerReviews inline star rating snippet (ReviewSnippet).
  Placed as a custom_liquid block directly after the product title block
  in templates/product.json so stars + count appear under the heading.
  The actual PowerReviews render() call lives in sections/product-reviews.liquid.
{%- endcomment -%}
<div id="pr-reviewsnippet" class="pr-rating-snippet"></div>
<script>
(function () {
  function showRatingCount() {
    var rw = document.querySelector('#pr-reviewsnippet .pr-snippet-read-and-write');
    if (rw) {
      rw.style.setProperty('display', 'inline-flex', 'important');
      rw.style.setProperty('align-items', 'center', 'important');
    }
  }
  // Try on a short delay after PR renders, then again slightly later
  setTimeout(showRatingCount, 800);
  setTimeout(showRatingCount, 2000);
})();
</script>

{% style %}
  /* ── PowerReviews inline snippet ──────────────────────────────────── */
  .pr-rating-snippet {
    min-height: 0;
    margin-top: -10px;
    margin-bottom: 5px;
  }

  #pr-reviewsnippet .p-w-r,
  #pr-reviewsnippet .p-w-r * {
    font-family: var(--font-body-family) !important;
  }

  /* Stars — replace PR's baked-in SVG background-images (orange box + white star)
     with clean amber/gray star shapes. Order: base first, filled classes after. */
  #pr-reviewsnippet .pr-star-v4 {
    width: 18px !important;
    height: 18px !important;
    background-size: contain !important;
    background-repeat: no-repeat !important;
    background-color: transparent !important;
    background-image: url("data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZmlsbD0iI0QxRDVEQiIgZD0ibTEwIDEzLjUtNC4xMTQgMi4xNjMuNzg1LTQuNTgxLTMuMzI4LTMuMjQ1IDQuNi0uNjY5TDEwIDNsMi4wNTcgNC4xNjggNC42LjY2OS0zLjMyOCAzLjI0NS43ODUgNC41ODF6Ii8+PC9zdmc+") !important;
  }

  #pr-reviewsnippet .pr-star-v4-100-filled {
    background-image: url("data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZmlsbD0iI0Y1OUUwQiIgZD0ibTEwIDEzLjUtNC4xMTQgMi4xNjMuNzg1LTQuNTgxLTMuMzI4LTMuMjQ1IDQuNi0uNjY5TDEwIDNsMi4wNTcgNC4xNjggNC42LjY2OS0zLjMyOCAzLjI0NS43ODUgNC41ODF6Ii8+PC9zdmc+") !important;
  }

  #pr-reviewsnippet .pr-star-v4-50-filled {
    background-image: url("data:image/svg+xml;base64,") !important;
  }

  /* Tighten star spacing — almost touching */
  #pr-reviewsnippet .pr-star-v4 {
    margin-right: 0 !important;
  }

  /* Rating decimal — remove box, shrink 5% (14px → 13px) */
  #pr-reviewsnippet .pr-snippet-rating-decimal {
    border: none !important;
    padding: 0 !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    color: #111 !important;
    margin-left: 4px !important;
    line-height: 1 !important;
    vertical-align: middle !important;
  }

  /* Show the read-and-write container (PR hides it by default) */
  #pr-reviewsnippet .pr-snippet-read-and-write {
    display: flex !important;
    align-items: center !important;
    line-height: 1 !important;
  }

  /* Review count — show as "· N Reviews" */
  #pr-reviewsnippet .pr-snippet-rating-count {
    display: inline-flex !important;
    align-items: center !important;
    font-size: 13px !important;
    font-weight: 400 !important;
    color: #6b7280 !important;
    line-height: 1 !important;
    transform: translateY(-6px) !important;
  }

  #pr-reviewsnippet .pr-snippet-rating-count::before {
    content: " · ";
    color: #9ca3af;
  }

  /* Hide write-review link and 68% recommend block */
  #pr-reviewsnippet .pr-snippet-write-review-link,
  #pr-reviewsnippet .pr-snippet-stars-reco-reco,
  #pr-reviewsnippet .pr-snippet-reco-to-friend,
  #pr-reviewsnippet .pr-reco,
  #pr-reviewsnippet .pr-reco-yellow {
    display: none !important;
  }

  /* Keep the whole snippet row flex */
  #pr-reviewsnippet .pr-snippet-stars-reco-inline {
    display: flex !important;
    align-items: center !important;
    flex-wrap: nowrap !important;
    gap: 4px !important;
  }
{% endstyle %}
