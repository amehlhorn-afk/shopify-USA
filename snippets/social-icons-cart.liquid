{% comment %}
  Renders social icons.
  Accepts:
  - class: {String} a class to be added to the <ul> element (optional).

  Usage:
  {% render 'social-icons',
    class: 'my-class'
  %}
{% endcomment %}
{%- capture cartItems -%}
{%- for item in cart.items -%}
    {{ item.variant.id }}:{{ item.quantity }}{% unless forloop.last %},{% endunless %}
{%- endfor -%}
{%- endcapture -%}

{%- assign sharURL = settings.share_your_cart_url | append: 'cart/' | append: cartItems |  append: '?storefront=true'| url_encode  -%} 

<ul class="list-unstyled list-social{% if class %} {{ class}}{% endif %}" role="list">
    <li class="list-social__item">
        <a href="https://mail.google.com/mail/u/0/?to&su&body={{ sharURL }}&fs=1&tf=cm" target="_blank" class="link list-social__link">
          <span class="svg-wrapper">
            {{- 'icon-email.svg' | inline_asset_content -}}
          </span>
        </a>
      </li>
    <li class="list-social__item">
        <a href="https://api.whatsapp.com/send/?text={{ sharURL }}" target="_blank" class="link list-social__link">
          <span class="svg-wrapper">
            {{- 'icon-whatsapp.svg' | inline_asset_content -}}
          </span>
        </a>
      </li>
    {% comment %} {%- if settings.social_instagram_link != blank -%}
      <li class="list-social__item">
        <a href="{{ settings.social_instagram_link }}" target="_blank" class="link list-social__link">
          <span class="svg-wrapper">
            {{- 'icon-instagram.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
        </a>
      </li>
    {%- endif -%} {% endcomment %}
    {%- if settings.social_twitter_link != blank -%}
      <li class="list-social__item">
        <a href="https://twitter.com/intent/tweet?url={{ sharURL }}&text=Check%20out%20my%20cart" target="_blank" class="link list-social__link">
          <span class="svg-wrapper">
            {{- 'icon-twitter.svg' | inline_asset_content -}}
