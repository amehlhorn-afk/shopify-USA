<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  {%- comment -%}
  Global Organization + WebSite graph with sameAs for GEO/Entity alignment.
  Fill the URLs via Theme Settings or Metafields (see section B).
{%- endcomment -%}
{%- assign org_id = shop.secure_url | append: '/#organization' -%}
{%- assign website_id = shop.secure_url | append: '/#website' -%}

{%- capture sameas_list -%}
  {%- assign urls = '' | split: ',' -%}
  {%- assign candidates = '' | split: ',' -%}

  {%- comment %} Theme settings examples {% endcomment -%}
  {%- assign candidates = candidates | push: settings.social_instagram -%}
  {%- assign candidates = candidates | push: settings.social_facebook -%}
  {%- assign candidates = candidates | push: settings.social_twitter -%}
  {%- assign candidates = candidates | push: settings.social_youtube -%}
  {%- assign candidates = candidates | push: settings.social_linkedin -%}
  {%- assign candidates = candidates | push: settings.social_tiktok -%}
  {%- assign candidates = candidates | push: settings.social_pinterest -%}

  {%- comment %} Metafields (e.g., brand.reference.*) {% endcomment -%}
  {%- assign candidates = candidates | push: shop.metafields.brand.wikipedia -%}
  {%- assign candidates = candidates | push: shop.metafields.brand.wikidata -%}
  {%- assign candidates = candidates | push: shop.metafields.brand.crunchbase -%}
  {%- assign candidates = candidates | push: shop.metafields.brand.bbb -%}
  {%- assign candidates = candidates | push: shop.metafields.brand.amazon_brand_store -%}

  {%- for c in candidates -%}
    {%- if c and c != '' -%}
      {%- assign urls = urls | push: c -%}
    {%- endif -%}
  {%- endfor -%}

  [
  {%- for u in urls -%}
    "{{ u | strip }}"
    {%- if forloop.last == false -%},{%- endif -%}
  {%- endfor -%}
  ]
{%- endcapture -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "{{ website_id }}",
      "url": "{{ shop.secure_url }}",
      "name": "{{ shop.name | escape }}",
      "publisher": { "@id": "{{ org_id }}" },
      "inLanguage": "{{ request.locale.iso_code | default: 'en' }}"
    },
    {
      "@type": ["Organization","Brand"],
      "@id": "{{ org_id }}",
      "name": "{{ shop.name | escape }}",
      "url": "{{ shop.secure_url }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ settings.logo | img_url: '400x' | prepend: 'https:' }}",
        "caption": "{{ shop.name | escape }}"
      },
      "sameAs": {{ sameas_list | strip }}
    }
  ]
}
</script>

